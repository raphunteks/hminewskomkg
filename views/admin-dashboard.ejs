                        <label for="kohatiActiveCheck" style="margin:0; cursor:pointer;">Tampilkan Fitur KOHATI</label>
                    </div>
                    <button type="submit" class="btn btn-primary" style="width:100%; background:#f472b6; border-color:#f472b6; color:#fff;">Simpan Status KOHATI</button>
