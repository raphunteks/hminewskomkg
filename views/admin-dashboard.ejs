                                    </td>
                                </tr>
                                <% }) %>
                                <% if(bioLinks.length === 0) { %><tr><td colspan="4" style="text-align:center; color:#9ca3af;">Belum ada link yang dibuat.</td></tr><% } %>
                            </tbody>
                        </table>
                    </div>
                <% } %>
            </div>
            
        </div>
        
        <div class="admin-sidebar">
            <div class="glass admin-panel" style="margin-bottom:0;">
                <h3 class="panel-title" style="margin-bottom:15px; color:#8b5cf6;"><i data-lucide="info"></i> Info Fitur</h3>
                <p style="color:#d1d5db; font-size:0.9rem; line-height:1.6;">Fitur <strong>Link in Bio</strong> berfungsi seperti Linktree atau msh.ke. Anda dapat membagikan URL pendek (misal: <code>domain.com/links</code>) ke bio Instagram atau TikTok.</p>
                <p style="color:#d1d5db; font-size:0.9rem; line-height:1.6; margin-top:10px;">Anda bisa membuat <strong>Banyak Halaman</strong> dengan tampilan dan tombol yang berbeda-beda. Gunakan fitur edit teks untuk mengubah warna, ukuran, dan ketebalan tulisan.</p>
            </div>
        </div>
    </div>
</div>

