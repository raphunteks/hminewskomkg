<%- include('partials/header') %>

<div class="glass dashboard-header">
    <div class="admin-info">
        <!-- AVATAR ADMIN MENGGUNAKAN LOGO -->
        <div class="admin-icon">
            <img src="/img/logo-hmikomkgumi.png" alt="Admin HMI">
        </div>
        <div>
            <h2>Dashboard Admin</h2>
            <p class="text-muted" style="margin:0;">Selamat datang, Anda login sebagai Admin.</p>
        </div>
    </div>
    <a href="/admin/logout" class="btn btn-danger"><i data-lucide="log-out" style="width:18px;"></i> Logout</a>
</div>

<div class="grid-3" style="align-items: start;">
    <!-- Bagian Kiri (Berisi Berita dan Kepengurusan) -->
    <div style="grid-column: span 2; display:flex; flex-direction:column; gap:30px;">
        
        <!-- Panel Berita -->
        <div class="glass" style="padding: 25px;">
            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:20px; border-bottom:1px solid rgba(255,255,255,0.1); padding-bottom:15px;">
                <h3 style="display:flex; align-items:center; gap:10px; margin:0;"><i data-lucide="file-text" class="text-primary"></i> Kelola Berita</h3>
                <button class="btn btn-primary" onclick="openModal('modalBerita')" style="padding:8px 15px; font-size:0.85rem;">+ Tambah Berita</button>
            </div>
            
            <div style="overflow-x:auto;">
                <table class="admin-table">
                    <thead>
                        <tr>
                            <th>Judul Berita</th>
                            <th>Kategori</th>
                            <th style="text-align:right;">Aksi</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% news.forEach(item => { %>
                        <tr>
                            <td style="font-weight:600;"><%= item.title %></td>
                            <td><span style="background:rgba(255,255,255,0.1); padding:5px 10px; border-radius:5px; font-size:0.8rem;"><%= item.category %></span></td>
                            <td style="text-align:right; white-space:nowrap;">
                                <form action="/admin/hapus-berita/<%= item.id %>" method="POST" style="display:inline-block;">
                                    <button type="submit" class="action-btn delete" onclick="return confirm('Yakin ingin menghapus berita ini?')" title="Hapus Berita"><i data-lucide="trash-2" style="width:16px;"></i></button>
                                </form>
                            </td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Panel Kelola Pengurus Utama -->
        <div class="glass" style="padding: 25px;">
            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:20px; border-bottom:1px solid rgba(255,255,255,0.1); padding-bottom:15px;">
                <h3 style="display:flex; align-items:center; gap:10px; margin:0;"><i data-lucide="users" class="text-primary"></i> Kelola Pengurus Harian</h3>
                <div>
                    <button class="btn btn-primary" onclick="openModal('modalPengurus')" style="padding:8px 15px; font-size:0.85rem; margin-right:5px;">+ Pengurus</button>
                    <button class="btn" onclick="openModal('modalBidang')" style="padding:8px 15px; font-size:0.85rem; background:rgba(255,255,255,0.1); color:#fff; border:1px solid rgba(255,255,255,0.2);">+ Buat Bidang Baru</button>
                </div>
            </div>
            
            <div style="overflow-x:auto;">
                <table class="admin-table">
                    <thead>
                        <tr>
                            <th>Foto</th>
                            <th>Nama Pengurus</th>
                            <th>Jabatan</th>
                            <th style="text-align:right;">Aksi</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% pengurus.forEach(person => { %>
                        <tr>
                            <td><img src="<%= person.image %>" style="width:40px; height:40px; border-radius:50%; object-fit:cover;"></td>
                            <td style="font-weight:600;"><%= person.name %></td>
                            <td style="color:#4ade80; font-size:0.85rem;"><%= person.role %></td>
                            <td style="text-align:right; white-space:nowrap;">
                                <!-- Tombol Edit -->
                                <button class="action-btn edit" onclick="openEditPengurusModal('<%= person.id %>', '<%= person.name %>', '<%= person.role %>')" title="Edit Data Pengurus"><i data-lucide="edit" style="width:16px;"></i></button>
                                <!-- Tombol Hapus -->
                                <form action="/admin/hapus-pengurus/<%= person.id %>" method="POST" style="display:inline-block;">
                                    <button type="submit" class="action-btn delete" onclick="return confirm('Yakin menghapus pengurus ini?')" title="Hapus Pengurus"><i data-lucide="trash-2" style="width:16px;"></i></button>
                                </form>
                            </td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>

            <!-- List Bidang & Anggotanya -->
            <div style="margin-top: 20px; padding-top: 20px; border-top: 1px dashed rgba(255,255,255,0.1);">
                <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:15px;">
                    <h4 style="font-size: 1rem; color: #fff;">Daftar Bidang & Anggota</h4>
                </div>
                
                <div style="display:flex; flex-direction:column; gap:15px;">
                    <% bidang.forEach(b => { %>
                        <div style="background:rgba(0,0,0,0.3); padding:15px; border-radius:12px; border:1px solid rgba(255,255,255,0.05);">
                            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:15px; border-bottom:1px solid rgba(255,255,255,0.1); padding-bottom:10px;">
                                <h5 style="color:#4ade80; font-size:1.1rem; margin:0;"><%= b.name %></h5>
                                <div>
                                    <button type="button" class="btn btn-primary" style="padding:4px 10px; font-size:0.75rem;" onclick="openModalAnggotaBidang('<%= b.id %>', '<%= b.name %>')">+ Tambah Anggota</button>
                                    <form action="/admin/hapus-bidang/<%= b.id %>" method="POST" style="display:inline-block; margin-left:5px;">
                                        <button type="submit" class="action-btn delete" onclick="return confirm('Hapus seluruh bidang ini beserta anggotanya?')" title="Hapus Bidang"><i data-lucide="trash-2" style="width:14px;"></i></button>
                                    </form>
                                </div>
                            </div>
                            
                            <!-- List members -->
                            <div style="display:grid; grid-template-columns: repeat(auto-fill, minmax(130px, 1fr)); gap:15px;">
                                <% if(b.members && b.members.length > 0) { %>
                                    <% b.members.forEach(m => { %>
                                        <div style="background:rgba(255,255,255,0.05); padding:10px; border-radius:8px; text-align:center; position:relative;">
                                            <img src="<%= m.image %>" style="width:50px; height:50px; border-radius:50%; object-fit:cover; margin:0 auto 10px; border:2px solid rgba(34,197,94,0.3);">
                                            <p style="font-size:0.8rem; font-weight:bold; margin:0;"><%= m.name %></p>
                                            
                                            <!-- Tombol Hapus Anggota -->
                                            <form action="/admin/hapus-anggota-bidang/<%= b.id %>/<%= m.id %>" method="POST" style="position:absolute; top:5px; right:5px;">
                                                <button type="submit" style="background:rgba(239,68,68,0.2); color:#ef4444; border:none; border-radius:4px; padding:2px; cursor:pointer; transition:0.3s;" onclick="return confirm('Hapus anggota ini dari bidang?')" onmouseover="this.style.background='rgba(239,68,68,0.4)'" onmouseout="this.style.background='rgba(239,68,68,0.2)'"><i data-lucide="x" style="width:12px; height:12px;"></i></button>
                                            </form>
                                        </div>
                                    <% }) %>
                                <% } else { %>
                                    <p style="font-size:0.8rem; color:#9ca3af; margin:0; grid-column: 1 / -1;">Belum ada anggota di bidang ini.</p>
                                <% } %>
                            </div>
                        </div>
                    <% }) %>
                </div>
            </div>
        </div>

    </div>

    <!-- Sidebar Kanan Tools -->
    <div style="display:flex; flex-direction:column; gap:30px;">
        
        <!-- Panel Galeri Kegiatan -->
        <div class="glass" style="padding: 25px;">
            <h3 style="display:flex; align-items:center; gap:10px; margin-bottom:20px; border-bottom:1px solid rgba(255,255,255,0.1); padding-bottom:15px;"><i data-lucide="image" class="text-primary"></i> Kelola Galeri Kegiatan</h3>
            <button class="btn" onclick="openModal('modalAlbum')" style="width:100%; background:rgba(255,255,255,0.1); color:#fff; margin-bottom:20px; border:1px solid rgba(255,255,255,0.2);">+ Tambah Galeri Foto</button>
            <ul style="display:flex; flex-direction:column; gap:10px;">
                <% albums.forEach(album => { %>
                <li style="background:rgba(0,0,0,0.3); padding:12px; border-radius:10px; display:flex; justify-content:space-between; align-items:center;">
                    <span style="font-size:0.85rem; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;"><%= album.title %></span>
                    <form action="/admin/hapus-album/<%= album.id %>" method="POST" style="display:inline-block;">
                        <button type="submit" class="action-btn delete" style="padding:5px;" onclick="return confirm('Hapus album ini?')"><i data-lucide="trash-2" style="width:16px;"></i></button>
                    </form>
                </li>
                <% }) %>
            </ul>
        </div>

        <!-- Panel Data Anggota -->
        <div class="glass" style="padding: 25px; text-align:center;">
            <div style="width:60px; height:60px; margin:0 auto 15px; background:rgba(34,197,94,0.2); border-radius:50%; display:flex; align-items:center; justify-content:center;">
                <i data-lucide="upload-cloud" class="text-primary" style="width:30px; height:30px;"></i>
            </div>
            <h3 style="font-size:1.1rem;">Upload PDF Anggota</h3>
            <p class="text-muted" style="font-size:0.8rem; margin-bottom:20px;">Gantikan file PDF lama di halaman publik.</p>
            <form>
                <input type="file" id="pdf-upload" accept=".pdf" style="display:none;">
                <label for="pdf-upload" class="btn btn-primary" style="width:100%;">Pilih File PDF</label>
            </form>
        </div>
    </div>
</div>

<!-- ================= MODALS AREA ================= -->

<!-- Modal Tambah Berita -->
<div class="modal-overlay" id="modalBerita">
    <div class="modal-content">
        <div class="modal-header">
            <h3>Tambah Berita Baru</h3>
            <button class="close-modal" onclick="closeModal('modalBerita')"><i data-lucide="x"></i></button>
        </div>
        <form action="/admin/tambah-berita" method="POST" enctype="multipart/form-data">
            <div class="form-group">
                <label>Judul Berita</label>
                <input type="text" name="title" class="input-control" required placeholder="Contoh: Kegiatan HMI KomKGUMI">
            </div>
            <div class="form-group">
                <label>Kategori</label>
                <select name="category" class="input-control" required style="background:#1f2937;">
                    <option value="Terbaru">Terbaru</option>
                    <option value="Populer">Populer</option>
                    <option value="Pin">Pin (Disematkan)</option>
                    <option value="Lama">Lama (Old)</option>
                </select>
            </div>
            <div class="form-group">
                <label>Isi Berita</label>
                <textarea name="content" class="input-control" rows="4" required placeholder="Tulis deskripsi berita di sini..."></textarea>
            </div>
            <div class="form-group">
                <label>Upload Foto Berita</label>
                <input type="file" name="image" class="input-control file-compress" accept="image/*" required>
            </div>
            <button type="submit" class="btn btn-primary submit-btn" style="width:100%;">Simpan Berita</button>
        </form>
    </div>
</div>

<!-- Modal Tambah Galeri / Album -->
<div class="modal-overlay" id="modalAlbum">
    <div class="modal-content">
        <div class="modal-header">
            <h3>Tambah Galeri Kegiatan</h3>
            <button class="close-modal" onclick="closeModal('modalAlbum')"><i data-lucide="x"></i></button>
        </div>
        <form action="/admin/tambah-album" method="POST" enctype="multipart/form-data">
            <div class="form-group">
                <label>Judul Kegiatan</label>
                <input type="text" name="title" class="input-control" required placeholder="Contoh: Basic Training I">
            </div>
            <div class="form-group">
                <label>Upload Foto Utama (Cover)</label>
                <input type="file" name="cover" class="input-control file-compress" accept="image/*" required>
            </div>
            <button type="submit" class="btn btn-primary submit-btn" style="width:100%;">Simpan Galeri</button>
        </form>
    </div>
</div>

<!-- Modal Tambah Pengurus Utama -->
<div class="modal-overlay" id="modalPengurus">
    <div class="modal-content">
        <div class="modal-header">
            <h3>Tambah Pengurus Utama</h3>
            <button class="close-modal" onclick="closeModal('modalPengurus')"><i data-lucide="x"></i></button>
        </div>
        <form action="/admin/tambah-pengurus" method="POST" enctype="multipart/form-data">
            <div class="form-group">
                <label>Nama Lengkap</label>
                <input type="text" name="name" class="input-control" required placeholder="Nama lengkap pengurus">
            </div>
            <div class="form-group">
                <label>Jabatan</label>
                <input type="text" name="role" class="input-control" required placeholder="Contoh: Ketua Umum / Sekretaris">
            </div>
            <div class="form-group">
                <label>Upload Foto Pengurus</label>
                <input type="file" name="image" class="input-control file-compress" accept="image/*" required>
            </div>
            <button type="submit" class="btn btn-primary submit-btn" style="width:100%;">Simpan Pengurus</button>
        </form>
    </div>
</div>

<!-- Modal Edit Pengurus Utama -->
<div class="modal-overlay" id="modalEditPengurus">
    <div class="modal-content">
        <div class="modal-header">
            <h3>Edit Pengurus</h3>
            <button class="close-modal" onclick="closeModal('modalEditPengurus')"><i data-lucide="x"></i></button>
        </div>
        <form id="formEditPengurus" method="POST" enctype="multipart/form-data">
            <div class="form-group">
                <label>Nama Lengkap</label>
                <input type="text" name="name" id="editPengurusName" class="input-control" required>
            </div>
            <div class="form-group">
                <label>Jabatan</label>
                <input type="text" name="role" id="editPengurusRole" class="input-control" required>
            </div>
            <div class="form-group">
                <label>Upload Foto Baru (Opsional)</label>
                <input type="file" name="image" class="input-control file-compress" accept="image/*">
                <p style="font-size:0.75rem; color:#9ca3af; margin-top:5px;">Kosongkan jika tidak ingin mengubah foto.</p>
            </div>
            <button type="submit" class="btn btn-primary submit-btn" style="width:100%;">Update Data Pengurus</button>
        </form>
    </div>
</div>

<!-- Modal Buat Bidang Baru -->
<div class="modal-overlay" id="modalBidang">
    <div class="modal-content">
        <div class="modal-header">
            <h3>Tambah Bidang Baru</h3>
            <button class="close-modal" onclick="closeModal('modalBidang')"><i data-lucide="x"></i></button>
        </div>
        <form action="/admin/tambah-bidang" method="POST">
            <div class="form-group">
                <label>Nama Bidang</label>
                <input type="text" name="bidang_name" class="input-control" required placeholder="Contoh: Bidang Humas">
            </div>
            <button type="submit" class="btn btn-primary" style="width:100%;">Buat Bidang</button>
        </form>
    </div>
</div>

<!-- Modal Tambah Anggota Bidang -->
<div class="modal-overlay" id="modalAnggotaBidang">
    <div class="modal-content">
        <div class="modal-header">
            <h3 id="anggotaBidangTitle">Tambah Anggota Bidang</h3>
            <button class="close-modal" onclick="closeModal('modalAnggotaBidang')"><i data-lucide="x"></i></button>
        </div>
        <form id="formAnggotaBidang" method="POST" enctype="multipart/form-data">
            <div class="form-group">
                <label>Nama Lengkap Anggota</label>
                <input type="text" name="name" class="input-control" required placeholder="Nama lengkap">
            </div>
            <div class="form-group">
                <label>Upload Foto Anggota</label>
                <input type="file" name="image" class="input-control file-compress" accept="image/*" required>
            </div>
            <button type="submit" class="btn btn-primary submit-btn" style="width:100%;">Simpan Anggota Bidang</button>
        </form>
    </div>
</div>

<script>
    // Logic Untuk Modal Biasa
    function openModal(modalId) {
        document.getElementById(modalId).classList.add('active');
    }
    function closeModal(modalId) {
        document.getElementById(modalId).classList.remove('active');
    }

    // Logic Khusus Modal Edit Pengurus
    function openEditPengurusModal(id, name, role) {
        document.getElementById('editPengurusName').value = name;
        document.getElementById('editPengurusRole').value = role;
        document.getElementById('formEditPengurus').action = '/admin/edit-pengurus/' + id;
        openModal('modalEditPengurus');
    }

    // Logic Khusus Modal Tambah Anggota Ke Bidang Tertentu
    function openModalAnggotaBidang(bidangId, bidangName) {
        document.getElementById('anggotaBidangTitle').innerText = "Tambah Anggota: " + bidangName;
        document.getElementById('formAnggotaBidang').action = '/admin/tambah-anggota-bidang/' + bidangId;
        openModal('modalAnggotaBidang');
    }

    // ==============================================================================
    // SCRIPT AUTO-COMPRESS GAMBAR (MENCEGAH ERROR 413 VERCEL & UPSTASH 1MB LIMIT)
    // ==============================================================================
    async function compressImage(file, maxWidth = 1000) {
        return new Promise((resolve) => {
            const reader = new FileReader();
            reader.readAsDataURL(file);
            reader.onload = (event) => {
                const img = new Image();
                img.src = event.target.result;
                img.onload = () => {
                    const canvas = document.createElement('canvas');
                    let width = img.width;
                    let height = img.height;
                    if (width > maxWidth) {
                        height = Math.round((height * maxWidth) / width);
                        width = maxWidth;
                    }
                    canvas.width = width;
                    canvas.height = height;
                    const ctx = canvas.getContext('2d');
                    ctx.drawImage(img, 0, 0, width, height);
                    // Kompresi ke format WEBP (jauh lebih ringan dari JPG/PNG) kualitas 60%
                    resolve(canvas.toDataURL('image/webp', 0.6)); 
                };
            };
        });
    }

    document.querySelectorAll('.file-compress').forEach(input => {
        input.addEventListener('change', async (e) => {
            const file = e.target.files[0];
            if (file && file.type.startsWith('image/')) {
                const submitBtn = input.closest('form').querySelector('.submit-btn');
                const originalText = submitBtn.innerText;
                
                // Beri indikator ke user bahwa proses kompresi sedang berjalan
                submitBtn.innerText = 'Mengompresi Gambar... Tunggu sebentar';
                submitBtn.disabled = true;

                // Lakukan kompresi
                const base64 = await compressImage(file);
                
                // Simpan hasil kompresi di input text tersembunyi
                let hidden = input.parentElement.querySelector('.b64-hidden');
                if (!hidden) {
                    hidden = document.createElement('input');
                    hidden.type = 'hidden';
                    hidden.name = input.name + '_b64';
                    hidden.className = 'b64-hidden';
                    input.parentElement.appendChild(hidden);
                }
                hidden.value = base64;

                // Kembalikan tombol seperti semula
                submitBtn.innerText = originalText;
                submitBtn.disabled = false;
            }
        });
    });
</script>

<%- include('partials/footer') %>
