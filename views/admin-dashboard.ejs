<%- include('partials/header') %>

<script src="https://unpkg.com/lucide@latest"></script>
<link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
<script src="https://cdn.quilljs.com/1.3.6/quill.min.js"></script>

<div class="glass dashboard-header">
    <div class="admin-info">
        <div class="admin-icon"><img src="<%= siteSettings.headerLogo %>" alt="Admin HMI"></div>
        <div>
            <h2>Dashboard Admin</h2>
            <p class="text-muted" style="margin:0;">Kelola Website HMI KomKGUMI</p>
        </div>
    </div>
    <a href="/admin/logout" class="btn btn-danger"><i data-lucide="log-out" style="width:18px;"></i> Logout</a>
</div>

<div class="admin-tab-nav">
    <button class="admin-tab-btn active" onclick="openAdmTab('adm-kelola', this)"><i data-lucide="database"></i> Kelola Data</button>
    <button class="admin-tab-btn" onclick="openAdmTab('adm-setelan', this)"><i data-lucide="settings"></i> Header, Footer & Tentang</button>
    <button class="admin-tab-btn" onclick="openAdmTab('adm-bio', this)"><i data-lucide="smartphone"></i> Link in Bio</button>
    <button class="admin-tab-btn" onclick="openAdmTab('adm-shortlink', this)"><i data-lucide="link"></i> Shortlink Custom</button>
    <button class="admin-tab-btn" onclick="openAdmTab('adm-announce', this)"><i data-lucide="bell"></i> Announcement Pop-up</button>
</div>

<div id="adm-kelola" class="admin-tab-pane active">
    <div class="admin-layout">
        <div class="admin-main-content">
            <div class="glass admin-panel" style="margin-bottom:0;">
                <div class="panel-header">
                    <h3 class="panel-title"><i data-lucide="file-text"></i> Kelola Berita</h3>
                    <button class="btn btn-primary" onclick="openModal('modalBerita')" style="padding:8px 15px; font-size:0.85rem;">+ Tambah Berita</button>
                </div>
                <div class="table-wrapper">
                    <table class="admin-table">
                        <thead><tr><th>Judul Berita</th><th>Kategori</th><th style="text-align:right;">Aksi</th></tr></thead>
                        <tbody>
                            <% news.forEach(item => { %>
                            <tr>
                                <td class="fw-600"><%= item.title %><div style="font-size:0.75rem; color:#4ade80; margin-top:3px;"><%= item.date %></div></td>
                                <td><span class="cat-badge"><%= item.category %></span></td>
                                <td class="td-actions">
                                    <div id="raw-content-<%= item.id %>" style="display: none;"><%- item.content %></div>
                                    <button type="button" class="action-btn" style="color:#fff;" onclick="openKelolaFotoBerita('<%= item.id %>')" title="Kelola Foto"><i data-lucide="image-plus"></i></button>
                                    <button type="button" class="action-btn edit" onclick="openEditBeritaModal('<%= item.id %>', '<%= item.title.replace(/'/g, "\\'") %>', '<%= item.category %>', '<%= item.date %>')" title="Edit Berita"><i data-lucide="edit"></i></button>
                                    <form action="/admin/hapus-berita/<%= item.id %>" method="POST" class="form-inline"><button type="submit" class="action-btn delete" onclick="return confirm('Hapus berita?')"><i data-lucide="trash-2"></i></button></form>
                                </td>
                            </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="glass admin-panel" style="margin-bottom:0;">
                <div class="panel-header">
                    <h3 class="panel-title"><i data-lucide="users"></i> Pengurus Harian (Umum)</h3>
                    <div class="panel-actions">
                        <button class="btn btn-primary" onclick="openModal('modalPengurus')" style="padding:8px 15px; font-size:0.85rem;">+ Pengurus</button>
                        <button class="btn btn-secondary" onclick="openModal('modalBidang')" style="padding:8px 15px; font-size:0.85rem;">+ Buat Bidang</button>
                    </div>
                </div>
                <div class="table-wrapper">
                    <table class="admin-table">
                        <thead><tr><th>Foto</th><th>Nama Pengurus</th><th>Jabatan</th><th style="text-align:right;">Aksi</th></tr></thead>
                        <tbody>
                            <% pengurus.forEach(person => { %>
                            <tr>
                                <td><img src="<%= person.image %>" style="width:40px; height:40px; border-radius:50%; object-fit:cover;"></td>
                                <td class="fw-600"><%= person.name %></td>
                                <td style="color:#4ade80; font-size:0.85rem;"><%= person.role %></td>
                                <td class="td-actions">
                                    <!-- UPGRADE PARAMETER: Menyertakan link sosmed termasuk TikTok -->
                                    <button type="button" class="action-btn edit" onclick="openEditDynamic('<%= person.id %>', '<%= person.name.replace(/'/g, "\\'") %>', '<%= person.role.replace(/'/g, "\\'") %>', '/admin/edit-pengurus/', '<%= person.ig ? person.ig.replace(/'/g, "\\'") : '' %>', '<%= person.fb ? person.fb.replace(/'/g, "\\'") : '' %>', '<%= person.twitter ? person.twitter.replace(/'/g, "\\'") : '' %>', '<%= person.linkedin ? person.linkedin.replace(/'/g, "\\'") : '' %>', '<%= person.tiktok ? person.tiktok.replace(/'/g, "\\'") : '' %>')"><i data-lucide="edit"></i></button>
                                    <form action="/admin/hapus-pengurus/<%= person.id %>" method="POST" class="form-inline"><button type="submit" class="action-btn delete" onclick="return confirm('Yakin?')"><i data-lucide="trash-2"></i></button></form>
                                </td>
                            </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
                <div class="bidang-container">
                    <h4 class="bidang-container-title">Daftar Bidang & Anggota</h4>
                    <div class="bidang-list">
                        <% bidang.forEach(b => { %>
                            <div class="bidang-card">
                                <div class="bidang-header">
                                    <div style="display:flex; align-items:center; gap:10px;">
                                        <h5 class="bidang-title"><%= b.name %></h5>
                                        <button class="action-btn edit" style="padding:4px; border:none; background:none;" onclick="openEditBidangModal('<%= b.id %>', '<%= b.name.replace(/'/g, "\\'") %>', '/admin/edit-bidang/')"><i data-lucide="edit"></i></button>
                                    </div>
                                    <div>
                                        <button type="button" class="btn btn-primary" style="padding:4px 10px; font-size:0.75rem;" onclick="openModalAnggotaBidang('<%= b.id %>', '<%= b.name.replace(/'/g, "\\'") %>', '/admin/tambah-anggota-bidang/')">+ Anggota</button>
                                        <form action="/admin/hapus-bidang/<%= b.id %>" method="POST" class="form-inline" style="margin-left:5px;"><button type="submit" class="action-btn delete" onclick="return confirm('Hapus seluruh bidang?')"><i data-lucide="trash-2" style="width:14px; height:14px;"></i></button></form>
                                    </div>
                                </div>
                                <div class="bidang-members-grid">
                                    <% if(b.members && b.members.length > 0) { b.members.forEach(m => { %>
                                        <div class="member-card">
                                            <img src="<%= m.image %>" class="member-avatar">
                                            <p class="member-name"><%= m.name %></p>
                                            <p style="font-size:0.75rem; color:#4ade80; margin-top:3px; font-weight:bold;"><%= m.role || '' %></p>
                                            <!-- UPGRADE PARAMETER: Menyertakan link sosmed termasuk TikTok -->
                                            <button type="button" class="action-btn edit" style="position:absolute; top:5px; left:5px; padding:2px; background:rgba(96,165,250,0.2); border:none;" onclick="openEditAnggotaBidangModal('<%= b.id %>', '<%= m.id %>', '<%= m.name.replace(/'/g, "\\'") %>', '<%= (m.role || '').replace(/'/g, "\\'") %>', '/admin/edit-anggota-bidang/', '<%= m.ig ? m.ig.replace(/'/g, "\\'") : '' %>', '<%= m.fb ? m.fb.replace(/'/g, "\\'") : '' %>', '<%= m.twitter ? m.twitter.replace(/'/g, "\\'") : '' %>', '<%= m.linkedin ? m.linkedin.replace(/'/g, "\\'") : '' %>', '<%= m.tiktok ? m.tiktok.replace(/'/g, "\\'") : '' %>')"><i data-lucide="edit" style="width:12px;"></i></button>
                                            <form action="/admin/hapus-anggota-bidang/<%= b.id %>/<%= m.id %>" method="POST" class="member-delete-btn"><button type="submit" style="background:transparent; border:none; color:inherit; cursor:pointer;" onclick="return confirm('Hapus anggota?')"><i data-lucide="x"></i></button></form>
                                        </div>
                                    <% }) } else { %><p class="empty-member">Belum ada anggota.</p><% } %>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                </div>
            </div>

            <div class="glass admin-panel" style="margin-bottom:0; border: 1px solid rgba(244,114,182,0.3);">
                <div class="panel-header">
                    <h3 class="panel-title" style="color:#f472b6;"><i data-lucide="heart" style="color:#f472b6;"></i> Pengurus Harian (KOHATI)</h3>
                    <div class="panel-actions">
                        <button class="btn btn-primary" style="background:#f472b6; box-shadow:0 4px 15px rgba(244,114,182,0.3); color:#fff;" onclick="openModal('modalKohatiPengurus')">+ Pengurus</button>
                        <button class="btn btn-secondary" onclick="openModal('modalKohatiBidang')">+ Bidang Kohati</button>
                    </div>
                </div>
                <div class="table-wrapper">
                    <table class="admin-table">
                        <thead><tr><th>Foto</th><th>Nama Pengurus</th><th>Jabatan</th><th style="text-align:right;">Aksi</th></tr></thead>
                        <tbody>
                            <% kohatiPengurus.forEach(person => { %>
                            <tr>
                                <td><img src="<%= person.image %>" style="width:40px; height:40px; border-radius:50%; object-fit:cover;"></td>
                                <td class="fw-600"><%= person.name %></td>
                                <td style="color:#f472b6; font-size:0.85rem;"><%= person.role %></td>
                                <td class="td-actions">
                                    <button type="button" class="action-btn edit" onclick="openEditDynamic('<%= person.id %>', '<%= person.name.replace(/'/g, "\\'") %>', '<%= person.role.replace(/'/g, "\\'") %>', '/admin/edit-kohati-pengurus/', '<%= person.ig ? person.ig.replace(/'/g, "\\'") : '' %>', '<%= person.fb ? person.fb.replace(/'/g, "\\'") : '' %>', '<%= person.twitter ? person.twitter.replace(/'/g, "\\'") : '' %>', '<%= person.linkedin ? person.linkedin.replace(/'/g, "\\'") : '' %>', '<%= person.tiktok ? person.tiktok.replace(/'/g, "\\'") : '' %>')"><i data-lucide="edit"></i></button>
                                    <form action="/admin/hapus-kohati-pengurus/<%= person.id %>" method="POST" class="form-inline"><button type="submit" class="action-btn delete" onclick="return confirm('Hapus pengurus kohati?')"><i data-lucide="trash-2"></i></button></form>
                                </td>
                            </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
                <div class="bidang-container">
                    <h4 class="bidang-container-title" style="color:#f472b6;">Bidang & Anggota (KOHATI)</h4>
                    <div class="bidang-list">
                        <% kohatiBidang.forEach(b => { %>
                            <div class="bidang-card">
                                <div class="bidang-header">
                                    <div style="display:flex; align-items:center; gap:10px;">
                                        <h5 class="bidang-title" style="color:#f472b6;"><%= b.name %></h5>
                                        <button class="action-btn edit" style="padding:4px; border:none; background:none;" onclick="openEditBidangModal('<%= b.id %>', '<%= b.name.replace(/'/g, "\\'") %>', '/admin/edit-kohati-bidang/')"><i data-lucide="edit"></i></button>
                                    </div>
                                    <div>
                                        <button type="button" class="btn" style="background:#f472b6; color:#fff; padding:4px 10px; font-size:0.75rem;" onclick="openModalAnggotaBidang('<%= b.id %>', '<%= b.name.replace(/'/g, "\\'") %>', '/admin/tambah-anggota-kohati-bidang/')">+ Anggota</button>
                                        <form action="/admin/hapus-kohati-bidang/<%= b.id %>" method="POST" class="form-inline" style="margin-left:5px;"><button type="submit" class="action-btn delete" onclick="return confirm('Hapus seluruh bidang?')"><i data-lucide="trash-2" style="width:14px; height:14px;"></i></button></form>
                                    </div>
                                </div>
                                <div class="bidang-members-grid">
                                    <% if(b.members && b.members.length > 0) { b.members.forEach(m => { %>
                                        <div class="member-card">
                                            <img src="<%= m.image %>" class="member-avatar" style="border-color:rgba(244,114,182,0.5);">
                                            <p class="member-name"><%= m.name %></p>
                                            <p style="font-size:0.75rem; color:#f472b6; margin-top:3px; font-weight:bold;"><%= m.role || '' %></p>
                                            <button type="button" class="action-btn edit" style="position:absolute; top:5px; left:5px; padding:2px; background:rgba(96,165,250,0.2); border:none;" onclick="openEditAnggotaBidangModal('<%= b.id %>', '<%= m.id %>', '<%= m.name.replace(/'/g, "\\'") %>', '<%= (m.role || '').replace(/'/g, "\\'") %>', '/admin/edit-anggota-kohati-bidang/', '<%= m.ig ? m.ig.replace(/'/g, "\\'") : '' %>', '<%= m.fb ? m.fb.replace(/'/g, "\\'") : '' %>', '<%= m.twitter ? m.twitter.replace(/'/g, "\\'") : '' %>', '<%= m.linkedin ? m.linkedin.replace(/'/g, "\\'") : '' %>', '<%= m.tiktok ? m.tiktok.replace(/'/g, "\\'") : '' %>')"><i data-lucide="edit" style="width:12px;"></i></button>
                                            <form action="/admin/hapus-anggota-kohati-bidang/<%= b.id %>/<%= m.id %>" method="POST" class="member-delete-btn"><button type="submit" style="background:transparent; border:none; color:inherit; cursor:pointer;" onclick="return confirm('Hapus anggota kohati?')"><i data-lucide="x"></i></button></form>
                                        </div>
                                    <% }) } else { %><p class="empty-member">Belum ada anggota.</p><% } %>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                </div>
            </div>
        </div>

        <div class="admin-sidebar">
            <div class="glass admin-panel" style="margin-bottom:0;">
                <h3 class="panel-title" style="margin-bottom:20px; border-bottom:1px solid rgba(255,255,255,0.1); padding-bottom:15px;"><i data-lucide="image"></i> Kelola Galeri</h3>
                <button class="btn btn-add-album" onclick="openModal('modalAlbum')">+ Tambah Galeri Baru</button>
                <div class="album-list">
                    <% albums.forEach(album => { %>
                    <div class="list-item-album">
                        <span class="list-item-title"><strong><%= album.title %></strong><br><small style="color:#4ade80;"><%= album.date %></small></span>
                        <div style="display:flex; gap:5px;">
                            <button type="button" class="action-btn" style="color:#fff;" onclick="openKelolaFotoAlbum('<%= album.id %>')"><i data-lucide="image-plus"></i></button>
                            <button type="button" class="action-btn edit" onclick="openEditAlbumModal('<%= album.id %>', '<%= album.title.replace(/'/g, "\\'") %>', '<%= album.date %>')"><i data-lucide="edit"></i></button>
                            <form action="/admin/hapus-album/<%= album.id %>" method="POST" class="form-inline"><button type="submit" class="action-btn delete" onclick="return confirm('Hapus album?')"><i data-lucide="trash-2"></i></button></form>
                        </div>
                    </div>
                    <% }) %>
                </div>
            </div>

            <% let safeDataAnggota = (typeof dataAnggota !== 'undefined' && dataAnggota) ? dataAnggota : []; %>
            <div class="glass admin-panel" style="margin-bottom:0;">
                <h3 class="panel-title" style="margin-bottom:20px; border-bottom:1px solid rgba(255,255,255,0.1); padding-bottom:15px;"><i data-lucide="folder-open"></i> Data Anggota (PDF)</h3>
                
                <% if(safeDataAnggota.length === 0) { %>
                    <div style="background: rgba(34,197,94,0.1); border: 1px dashed rgba(34,197,94,0.4); padding: 15px; border-radius: 12px; margin-bottom: 20px;">
                        <p style="color:#4ade80; font-size:0.85rem; margin-bottom:10px;"><i data-lucide="info" style="width:16px; display:inline-block; vertical-align:middle;"></i> <strong>Sistem Otomatis:</strong> Saat ini web menggunakan File PDF Bawaan.</p>
                        <p style="color:#d1d5db; font-size:0.8rem; margin-bottom:15px;">Untuk mengubah atau menimpa file default tersebut, Anda cukup membuat data baru. File default lama akan otomatis tergantikan!</p>
                        <button class="btn btn-primary" onclick="openModal('modalDataAnggota')" style="width:100%; box-shadow: 0 4px 15px rgba(34,197,94,0.3);"><i data-lucide="upload"></i> Upload & Ubah File Default</button>
                    </div>
                <% } else { %>
                    <button class="btn btn-add-album" onclick="openModal('modalDataAnggota')" style="margin-bottom: 20px;">+ Upload PDF Anggota Baru</button>
                <% } %>

                <div class="album-list">
                    <% safeDataAnggota.forEach((item, index) => { %>
                    <div class="list-item-album" style="<%= index === 0 ? 'border-left: 4px solid #4ade80;' : '' %>">
                        <span class="list-item-title">
                            <strong><%= item.title %></strong>
                            <% if(index === 0) { %><span class="badge" style="font-size:0.6rem; padding:2px 6px; margin-left:5px;">Aktif di Web</span><% } %>
                            <br><small style="color:#4ade80;"><%= item.date %></small>
                        </span>
                        <div style="display:flex; gap:5px;">
                            <button type="button" class="action-btn" style="color:#fff;" onclick="window.open('<%= item.file %>', '_blank')" title="Lihat PDF"><i data-lucide="eye"></i></button>
                            <button type="button" class="action-btn edit" onclick="openEditDataAnggotaModal('<%= item.id %>', '<%= item.title.replace(/'/g, "\\'") %>', '<%= item.date %>')" title="Edit Data"><i data-lucide="edit"></i></button>
                            <form action="/admin/hapus-data-anggota/<%= item.id %>" method="POST" class="form-inline"><button type="submit" class="action-btn delete" onclick="return confirm('Hapus PDF ini? Jika ini satu-satunya data, web akan kembali ke file default bawaan.')" title="Hapus Data"><i data-lucide="trash-2"></i></button></form>
                        </div>
                    </div>
                    <% }) %>
                    
                    <% if(safeDataAnggota.length === 0) { %>
                        <div class="list-item-album" style="opacity: 0.6; border: 1px dashed rgba(255,255,255,0.2);">
                            <span class="list-item-title"><strong>Data Anggota Komisariat (Default)</strong><br><small style="color:#9ca3af;">/data-anggota.pdf</small></span>
                            <div style="display:flex; gap:5px;">
                                <button type="button" class="action-btn" style="color:#fff;" onclick="window.open('/data-anggota.pdf', '_blank')" title="Lihat PDF"><i data-lucide="eye"></i></button>
                                <button type="button" class="action-btn edit" disabled style="opacity:0.5; cursor:not-allowed;" title="Tidak bisa diedit langsung, buat data baru untuk menimpa"><i data-lucide="edit"></i></button>
                                <button type="button" class="action-btn delete" disabled style="opacity:0.5; cursor:not-allowed;" title="Tidak bisa dihapus, buat data baru untuk menimpa"><i data-lucide="trash-2"></i></button>
                            </div>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ==============================================================
     TAB 2: SETELAN WEB
============================================================== -->
<div id="adm-setelan" class="admin-tab-pane">
    <div class="grid-2">
        <div style="display:flex; flex-direction:column; gap:30px;">
            <div class="glass admin-panel" style="margin-bottom:0;">
                <h3 class="panel-title" style="margin-bottom:20px;"><i data-lucide="layout"></i> Setelan Header & Web</h3>
                <form action="/admin/setelan-header" method="POST" enctype="multipart/form-data">
                    <div class="form-group"><label>Judul Web (Title Tab/Browser)</label><input type="text" name="webTitle" class="input-control" value="<%= siteSettings.webTitle %>"></div>
                    <div class="form-group"><label>Judul Hero (Welcome Halaman Beranda)</label><input type="text" name="heroTitle" class="input-control" value="<%= siteSettings.heroTitle %>"></div>
                    <div class="form-group"><label>Teks Logo Kiri (Awal)</label><input type="text" name="headerTitle" class="input-control" value="<%= siteSettings.headerTitle %>"></div>
                    <div class="form-group"><label>Teks Logo Kanan (Warna Hijau)</label><input type="text" name="headerHighlight" class="input-control" value="<%= siteSettings.headerHighlight %>"></div>
                    <div class="form-group"><label>Teks Bawah Logo</label><input type="text" name="headerSubtitle" class="input-control" value="<%= siteSettings.headerSubtitle %>"></div>
                    <div class="form-group"><label>Logo Header & Favicon</label><input type="file" name="headerLogo" class="input-control file-compress" accept="image/*"></div>
                    
                    <h4 style="color:#4ade80; margin-top:35px; margin-bottom:15px; border-bottom:1px solid rgba(255,255,255,0.1); padding-bottom:10px; display:flex; align-items:center; gap:8px;">
                        <i data-lucide="search" style="width:18px;"></i> Setelan SEO & Open Graph
                    </h4>
                    <p class="text-muted" style="font-size:0.85rem; margin-bottom:15px;">Konfigurasi agar website tampil profesional di pencarian Google dan saat dibagikan ke WhatsApp, Facebook, atau Twitter.</p>
                    
                    <div class="form-group">
                        <label>Deskripsi Penelusuran (Meta Description)</label>
                        <textarea name="seoDescription" class="input-control" rows="3" placeholder="Contoh: Website Resmi Himpunan Mahasiswa Islam Komisariat Kedokteran Gigi UMI"><%= siteSettings.seoDescription %></textarea>
                    </div>
                    <div class="form-group">
                        <label>Kata Kunci (Meta Keywords)</label>
                        <input type="text" name="seoKeywords" class="input-control" value="<%= siteSettings.seoKeywords %>" placeholder="hmi komkg umi, hmikomkgumi, hmi, hmi kom kg umi, hmicabmakassar, yakusa">
                    </div>
                    <div class="form-group">
                        <label>Cover / Thumbnail Link (OG Image)</label>
                        <input type="file" name="seoImage" class="input-control file-compress" accept="image/*">
                        <% if(siteSettings.seoImage) { %>
                            <div style="margin-top:10px;">
                                <img src="<%= siteSettings.seoImage %>" style="height:80px; border-radius:8px; border:1px solid rgba(255,255,255,0.2); object-fit:cover;">
                            </div>
                        <% } %>
                    </div>

                    <button type="submit" class="btn btn-primary submit-btn" style="width:100%; margin-top:15px;">Simpan Perubahan Header & SEO</button>
                </form>
            </div>

            <div class="glass admin-panel" style="margin-bottom:0; border-top: 4px solid #3b82f6;">
                <h3 class="panel-title" style="margin-bottom:20px; color: #60a5fa;"><i data-lucide="align-bottom"></i> Setelan Footer</h3>
                <form action="/admin/setelan-footer" method="POST" enctype="multipart/form-data">
                    <div class="form-group"><label>Logo Footer</label><input type="file" name="footerLogo" class="input-control file-compress" accept="image/*"></div>
                    <div class="form-group"><label>Teks Judul Footer</label><input type="text" name="footerTitle" class="input-control" value="<%= siteSettings.footerTitle %>"></div>
                    <div class="form-group"><label>Deskripsi Footer</label><textarea name="footerDesc" class="input-control" rows="3"><%= siteSettings.footerDesc %></textarea></div>
                    <div class="form-group"><label>Teks Hak Cipta (Copyright)</label><input type="text" name="footerCopyright" class="input-control" value="<%= siteSettings.footerCopyright %>"></div>
                    <div class="form-group"><label>Teks Programmer / Watermark</label><input type="text" name="footerProgrammer" class="input-control" value="<%= siteSettings.footerProgrammer %>"></div>
                    <button type="submit" class="btn btn-primary submit-btn" style="width:100%; margin-top:5px; background: #3b82f6; border-color: #3b82f6;">Simpan Perubahan Footer</button>
                </form>

                <h4 style="margin:30px 0 15px; border-top:1px solid rgba(255,255,255,0.1); padding-top:20px; color: #60a5fa;">Daftar Sosial Media Footer</h4>
