        <div class="glass admin-panel" style="margin-bottom:0; align-self:start;">
            <h3 class="panel-title" style="margin-bottom:20px;"><i data-lucide="file-text"></i> Halaman Tentang Kami</h3>
            
            <% 
            function cleanText(str) {
                if(!str) return '';
                let s = String(str);
                s = s.replace(/<p[^>]*>/gi, '');
                s = s.replace(/<\/p>/gi, '\n\n');
                s = s.replace(/<li[^>]*>/gi, '• ');
                s = s.replace(/<\/li>/gi, '\n');
                s = s.replace(/<br\s*[\/]?>/gi, '\n');
                s = s.replace(/<[^>]+>/g, ''); 
                s = s.replace(/&nbsp;/g, ' ').replace(/&amp;/g, '&');
                return s.replace(/\n\s*\n\s*\n/g, '\n\n').trim();
            }
            %>

            <form action="/admin/setelan-tentang" method="POST" enctype="multipart/form-data">
                
                <h4 style="color:#4ade80; margin-bottom:15px; border-bottom:1px solid rgba(255,255,255,0.1); padding-bottom:10px;">Bagian Profil Umum</h4>
                <div class="form-group"><label>Teks Profil (Bagian Atas)</label><textarea name="profilText" class="input-control" rows="5" placeholder="Ketik profil di sini..."><%= cleanText(siteSettings.profilText) %></textarea></div>
                <div class="form-group"><label>Teks Welcome (Sambutan)</label><textarea name="welcomeText" class="input-control" rows="5" placeholder="Ketik sambutan di sini..."><%= cleanText(siteSettings.welcomeText) %></textarea></div>
                
                <h4 style="color:#4ade80; margin-top:30px; margin-bottom:15px; border-bottom:1px solid rgba(255,255,255,0.1); padding-bottom:10px;">Bagian Visi & Misi Umum</h4>
                <div class="form-group"><label>Teks Visi Umum</label><textarea name="visiText" class="input-control" rows="4"><%= cleanText(siteSettings.visiText) %></textarea></div>
                <div class="form-group"><label>Teks Misi Umum</label><textarea name="misiText" class="input-control" rows="5"><%= cleanText(siteSettings.misiText) %></textarea></div>
                
                <div class="form-group" style="margin-top:30px;">
                    <label>Embed Code Google Maps (Iframe)</label>
                    <textarea name="mapsEmbed" class="input-control" rows="3"><%= siteSettings.mapsEmbed %></textarea>
                </div>
                
                <div class="form-group" style="margin-top:30px; background: rgba(0,0,0,0.2); padding: 15px; border-radius: 12px; border: 1px dashed rgba(255,255,255,0.2);">
                    <label style="color:#4ade80; font-size:1rem; border-bottom:1px solid rgba(255,255,255,0.1); padding-bottom:8px;">Upload Booklet / Pedoman PDF</label>
                    <p class="text-muted" style="font-size:0.8rem; margin-bottom: 15px;">Pilih salah satu metode di bawah. Disarankan menggunakan Link Google Drive.</p>
                    <label style="font-size:0.85rem;">Metode 1: Link Google Drive (Sangat Disarankan)</label>
                    <input type="url" name="bookletPdfUrl" class="input-control" placeholder="Paste link Google Drive disini...">
                    <div style="text-align:center; color:#9ca3af; margin: 15px 0; font-size:0.8rem; font-weight:bold;">ATAU</div>
                    <label style="font-size:0.85rem;">Metode 2: Upload File Lokal (Maksimal 1 MB)</label>
                    <input type="file" name="bookletPdf" class="input-control file-to-b64" accept="application/pdf">
                    <% if(siteSettings.bookletPdf) { %><p class="form-hint" style="color:#4ade80; margin-top:10px;">✅ Status: File/Link Booklet sudah tersedia dan aktif.</p><% } %>
                </div>
                
                <div class="form-group" style="margin-top:40px; border-top:1px solid rgba(244,114,182,0.3); padding-top:20px;">
                    <h4 style="color:#f472b6; margin-bottom:15px;"><i data-lucide="heart" style="width:16px;"></i> Konten Halaman Kohati</h4>
                    <label style="margin-top:15px;">Teks Profil KOHATI</label><textarea name="kohatiProfilText" class="input-control" rows="4"><%= cleanText(siteSettings.kohatiProfilText) %></textarea>
                    <label style="margin-top:15px;">Teks Visi KOHATI</label><textarea name="kohatiVisiText" class="input-control" rows="3"><%= cleanText(siteSettings.kohatiVisiText) %></textarea>
                    <label style="margin-top:15px;">Teks Misi KOHATI</label><textarea name="kohatiMisiText" class="input-control" rows="5"><%= cleanText(siteSettings.kohatiMisiText) %></textarea>
                </div>
                
                <button type="submit" class="btn btn-primary submit-btn" style="width:100%; margin-top:20px;">Simpan Halaman Tentang & PDF</button>
            </form>
        </div>
    </div>
</div>

