<script>
    function openAdmTab(tabId, btn) {
        document.querySelectorAll('.admin-tab-pane').forEach(tab => tab.classList.remove('active'));
        document.querySelectorAll('.admin-tab-btn').forEach(b => b.classList.remove('active'));
        document.getElementById(tabId).classList.add('active');
        btn.classList.add('active');
        window.dispatchEvent(new Event('resize'));
    }

    document.addEventListener('DOMContentLoaded', function() {
        if (typeof Quill !== 'undefined') {
            var toolbarOptions = [['bold', 'italic', 'underline', 'strike'], ['blockquote'], [{ 'header': 1 }, { 'header': 2 }], [{ 'list': 'ordered'}, { 'list': 'bullet' }], [{ 'color': [] }, { 'background': [] }], [{ 'align': [] }], ['clean']];
            var qConfig = { theme: 'snow', modules: { toolbar: toolbarOptions } };
            var qConfigMini = { theme: 'snow', modules: { toolbar: [['bold', 'italic', 'underline'], [{ 'color': [] }, { 'background': [] }], [{ 'font': [] }], [{ 'size': ['small', false, 'large', 'huge'] }], [{ 'align': [] }], ['clean']] } };
            
            var quillTambah = new Quill('#quill-tambah', qConfig);
            var quillEdit = new Quill('#quill-edit', qConfig);

            // QUILL UNTUK BIO LINK (RICH TEXT)
            var qTambahBioTitle = new Quill('#quill-tambah-bio-title', qConfigMini);
            var qEditBioTitle = new Quill('#quill-edit-bio-title', qConfigMini);
            var qTambahLinkTitle = new Quill('#quill-tambah-link-title', qConfigMini);
            var qEditLinkTitle = new Quill('#quill-edit-link-title', qConfigMini);

            document.getElementById('formTambahBerita').onsubmit = function() { 
                document.getElementById('content-tambah').value = quillTambah.root.innerHTML; 
            };
            document.getElementById('formEditBerita').onsubmit = function() { 
                document.getElementById('content-edit').value = quillEdit.root.innerHTML; 
            };

            // SUBMIT UNTUK BIO LINK
            document.getElementById('formTambahBioPage').onsubmit = function() {
                document.getElementById('hidden-tambah-bio-title').value = qTambahBioTitle.root.innerHTML;
            };
            document.getElementById('formEditBioPage').onsubmit = function() {
                document.getElementById('hidden-edit-bio-title').value = qEditBioTitle.root.innerHTML;
            };
            document.getElementById('formTambahBioLink').onsubmit = function() {
                document.getElementById('hidden-tambah-link-title').value = qTambahLinkTitle.root.innerHTML;
            };
            document.getElementById('formEditBioLink').onsubmit = function() {
                document.getElementById('hidden-edit-link-title').value = qEditLinkTitle.root.innerHTML;
            };
            
            // FUNGSI BUKA MODAL BIO PAGE & LINK yang membutuhkan Quill
            window.openEditBioPageModal = function(id, path, bio, bgType, bgValue) {
                document.getElementById('editBioPagePath').value = path;
                document.getElementById('editBioPageBio').value = bio;
                
                qEditBioTitle.root.innerHTML = document.getElementById('raw-bio-title-' + id).innerHTML;

                if(bgType === 'gradient') {
                    document.getElementById('editBioPageBgGradient').value = bgValue;
                } else {
                    document.getElementById('editBioPageBgGradient').value = ""; 
                }

                document.getElementById('formEditBioPage').action = '/admin/edit-bio-page/' + id;
                openModal('modalEditBioPage');
            };

            window.openEditBioLinkModal = function(id, bioPageId, url) {
                document.getElementById('editBioLinkPageId').value = bioPageId;
                document.getElementById('editBioLinkUrl').value = url;
                
                qEditLinkTitle.root.innerHTML = document.getElementById('raw-link-title-' + id).innerHTML;

                document.getElementById('formEditBioLink').action = '/admin/edit-biolink/' + id;
                openModal('modalEditBioLink');
            };

            window.openEditBeritaModal = function(id, title, category, date) {
                document.getElementById('editBeritaTitle').value = title; 
                document.getElementById('editBeritaCategory').value = category; 
                document.getElementById('editBeritaDate').value = date;
                quillEdit.root.innerHTML = document.getElementById('raw-content-' + id).innerHTML;
                document.getElementById('formEditBerita').action = '/admin/edit-berita/' + id; 
                openModal('modalEditBerita');
            };

        }
        
        if (typeof lucide !== 'undefined') lucide.createIcons();
    });

    function openModal(modalId) { document.getElementById(modalId).classList.add('active'); }
    function closeModal(modalId) { document.getElementById(modalId).classList.remove('active'); }

    // FUNGSI MODAL BAWAAN
    function openEditSosmedModal(id, name, url) {
        document.getElementById('editSosmedName').value = name;
        document.getElementById('editSosmedUrl').value = url;
        document.getElementById('formEditSosmed').action = '/admin/edit-sosmed/' + id;
        openModal('modalEditSosmed');
    }

    function openEditDataAnggotaModal(id, title, date) { document.getElementById('editDataAnggotaTitle').value = title; document.getElementById('editDataAnggotaDate').value = date; document.getElementById('formEditDataAnggota').action = '/admin/edit-data-anggota/' + id; openModal('modalEditDataAnggota'); }

    function openKelolaFotoBerita(id) {
        const berita = newsData.find(n => n.id == id); if(!berita) return;
        document.getElementById('kelolaFotoBeritaTitle').innerText = 'Kelola Foto: ' + berita.title;
        document.getElementById('formTambahFotoBerita').action = '/admin/tambah-foto-berita/' + id;
        const grid = document.getElementById('existingPhotosBeritaGrid'); grid.innerHTML = '';
        if (berita.photos && berita.photos.length > 0) {
            berita.photos.forEach(p => {
                grid.innerHTML += `<div style="position:relative; background:rgba(255,255,255,0.05); padding:5px; border-radius:8px;"><img src="${p.url}" style="width:100%; height:80px; object-fit:cover; border-radius:4px;"><form action="/admin/hapus-foto-berita/${berita.id}/${p.id}" method="POST" style="position:absolute; top:8px; right:8px;"><button type="submit" style="background:rgba(239,68,68,0.8); color:#fff; border:none; border-radius:4px; padding:4px; cursor:pointer;" onclick="return confirm('Hapus foto ini?')"><i data-lucide="trash-2" style="width:14px; height:14px;"></i></button></form></div>`;
            });
            if (typeof lucide !== 'undefined') lucide.createIcons();
        } else { grid.innerHTML = '<p class="text-muted" style="grid-column: 1 / -1;">Belum ada foto.</p>'; }
        openModal('modalKelolaFotoBerita');
    }

    function openEditDynamic(id, name, role, actionPath) {
        document.getElementById('editDynamicName').value = name;
        document.getElementById('editDynamicRole').value = role;
        document.getElementById('formEditDynamic').action = actionPath + id;
        openModal('modalEditDynamic');
    }

    function openEditBidangModal(id, name, actionPath) { document.getElementById('editBidangName').value = name; document.getElementById('formEditBidang').action = actionPath + id; openModal('modalEditBidang'); }
    
    function openModalAnggotaBidang(bidangId, bidangName, actionPath) { 
        document.getElementById('anggotaBidangTitle').innerText = "Tambah Anggota: " + bidangName; 
        document.getElementById('editAnggotaBidangName').value = "";
        document.getElementById('editAnggotaBidangRole').value = ""; 
        document.getElementById('formAnggotaBidang').action = actionPath + bidangId; 
        openModal('modalAnggotaBidang'); 
    }
    
    function openEditAnggotaBidangModal(bidangId, memberId, name, role, actionPath) { 
        document.getElementById('anggotaBidangTitle').innerText = "Edit Anggota"; 
        document.getElementById('editAnggotaBidangName').value = name; 
        document.getElementById('editAnggotaBidangRole').value = role; 
        document.getElementById('formAnggotaBidang').action = actionPath + bidangId + "/" + memberId; 
        openModal('modalAnggotaBidang'); 
    }

    function openEditAlbumModal(id, title, date) { document.getElementById('editAlbumTitle').value = title; document.getElementById('editAlbumDate').value = date; document.getElementById('formEditAlbum').action = '/admin/edit-album/' + id; openModal('modalEditAlbum'); }
    
    function openKelolaFotoAlbum(id) {
        const album = albumsData.find(a => a.id == id); if(!album) return;
        document.getElementById('kelolaFotoTitle').innerText = 'Kelola Foto: ' + album.title;
        document.getElementById('formTambahFotoAlbum').action = '/admin/tambah-foto-album/' + id;
        const grid = document.getElementById('existingPhotosGrid'); grid.innerHTML = '';
        if (album.photos && album.photos.length > 0) {
            album.photos.forEach(p => {
                grid.innerHTML += `<div style="position:relative; background:rgba(255,255,255,0.05); padding:5px; border-radius:8px;"><img src="${p.url}" style="width:100%; height:80px; object-fit:cover; border-radius:4px;"><form action="/admin/hapus-foto-album/${album.id}/${p.id}" method="POST" style="position:absolute; top:8px; right:8px;"><button type="submit" style="background:rgba(239,68,68,0.8); color:#fff; border:none; border-radius:4px; padding:4px; cursor:pointer;" onclick="return confirm('Hapus foto?')"><i data-lucide="trash-2" style="width:14px; height:14px;"></i></button></form></div>`;
            });
            if (typeof lucide !== 'undefined') lucide.createIcons();
        } else { grid.innerHTML = '<p class="text-muted" style="grid-column: 1 / -1;">Belum ada foto.</p>'; }
        openModal('modalKelolaFotoAlbum');
    }

    function openEditShortlinkModal(id, title, path, url) {
        document.getElementById('editShortlinkTitle').value = title; document.getElementById('editShortlinkPath').value = path; document.getElementById('editShortlinkUrl').value = url;
        document.getElementById('formEditShortlink').action = '/admin/edit-shortlink/' + id; openModal('modalEditShortlink');
    }

    async function compressImage(file, maxWidth = 1000) {
        return new Promise((resolve) => {
            const reader = new FileReader(); reader.readAsDataURL(file);
            reader.onload = (event) => {
                const img = new Image(); img.src = event.target.result;
                img.onload = () => {
                    const canvas = document.createElement('canvas'); let width = img.width; let height = img.height;
                    if (width > maxWidth) { height = Math.round((height * maxWidth) / width); width = maxWidth; }
                    canvas.width = width; canvas.height = height; const ctx = canvas.getContext('2d'); ctx.drawImage(img, 0, 0, width, height);
                    resolve(canvas.toDataURL('image/webp', 0.6)); 
                };
            };
        });
    }

    document.querySelectorAll('.file-compress').forEach(input => {
        input.addEventListener('change', async (e) => {
            const file = e.target.files[0];
            if (file && file.type.startsWith('image/')) {
                const submitBtn = input.closest('form').querySelector('.submit-btn');
                const originalText = submitBtn.innerText; submitBtn.innerText = 'Mengompresi Gambar...'; submitBtn.disabled = true;
                const base64 = await compressImage(file);
                let hidden = input.parentElement.querySelector('.b64-hidden');
                if (!hidden) { hidden = document.createElement('input'); hidden.type = 'hidden'; hidden.name = input.name + '_b64'; hidden.className = 'b64-hidden'; input.parentElement.appendChild(hidden); }
                hidden.value = base64; submitBtn.innerText = originalText; submitBtn.disabled = false;
            }
        });
    });

    document.querySelectorAll('.file-compress-multiple').forEach(input => {
        input.addEventListener('change', async (e) => {
            const files = e.target.files;
            if (files && files.length > 0) {
                const submitBtn = input.closest('form').querySelector('.submit-btn-multi');
                const originalText = submitBtn.innerText; submitBtn.innerText = 'Memproses ' + files.length + ' Foto...'; submitBtn.disabled = true;
                input.parentElement.querySelectorAll('.b64-hidden-multi').forEach(el => el.remove());
                for(let i=0; i < files.length; i++) {
                    if (files[i].type.startsWith('image/')) {
                        const base64 = await compressImage(files[i]);
                        const hidden = document.createElement('input'); hidden.type = 'hidden'; hidden.name = 'photos_b64'; hidden.className = 'b64-hidden-multi'; hidden.value = base64;
                        input.parentElement.appendChild(hidden);
                    }
                }
                submitBtn.innerText = originalText; submitBtn.disabled = false;
            }
        });
    });

    document.querySelectorAll('.file-to-b64').forEach(input => {
        input.addEventListener('change', async (e) => {
            const file = e.target.files[0];
            if (file) {
                const submitBtn = input.closest('form').querySelector('.submit-btn');
                const originalText = submitBtn.innerText; submitBtn.innerText = 'Memproses PDF...'; submitBtn.disabled = true;
                const reader = new FileReader(); reader.readAsDataURL(file);
                reader.onload = () => {
                    let hidden = input.parentElement.querySelector('.b64-hidden');
                    if (!hidden) { hidden = document.createElement('input'); hidden.type = 'hidden'; hidden.name = input.name + '_b64'; hidden.className = 'b64-hidden'; input.parentElement.appendChild(hidden); }
                    hidden.value = reader.result; submitBtn.innerText = originalText; submitBtn.disabled = false;
                };
            }
        });
    });
</script>

