            album.photos.forEach(p => {
                grid.innerHTML += `<div style="position:relative; background:rgba(255,255,255,0.05); padding:5px; border-radius:8px;"><img src="${p.url}" style="width:100%; height:80px; object-fit:cover; border-radius:4px;"><form action="/admin/hapus-foto-album/${album.id}/${p.id}" method="POST" style="position:absolute; top:8px; right:8px;"><button type="submit" style="background:rgba(239,68,68,0.8); color:#fff; border:none; border-radius:4px; padding:4px; cursor:pointer;" onclick="return confirm('Hapus foto?')"><i data-lucide="trash-2" style="width:14px; height:14px;"></i></button></form></div>`;
