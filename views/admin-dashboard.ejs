<%- include('partials/header') %>

<div class="glass dashboard-header">
    <div class="admin-info">
        <div class="admin-icon"><img src="<%= siteSettings.headerLogo %>" alt="Admin HMI"></div>
        <div>
            <h2>Dashboard Admin</h2>
            <p class="text-muted" style="margin:0;">Kelola Website HMI KomKGUMI</p>
        </div>
    </div>
    <a href="/admin/logout" class="btn btn-danger"><i data-lucide="log-out" style="width:18px;"></i> Logout</a>
</div>

<!-- NAVIGASI TAB ADMIN -->
<div class="admin-tab-nav">
    <button class="admin-tab-btn active" onclick="openAdmTab('adm-kelola', this)"><i data-lucide="database"></i> Kelola Data</button>
    <button class="admin-tab-btn" onclick="openAdmTab('adm-setelan', this)"><i data-lucide="settings"></i> Header, Footer & Tentang</button>
    <button class="admin-tab-btn" onclick="openAdmTab('adm-shortlink', this)"><i data-lucide="link"></i> Shortlink Custom</button>
    <button class="admin-tab-btn" onclick="openAdmTab('adm-announce', this)"><i data-lucide="bell"></i> Announcement Pop-up</button>
</div>

<!-- ==============================================================
     TAB 1: KELOLA DATA UTAMA & KOHATI
============================================================== -->
<div id="adm-kelola" class="admin-tab-pane active">
    <div class="admin-layout">
        
        <div class="admin-main-content">
            <div class="glass admin-panel" style="margin-bottom:0;">
                <div class="panel-header">
                    <h3 class="panel-title"><i data-lucide="file-text"></i> Kelola Berita</h3>
                    <button class="btn btn-primary" onclick="openModal('modalBerita')" style="padding:8px 15px; font-size:0.85rem;">+ Tambah Berita</button>
                </div>
                <div class="table-wrapper">
                    <table class="admin-table">
                        <thead><tr><th>Judul Berita</th><th>Kategori</th><th style="text-align:right;">Aksi</th></tr></thead>
                        <tbody>
                            <% news.forEach(item => { %>
                            <tr>
                                <td class="fw-600"><%= item.title %><div style="font-size:0.75rem; color:#4ade80; margin-top:3px;"><%= item.date %></div></td>
                                <td><span class="cat-badge"><%= item.category %></span></td>
                                <td class="td-actions">
                                    <div id="raw-content-<%= item.id %>" style="display: none;"><%- item.content %></div>
                                    <button type="button" class="action-btn" style="color:#fff;" onclick="openKelolaFotoBerita('<%= item.id %>')" title="Kelola Foto"><i data-lucide="image-plus"></i></button>
                                    <button type="button" class="action-btn edit" onclick="openEditBeritaModal('<%= item.id %>', '<%= item.title.replace(/'/g, "\\'") %>', '<%= item.category %>', '<%= item.date %>')" title="Edit Berita"><i data-lucide="edit"></i></button>
                                    <form action="/admin/hapus-berita/<%= item.id %>" method="POST" class="form-inline"><button type="submit" class="action-btn delete" onclick="return confirm('Hapus berita?')"><i data-lucide="trash-2"></i></button></form>
                                </td>
                            </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- PENGURUS & BIDANG UMUM -->
            <div class="glass admin-panel" style="margin-bottom:0;">
                <div class="panel-header">
                    <h3 class="panel-title"><i data-lucide="users"></i> Pengurus Harian (Umum)</h3>
                    <div class="panel-actions">
                        <button class="btn btn-primary" onclick="openModal('modalPengurus')" style="padding:8px 15px; font-size:0.85rem;">+ Pengurus</button>
                        <button class="btn btn-secondary" onclick="openModal('modalBidang')" style="padding:8px 15px; font-size:0.85rem;">+ Buat Bidang</button>
                    </div>
                </div>
                <div class="table-wrapper">
                    <table class="admin-table">
                        <thead><tr><th>Foto</th><th>Nama Pengurus</th><th>Jabatan</th><th style="text-align:right;">Aksi</th></tr></thead>
                        <tbody>
                            <% pengurus.forEach(person => { %>
                            <tr>
                                <td><img src="<%= person.image %>" style="width:40px; height:40px; border-radius:50%; object-fit:cover;"></td>
                                <td class="fw-600"><%= person.name %></td>
                                <td style="color:#4ade80; font-size:0.85rem;"><%= person.role %></td>
                                <td class="td-actions">
                                    <button type="button" class="action-btn edit" onclick="openEditDynamic('<%= person.id %>', '<%= person.name.replace(/'/g, "\\'") %>', '<%= person.role.replace(/'/g, "\\'") %>', '/admin/edit-pengurus/')"><i data-lucide="edit"></i></button>
                                    <form action="/admin/hapus-pengurus/<%= person.id %>" method="POST" class="form-inline"><button type="submit" class="action-btn delete" onclick="return confirm('Yakin?')"><i data-lucide="trash-2"></i></button></form>
                                </td>
                            </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
                <div class="bidang-container">
                    <h4 class="bidang-container-title">Daftar Bidang & Anggota</h4>
                    <div class="bidang-list">
                        <% bidang.forEach(b => { %>
                            <div class="bidang-card">
                                <div class="bidang-header">
                                    <div style="display:flex; align-items:center; gap:10px;">
                                        <h5 class="bidang-title"><%= b.name %></h5>
                                        <button class="action-btn edit" style="padding:4px; border:none; background:none;" onclick="openEditBidangModal('<%= b.id %>', '<%= b.name.replace(/'/g, "\\'") %>', '/admin/edit-bidang/')"><i data-lucide="edit"></i></button>
                                    </div>
                                    <div>
                                        <button type="button" class="btn btn-primary" style="padding:4px 10px; font-size:0.75rem;" onclick="openModalAnggotaBidang('<%= b.id %>', '<%= b.name.replace(/'/g, "\\'") %>', '/admin/tambah-anggota-bidang/')">+ Anggota</button>
                                        <form action="/admin/hapus-bidang/<%= b.id %>" method="POST" class="form-inline" style="margin-left:5px;"><button type="submit" class="action-btn delete" onclick="return confirm('Hapus seluruh bidang?')"><i data-lucide="trash-2" style="width:14px; height:14px;"></i></button></form>
                                    </div>
                                </div>
                                <div class="bidang-members-grid">
                                    <% if(b.members && b.members.length > 0) { b.members.forEach(m => { %>
                                        <div class="member-card">
                                            <img src="<%= m.image %>" class="member-avatar">
                                            <p class="member-name"><%= m.name %></p>
                                            <button type="button" class="action-btn edit" style="position:absolute; top:5px; left:5px; padding:2px; background:rgba(96,165,250,0.2); border:none;" onclick="openEditAnggotaBidangModal('<%= b.id %>', '<%= m.id %>', '<%= m.name.replace(/'/g, "\\'") %>', '/admin/edit-anggota-bidang/')"><i data-lucide="edit" style="width:12px;"></i></button>
                                            <form action="/admin/hapus-anggota-bidang/<%= b.id %>/<%= m.id %>" method="POST" class="member-delete-btn"><button type="submit" style="background:transparent; border:none; color:inherit; cursor:pointer;" onclick="return confirm('Hapus anggota?')"><i data-lucide="x"></i></button></form>
                                        </div>
                                    <% }) } else { %><p class="empty-member">Belum ada anggota.</p><% } %>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                </div>
            </div>

            <!-- PENGURUS & BIDANG KOHATI -->
            <div class="glass admin-panel" style="margin-bottom:0; border: 1px solid rgba(244,114,182,0.3);">
                <div class="panel-header">
                    <h3 class="panel-title" style="color:#f472b6;"><i data-lucide="heart" style="color:#f472b6;"></i> Pengurus Harian (KOHATI)</h3>
                    <div class="panel-actions">
                        <button class="btn btn-primary" style="background:#f472b6; box-shadow:0 4px 15px rgba(244,114,182,0.3); color:#fff;" onclick="openModal('modalKohatiPengurus')">+ Pengurus</button>
                        <button class="btn btn-secondary" onclick="openModal('modalKohatiBidang')">+ Bidang Kohati</button>
                    </div>
                </div>
                <div class="table-wrapper">
                    <table class="admin-table">
                        <thead><tr><th>Foto</th><th>Nama Pengurus</th><th>Jabatan</th><th style="text-align:right;">Aksi</th></tr></thead>
                        <tbody>
                            <% kohatiPengurus.forEach(person => { %>
                            <tr>
                                <td><img src="<%= person.image %>" style="width:40px; height:40px; border-radius:50%; object-fit:cover;"></td>
                                <td class="fw-600"><%= person.name %></td>
                                <td style="color:#f472b6; font-size:0.85rem;"><%= person.role %></td>
                                <td class="td-actions">
                                    <button type="button" class="action-btn edit" onclick="openEditDynamic('<%= person.id %>', '<%= person.name.replace(/'/g, "\\'") %>', '<%= person.role.replace(/'/g, "\\'") %>', '/admin/edit-kohati-pengurus/')"><i data-lucide="edit"></i></button>
                                    <form action="/admin/hapus-kohati-pengurus/<%= person.id %>" method="POST" class="form-inline"><button type="submit" class="action-btn delete" onclick="return confirm('Hapus pengurus kohati?')"><i data-lucide="trash-2"></i></button></form>
                                </td>
                            </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
                <div class="bidang-container">
                    <h4 class="bidang-container-title" style="color:#f472b6;">Bidang & Anggota (KOHATI)</h4>
                    <div class="bidang-list">
                        <% kohatiBidang.forEach(b => { %>
                            <div class="bidang-card">
                                <div class="bidang-header">
                                    <div style="display:flex; align-items:center; gap:10px;">
                                        <h5 class="bidang-title" style="color:#f472b6;"><%= b.name %></h5>
                                        <button class="action-btn edit" style="padding:4px; border:none; background:none;" onclick="openEditBidangModal('<%= b.id %>', '<%= b.name.replace(/'/g, "\\'") %>', '/admin/edit-kohati-bidang/')"><i data-lucide="edit"></i></button>
                                    </div>
                                    <div>
                                        <button type="button" class="btn" style="background:#f472b6; color:#fff; padding:4px 10px; font-size:0.75rem;" onclick="openModalAnggotaBidang('<%= b.id %>', '<%= b.name.replace(/'/g, "\\'") %>', '/admin/tambah-anggota-kohati-bidang/')">+ Anggota</button>
                                        <form action="/admin/hapus-kohati-bidang/<%= b.id %>" method="POST" class="form-inline" style="margin-left:5px;"><button type="submit" class="action-btn delete" onclick="return confirm('Hapus seluruh bidang?')"><i data-lucide="trash-2" style="width:14px; height:14px;"></i></button></form>
                                    </div>
                                </div>
                                <div class="bidang-members-grid">
                                    <% if(b.members && b.members.length > 0) { b.members.forEach(m => { %>
                                        <div class="member-card">
                                            <img src="<%= m.image %>" class="member-avatar" style="border-color:rgba(244,114,182,0.5);">
                                            <p class="member-name"><%= m.name %></p>
                                            <button type="button" class="member-edit-btn" onclick="openEditAnggotaBidangModal('<%= b.id %>', '<%= m.id %>', '<%= m.name.replace(/'/g, "\\'") %>', '/admin/edit-anggota-kohati-bidang/')"><i data-lucide="edit"></i></button>
                                            <form action="/admin/hapus-anggota-kohati-bidang/<%= b.id %>/<%= m.id %>" method="POST" class="member-delete-btn"><button type="submit" style="background:transparent; border:none; color:inherit; cursor:pointer;" onclick="return confirm('Hapus anggota kohati?')"><i data-lucide="x"></i></button></form>
                                        </div>
                                    <% }) } else { %><p class="empty-member">Belum ada anggota.</p><% } %>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                </div>
            </div>
        </div>

        <div class="admin-sidebar">
            <div class="glass admin-panel" style="margin-bottom:0;">
                <h3 class="panel-title" style="margin-bottom:20px; border-bottom:1px solid rgba(255,255,255,0.1); padding-bottom:15px;"><i data-lucide="image"></i> Kelola Galeri</h3>
                <button class="btn btn-add-album" onclick="openModal('modalAlbum')">+ Tambah Galeri Baru</button>
                <div class="album-list">
                    <% albums.forEach(album => { %>
                    <div class="list-item-album">
                        <span class="list-item-title"><strong><%= album.title %></strong><br><small style="color:#4ade80;"><%= album.date %></small></span>
                        <div style="display:flex; gap:5px;">
                            <button type="button" class="action-btn" style="color:#fff;" onclick="openKelolaFotoAlbum('<%= album.id %>')"><i data-lucide="image-plus"></i></button>
                            <button type="button" class="action-btn edit" onclick="openEditAlbumModal('<%= album.id %>', '<%= album.title.replace(/'/g, "\\'") %>', '<%= album.date %>')"><i data-lucide="edit"></i></button>
                            <form action="/admin/hapus-album/<%= album.id %>" method="POST" class="form-inline"><button type="submit" class="action-btn delete" onclick="return confirm('Hapus album?')"><i data-lucide="trash-2"></i></button></form>
                        </div>
                    </div>
                    <% }) %>
                </div>
            </div>

            <div class="glass admin-panel" style="margin-bottom:0;">
                <h3 class="panel-title" style="margin-bottom:20px; border-bottom:1px solid rgba(255,255,255,0.1); padding-bottom:15px;"><i data-lucide="folder-open"></i> Data Anggota (PDF)</h3>
                <button class="btn btn-add-album" onclick="openModal('modalDataAnggota')">+ Data Anggota Baru</button>
                <div class="album-list">
                    <% dataAnggota.forEach(item => { %>
                    <div class="list-item-album">
                        <span class="list-item-title"><strong><%= item.title %></strong><br><small style="color:#4ade80;"><%= item.date %></small></span>
                        <div style="display:flex; gap:5px;">
                            <button type="button" class="action-btn" style="color:#fff;" onclick="window.open('<%= item.file %>', '_blank')"><i data-lucide="eye"></i></button>
                            <button type="button" class="action-btn edit" onclick="openEditDataAnggotaModal('<%= item.id %>', '<%= item.title.replace(/'/g, "\\'") %>', '<%= item.date %>')"><i data-lucide="edit"></i></button>
                            <form action="/admin/hapus-data-anggota/<%= item.id %>" method="POST" class="form-inline"><button type="submit" class="action-btn delete" onclick="return confirm('Hapus PDF?')"><i data-lucide="trash-2"></i></button></form>
                        </div>
                    </div>
                    <% }) %>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ==============================================================
     TAB 2: HEADER, FOOTER, & TENTANG (SETELAN WEB)
============================================================== -->
<div id="adm-setelan" class="admin-tab-pane">
    <div class="grid-2">
        <div class="glass admin-panel">
            <h3 class="panel-title" style="margin-bottom:20px;"><i data-lucide="layout"></i> Header & Footer</h3>
            <form action="/admin/setelan-web" method="POST" enctype="multipart/form-data">
                <div class="form-group">
                    <label>Judul Web (Title Tab/Browser)</label>
                    <input type="text" name="webTitle" class="input-control" value="<%= siteSettings.webTitle %>">
                </div>
                <div class="form-group">
                    <label>Judul Hero (Welcome Halaman Beranda)</label>
                    <input type="text" name="heroTitle" class="input-control" value="<%= siteSettings.heroTitle %>">
                </div>
                <div class="form-group">
                    <label>Teks Logo Kiri (Awal)</label>
                    <input type="text" name="headerTitle" class="input-control" value="<%= siteSettings.headerTitle %>">
                </div>
                <div class="form-group">
                    <label>Teks Logo Kanan (Warna Hijau)</label>
                    <input type="text" name="headerHighlight" class="input-control" value="<%= siteSettings.headerHighlight %>">
                </div>
                <div class="form-group">
                    <label>Teks Bawah Logo</label>
                    <input type="text" name="headerSubtitle" class="input-control" value="<%= siteSettings.headerSubtitle %>">
                </div>
                <div class="form-group">
                    <label>Logo Header & Favicon (Biarkan kosong jika tetap)</label>
                    <input type="file" name="headerLogo" class="input-control file-compress" accept="image/*">
                </div>
                <div class="form-group">
                    <label>Logo Footer (Biarkan kosong jika tetap)</label>
                    <input type="file" name="footerLogo" class="input-control file-compress" accept="image/*">
                </div>
                <div class="form-group" style="margin-top:30px; border-top:1px dashed rgba(255,255,255,0.2); padding-top:20px;">
                    <label>Teks Judul Footer</label>
                    <input type="text" name="footerTitle" class="input-control" value="<%= siteSettings.footerTitle %>">
                </div>
                <div class="form-group">
                    <label>Deskripsi Footer</label>
                    <textarea name="footerDesc" class="input-control" rows="3"><%= siteSettings.footerDesc %></textarea>
                </div>
                <div class="form-group">
                    <label>Teks Hak Cipta (Copyright)</label>
                    <input type="text" name="footerCopyright" class="input-control" value="<%= siteSettings.footerCopyright %>">
                </div>
                <div class="form-group">
                    <label>Teks Programmer / Watermark</label>
                    <input type="text" name="footerProgrammer" class="input-control" value="<%= siteSettings.footerProgrammer %>">
                </div>
                
                <h4 style="margin:20px 0 10px; border-top:1px solid rgba(255,255,255,0.1); padding-top:20px;">Sosial Media Footer</h4>
                <div style="display:flex; flex-direction:column; gap:10px; margin-bottom:20px;">
                    <% socialMediaList.forEach(soc => { %>
                        <div style="background:rgba(0,0,0,0.3); padding:10px; border-radius:8px; display:flex; justify-content:space-between; align-items:center;">
                            <span style="font-size:0.85rem;"><%= soc.name %>: <a href="<%= soc.url %>" target="_blank" style="color:#4ade80;">Link</a></span>
                            <!-- Form Delete Sosmed remains same -->
                        </div>
                    <% }) %>
                    <button type="button" class="btn btn-secondary" onclick="openModal('modalSosmed')" style="font-size:0.8rem; padding:8px;">+ Tambah Sosial Media (Icon Upload)</button>
                </div>
                
                <button type="submit" class="btn btn-primary submit-btn" style="width:100%; margin-top:15px;">Simpan Header & Footer</button>
            </form>
        </div>

        <div>
            <!-- PANEL KHUSUS TOGGLE KOHATI AGAR TIDAK SALING TIMPA (FIXED) -->
            <div class="glass admin-panel" style="border-top: 4px solid #f472b6;">
                <h3 class="panel-title" style="margin-bottom:20px; color:#f472b6;"><i data-lucide="heart"></i> Status Fitur KOHATI</h3>
                <form action="/admin/setelan-kohati-toggle" method="POST" enctype="multipart/form-data">
                    <p class="text-muted" style="font-size:0.85rem; margin-bottom:15px;">Aktifkan atau Nonaktifkan seluruh tab dan fitur KOHATI di halaman publik.</p>
                    <div class="form-group" style="display:flex; align-items:center; gap:10px; background:rgba(255,255,255,0.05); padding:15px; border-radius:10px;">
                        <input type="checkbox" name="kohatiActive" id="kohatiActiveCheck" value="true" <%= siteSettings.kohatiActive === 'true' || siteSettings.kohatiActive === true ? 'checked' : '' %> style="width:20px; height:20px;">
                        <label for="kohatiActiveCheck" style="margin:0; cursor:pointer;">Tampilkan Fitur KOHATI</label>
                    </div>
                    <button type="submit" class="btn btn-primary submit-btn" style="width:100%; background:#f472b6; border-color:#f472b6; color:#fff;">Simpan Status KOHATI</button>
                </form>
            </div>

            <!-- PANEL TENTANG KAMI -->
            <div class="glass admin-panel">
                <h3 class="panel-title" style="margin-bottom:20px;"><i data-lucide="file-text"></i> Halaman Tentang Kami</h3>
                <form action="/admin/setelan-tentang" method="POST" enctype="multipart/form-data" id="formSetelanTentang">
                    <div class="form-group">
                        <label>Teks Profil</label>
                        <div id="quill-profil" style="height:200px; color:white;"></div>
                        <input type="hidden" name="profilText" id="hidden-profil">
                    </div>
                    <div class="form-group">
                        <label>Teks Visi & Misi</label>
                        <div id="quill-visimisi" style="height:200px; color:white;"></div>
                        <input type="hidden" name="visiMisiText" id="hidden-visimisi">
                    </div>
                    <div class="form-group">
                        <label>Embed Code Google Maps (Iframe)</label>
                        <textarea name="mapsEmbed" class="input-control" rows="3" placeholder='<iframe src="..."></iframe>'><%= siteSettings.mapsEmbed %></textarea>
                    </div>
                    <div class="form-group">
                        <label>Upload Booklet / Pedoman PDF</label>
                        <input type="file" name="bookletPdf" class="input-control file-to-b64" accept="application/pdf">
                        <% if(siteSettings.bookletPdf) { %><p class="form-hint" style="color:#4ade80;">File booklet saat ini sudah terpasang.</p><% } %>
                    </div>

                    <!-- SEGMEN TENTANG KOHATI -->
                    <div class="form-group" style="margin-top:40px; border-top:1px solid rgba(244,114,182,0.3); padding-top:20px;">
                        <h4 style="color:#f472b6; margin-bottom:15px;"><i data-lucide="heart" style="width:16px;"></i> Konten Halaman Kohati</h4>
                        <label>Teks Profil KOHATI</label>
                        <div id="quill-kohati-profil" style="height:150px; color:white;"></div>
                        <input type="hidden" name="kohatiProfilText" id="hidden-kohati-profil">
                    </div>
                    <div class="form-group">
                        <label>Teks Visi & Misi KOHATI</label>
                        <div id="quill-kohati-visimisi" style="height:150px; color:white;"></div>
                        <input type="hidden" name="kohatiVisiMisiText" id="hidden-kohati-visimisi">
                    </div>

                    <button type="submit" class="btn btn-primary submit-btn" style="width:100%;">Simpan Halaman Tentang</button>
                </form>
                
                <div id="raw-profil" style="display:none;"><%- siteSettings.profilText %></div>
                <div id="raw-visimisi" style="display:none;"><%- siteSettings.visiMisiText %></div>
                <div id="raw-kohati-profil" style="display:none;"><%- siteSettings.kohatiProfilText %></div>
                <div id="raw-kohati-visimisi" style="display:none;"><%- siteSettings.kohatiVisiMisiText %></div>
            </div>
        </div>
    </div>
</div>

<!-- ==============================================================
     TAB 3: SHORTLINK CUSTOM
============================================================== -->
<div id="adm-shortlink" class="admin-tab-pane">
    <div class="glass admin-panel" style="max-width:800px; margin:0 auto;">
        <div class="panel-header">
            <h3 class="panel-title"><i data-lucide="link"></i> Shortlink Custom</h3>
            <button class="btn btn-primary" onclick="openModal('modalShortlink')" style="padding:8px 15px; font-size:0.85rem;">+ Buat Link</button>
        </div>
        <p class="text-muted" style="margin-bottom:20px; font-size:0.9rem;">Buat URL kustom untuk website Anda, contoh: <code>domain.com/daftar</code> -> mengarah ke Google Form.</p>
        <div class="table-wrapper">
            <table class="admin-table">
                <thead><tr><th>Judul / Keterangan</th><th>Short Path</th><th>Tujuan Asli (Original URL)</th><th style="text-align:right;">Aksi</th></tr></thead>
                <tbody>
                    <% shortlinks.forEach(l => { %>
                    <tr>
                        <td class="fw-600"><%= l.title %></td>
                        <td style="color:#4ade80;">/<%= l.path %></td>
                        <td style="font-size:0.8rem; max-width:200px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;"><a href="<%= l.originalUrl %>" target="_blank"><%= l.originalUrl %></a></td>
                        <td class="td-actions">
                            <button type="button" class="action-btn" style="color:#fff;" onclick="window.open('/<%= l.path %>', '_blank')" title="Test Link"><i data-lucide="external-link"></i></button>
