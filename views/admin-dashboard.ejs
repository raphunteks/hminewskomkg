                                %>
                                <tr>
                                    <td>
                                        <% if(l.icon) { %> <img src="<%= l.icon %>" style="width:30px; height:30px; border-radius:6px; object-fit:cover;"> <% } else { %> <div style="width:30px; height:30px; background:rgba(255,255,255,0.1); border-radius:6px; display:flex; align-items:center; justify-content:center;"><i data-lucide="link" style="width:16px;"></i></div> <% } %>
