<div id="adm-announce" class="admin-tab-pane">
    <div class="glass admin-panel" style="max-width:800px; margin:0 auto;">
        <h3 class="panel-title" style="margin-bottom:20px;"><i data-lucide="bell"></i> Setelan Announcement Pop-up</h3>
        <p class="text-muted" style="margin-bottom:30px; font-size:0.9rem;">Pengumuman akan muncul di beranda sebagai popup saat pengunjung membuka web.</p>
        
        <form action="/admin/setelan-announcement" method="POST" enctype="multipart/form-data" id="formAnnounce">
            <div class="form-group" style="display:flex; align-items:center; gap:10px; background:rgba(34,197,94,0.1); border:1px solid rgba(34,197,94,0.3); padding:15px; border-radius:10px;">
                <input type="checkbox" name="announceActive" id="announceActive" value="true" <%= String(siteSettings.announceActive) === 'true' ? 'checked' : '' %> style="width:20px; height:20px;">
                <label for="announceActive" style="margin:0; color:#4ade80; cursor:pointer;">Aktifkan Pop-up Pengumuman di Beranda</label>
            </div>
            <div class="form-group">
                <label>Judul Pengumuman</label>
                <input type="text" name="announceTitle" class="input-control" value="<%= siteSettings.announceTitle %>">
            </div>
            <div class="form-group">
                <label>Upload Poster/Foto Pengumuman (Opsional)</label>
                <input type="file" name="announceImage" class="input-control file-compress" accept="image/*">
                <% if(siteSettings.announceImage) { %><img src="<%= siteSettings.announceImage %>" style="height:100px; border-radius:8px; margin-top:10px; border:1px solid rgba(255,255,255,0.2);"><% } %>
            </div>
            <div class="form-group">
                <label>Isi Teks Pengumuman</label>
                <div id="quill-announce" style="height:200px; color:white;"></div>
                <input type="hidden" name="announceContent" id="hidden-announce">
            </div>
            <div id="raw-announce" style="display:none;"><%- siteSettings.announceContent %></div>
            <button type="submit" class="btn btn-primary submit-btn" style="width:100%;">Simpan Setelan Pengumuman</button>
        </form>
    </div>
</div>

