<script>
    function openAdmTab(tabId, btn) {
        document.querySelectorAll('.admin-tab-pane').forEach(tab => tab.classList.remove('active'));
        document.querySelectorAll('.admin-tab-btn').forEach(b => b.classList.remove('active'));
        document.getElementById(tabId).classList.add('active');
        btn.classList.add('active');
        window.dispatchEvent(new Event('resize'));
    }

    document.addEventListener('DOMContentLoaded', function() {
        var toolbarOptions = [['bold', 'italic', 'underline', 'strike'], ['blockquote'], [{ 'header': 1 }, { 'header': 2 }], [{ 'list': 'ordered'}, { 'list': 'bullet' }], [{ 'color': [] }, { 'background': [] }], [{ 'align': [] }], ['clean']];
        var qConfig = { theme: 'snow', modules: { toolbar: toolbarOptions } };
        
        var quillTambah = new Quill('#quill-tambah', qConfig);
        var quillEdit = new Quill('#quill-edit', qConfig);
        var quillProfil = new Quill('#quill-profil', qConfig);
        var quillVisi = new Quill('#quill-visimisi', qConfig);
        var quillAnnounce = new Quill('#quill-announce', qConfig);
        var quillKohatiProfil = new Quill('#quill-kohati-profil', qConfig);
        var quillKohatiVisi = new Quill('#quill-kohati-visimisi', qConfig);

        quillProfil.root.innerHTML = document.getElementById('raw-profil').innerHTML;
        quillVisi.root.innerHTML = document.getElementById('raw-visimisi').innerHTML;
        quillAnnounce.root.innerHTML = document.getElementById('raw-announce').innerHTML;
        quillKohatiProfil.root.innerHTML = document.getElementById('raw-kohati-profil').innerHTML;
        quillKohatiVisi.root.innerHTML = document.getElementById('raw-kohati-visimisi').innerHTML;

        document.getElementById('formSetelanTentang').onsubmit = function() {
            document.getElementById('hidden-profil').value = quillProfil.root.innerHTML;
            document.getElementById('hidden-visimisi').value = quillVisi.root.innerHTML;
            document.getElementById('hidden-kohati-profil').value = quillKohatiProfil.root.innerHTML;
            document.getElementById('hidden-kohati-visimisi').value = quillKohatiVisi.root.innerHTML;
        };
        document.getElementById('formAnnounce').onsubmit = function() {
            document.getElementById('hidden-announce').value = quillAnnounce.root.innerHTML;
        };
        document.getElementById('formTambahBerita').onsubmit = function() { 
            document.getElementById('content-tambah').value = quillTambah.root.innerHTML; 
        };
        document.getElementById('formEditBerita').onsubmit = function() { 
            document.getElementById('content-edit').value = quillEdit.root.innerHTML; 
        };
    });

    function openModal(modalId) { document.getElementById(modalId).classList.add('active'); }
    function closeModal(modalId) { document.getElementById(modalId).classList.remove('active'); }

    function openEditDataAnggotaModal(id, title, date) { document.getElementById('editDataAnggotaTitle').value = title; document.getElementById('editDataAnggotaDate').value = date; document.getElementById('formEditDataAnggota').action = '/admin/edit-data-anggota/' + id; openModal('modalEditDataAnggota'); }

    function openEditBeritaModal(id, title, category, date) {
        document.getElementById('editBeritaTitle').value = title; document.getElementById('editBeritaCategory').value = category; document.getElementById('editBeritaDate').value = date;
        var editEditor = Quill.find(document.getElementById('quill-edit'));
        editEditor.root.innerHTML = document.getElementById('raw-content-' + id).innerHTML;
        document.getElementById('formEditBerita').action = '/admin/edit-berita/' + id; openModal('modalEditBerita');
    }

    function openKelolaFotoBerita(id) {
        const berita = newsData.find(n => n.id == id); if(!berita) return;
        document.getElementById('kelolaFotoBeritaTitle').innerText = 'Kelola Foto: ' + berita.title;
        document.getElementById('formTambahFotoBerita').action = '/admin/tambah-foto-berita/' + id;
        const grid = document.getElementById('existingPhotosBeritaGrid'); grid.innerHTML = '';
        if (berita.photos && berita.photos.length > 0) {
            berita.photos.forEach(p => {
                grid.innerHTML += `<div style="position:relative; background:rgba(255,255,255,0.05); padding:5px; border-radius:8px;"><img src="${p.url}" style="width:100%; height:80px; object-fit:cover; border-radius:4px;"><form action="/admin/hapus-foto-berita/${berita.id}/${p.id}" method="POST" style="position:absolute; top:8px; right:8px;"><button type="submit" style="background:rgba(239,68,68,0.8); color:#fff; border:none; border-radius:4px; padding:4px; cursor:pointer;" onclick="return confirm('Hapus foto ini?')"><i data-lucide="trash-2" style="width:14px; height:14px;"></i></button></form></div>`;
            });
            lucide.createIcons();
        } else { grid.innerHTML = '<p class="text-muted" style="grid-column: 1 / -1;">Belum ada foto.</p>'; }
        openModal('modalKelolaFotoBerita');
    }

    function openEditDynamic(id, name, role, actionPath) {
        document.getElementById('editDynamicName').value = name;
        document.getElementById('editDynamicRole').value = role;
        document.getElementById('formEditDynamic').action = actionPath + id;
        openModal('modalEditDynamic');
