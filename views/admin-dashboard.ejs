<div class="modal-overlay" id="modalSosmed"><div class="modal-content"><div class="modal-header"><h3>Tambah Sosial Media</h3><button type="button" class="close-modal" onclick="closeModal('modalSosmed')"><i data-lucide="x"></i></button></div><form action="/admin/tambah-sosmed" method="POST" enctype="multipart/form-data"><div class="form-group"><label>Nama Sosmed</label><input type="text" name="name" class="input-control" required></div><div class="form-group"><label>URL Profile</label><input type="url" name="url" class="input-control" required></div><div class="form-group"><label>Upload Icon/Logo</label><input type="file" name="icon" class="input-control file-compress" accept="image/*"></div><div class="modal-actions"><button type="button" class="btn btn-secondary" onclick="closeModal('modalSosmed')">Batal</button><button type="submit" class="btn btn-primary submit-btn">Simpan</button></div></form></div></div>
