<%- include('partials/header') %>

<div class="flex flex-col md:flex-row justify-between items-center bg-black/40 border border-white/10 p-6 rounded-2xl backdrop-blur-md mb-8 glass-panel">
    <div class="flex items-center mb-4 md:mb-0">
        <div class="w-12 h-12 rounded-full bg-green-500/20 flex items-center justify-center mr-4">
            <i data-lucide="shield-check" class="text-green-400 w-6 h-6"></i>
        </div>
        <div>
            <h2 class="text-2xl font-bold">Dashboard Admin</h2>
            <p class="text-sm text-gray-400">Selamat datang, Anda login sebagai Admin.</p>
        </div>
    </div>
    <a href="/admin/logout" class="flex items-center px-4 py-2 bg-red-500/20 text-red-400 hover:bg-red-500/30 border border-red-500/50 rounded-lg transition-all font-semibold">
        <i data-lucide="log-out" class="w-4 h-4 mr-2"></i> Logout
    </a>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <!-- Panel Berita -->
    <div class="glass-panel p-6 rounded-2xl lg:col-span-2">
        <div class="flex justify-between items-center mb-6 border-b border-white/10 pb-4">
            <h3 class="text-xl font-bold flex items-center"><i data-lucide="file-text" class="mr-2 text-green-400"></i> Kelola Berita</h3>
            <button class="bg-green-500 text-black px-3 py-1.5 rounded-lg text-sm font-bold hover:bg-green-400">+ Tambah</button>
        </div>
        
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="text-sm text-gray-400 border-b border-white/10">
                        <th class="pb-3 px-2">Judul</th>
                        <th class="pb-3 px-2">Kategori</th>
                        <th class="pb-3 px-2 text-right">Aksi</th>
                    </tr>
                </thead>
                <tbody>
                    <% news.forEach(item => { %>
                    <tr class="border-b border-white/5 hover:bg-white/5">
                        <td class="py-3 px-2 font-medium text-sm"><%= item.title %></td>
                        <td class="py-3 px-2 text-sm"><span class="bg-white/10 px-2 py-1 rounded text-xs"><%= item.category %></span></td>
                        <td class="py-3 px-2 text-right">
                            <button class="text-blue-400 hover:bg-blue-400/20 p-1.5 rounded"><i data-lucide="edit" class="w-4 h-4"></i></button>
                            <button class="text-red-400 hover:bg-red-400/20 p-1.5 rounded"><i data-lucide="trash-2" class="w-4 h-4"></i></button>
                        </td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>

    <!-- Sidebar Tools -->
    <div class="space-y-8">
        <!-- Panel Galeri -->
        <div class="glass-panel p-6 rounded-2xl">
            <h3 class="text-lg font-bold mb-4 border-b border-white/10 pb-2 flex items-center"><i data-lucide="image" class="mr-2 text-green-400"></i> Kelola Galeri</h3>
            <button class="w-full bg-white/10 text-white py-2.5 rounded-xl font-semibold hover:bg-white/20 transition-colors mb-4 border border-white/10 text-sm">Buat Album Baru</button>
            <ul class="space-y-3">
                <% albums.forEach(album => { %>
                <li class="bg-black/30 p-3 rounded-xl flex items-center justify-between">
                    <span class="text-sm truncate pr-2"><%= album.title %></span>
                    <button class="text-red-400 hover:text-red-300"><i data-lucide="trash-2" class="w-4 h-4"></i></button>
                </li>
                <% }) %>
            </ul>
        </div>

        <!-- Panel Data Anggota -->
        <div class="glass-panel p-6 rounded-2xl text-center">
            <div class="w-16 h-16 mx-auto bg-green-500/20 rounded-full flex items-center justify-center mb-3">
                <i data-lucide="upload-cloud" class="w-8 h-8 text-green-400"></i>
            </div>
            <h3 class="text-lg font-bold mb-1">Upload PDF Anggota</h3>
            <p class="text-xs text-gray-400 mb-4">Gantikan file PDF lama di halaman publik.</p>
            <form>
                <input type="file" class="hidden" id="pdf-upload" accept=".pdf">
                <label for="pdf-upload" class="cursor-pointer block w-full bg-green-500 text-black py-2.5 rounded-xl text-sm font-bold hover:bg-green-400 transition-colors">
                    Pilih File PDF
                </label>
            </form>
        </div>
    </div>
</div>

<%- include('partials/footer') %>