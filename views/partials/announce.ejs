<% if (typeof siteSettings !== 'undefined' && (siteSettings.announceActive === 'true' || siteSettings.announceActive === true)) { %>
<div class="modal-overlay announce-overlay" id="announceModal" style="z-index: 10000; padding: 20px;">
    <!-- Desain Horizontal Pop-up -->
    <div class="announce-horizontal" style="display: flex; max-width: 850px; width: 100%; background: #1b4332; border-radius: 16px; overflow: hidden; position: relative; box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.6); border: 1px solid rgba(74,222,128,0.2);">
        
        <button class="close-modal" style="position:absolute; top: 15px; right: 15px; z-index: 10; background:rgba(0,0,0,0.3); border-radius:50%; padding:8px; color:#fff; border: 1px solid rgba(255,255,255,0.1); cursor:pointer; transition:0.3s;" onmouseover="this.style.background='rgba(239,68,68,0.8)'" onmouseout="this.style.background='rgba(0,0,0,0.3)'" onclick="closeAnnounce()">
            <i data-lucide="x" style="width: 18px; height: 18px;"></i>
        </button>

        <% if (siteSettings.announceImage) { %>
        <div class="announce-left" style="flex: 1; max-width: 45%; background: #000;">
            <img src="<%= siteSettings.announceImage %>" alt="Announcement" style="width: 100%; height: 100%; object-fit: cover;">
        </div>
        <% } %>

        <div class="announce-right" style="flex: 1; padding: 40px 30px; display: flex; flex-direction: column; justify-content: center;">
            <h2 style="color: #fff; margin-bottom: 10px; font-size: 2rem; font-weight: 800; line-height: 1.2;"><%= siteSettings.announceTitle %></h2>
            <div style="width: 40px; height: 4px; background: #4ade80; margin-bottom: 20px; border-radius: 2px;"></div>

            <!-- DITAMBAHKAN WHITE-SPACE: PRE-LINE AGAR FORMAT ENTER DARI ADMIN TERBACA OTOMATIS -->
            <div class="rich-text-content announce-text" style="color: #d1d5db; margin-bottom: 30px; line-height: 1.6; font-size: 0.95rem; border-left: 3px solid rgba(74, 222, 128, 0.4); padding-left: 15px; white-space: pre-line;">
                <%- siteSettings.announceContent %>
            </div>

            <button class="btn" style="align-self: flex-start; padding: 10px 24px; font-size: 0.95rem; border-radius: 8px; font-weight: bold; background: transparent; border: 1px solid #4ade80; color: #4ade80; cursor:pointer; transition: 0.3s;" onmouseover="this.style.background='#4ade80'; this.style.color='#000';" onmouseout="this.style.background='transparent'; this.style.color='#4ade80';" onclick="readAnnounce()">Tutup Pengumuman</button>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const titleKey = '<%= siteSettings.announceTitle.replace(/[^a-zA-Z0-9]/g, "_") %>';
        const announceKey = 'announce_read_' + titleKey;
        if (!localStorage.getItem(announceKey)) {
            setTimeout(() => { document.getElementById('announceModal').classList.add('active'); }, 600);
        }
    });

    function closeAnnounce() { 
        document.getElementById('announceModal').classList.remove('active'); 
    }

    function readAnnounce() {
        const titleKey = '<%= siteSettings.announceTitle.replace(/[^a-zA-Z0-9]/g, "_") %>';
        const announceKey = 'announce_read_' + titleKey;
        localStorage.setItem(announceKey, 'true');
        closeAnnounce();
    }
</script>
<% } %>
