</div> <!-- Menutup div.container dari header -->
    </main> <!-- Menutup tag main dari header -->
    
    <!-- Footer Utama -->
    <footer class="site-footer" style="z-index: 10; position: relative;">
        <div class="container">
            <div class="grid-3 footer-top">
                <div style="grid-column: span 1;">
                    <div class="footer-logo-area">
                        <div class="logo-box" style="width:40px; height:40px;">
                            <img src="<%= siteSettings.footerLogo %>" alt="Logo" class="logo-img" style="width:100%; max-width:40px; object-fit:contain;">
                        </div>
                        <div class="logo-text">
                            <h2 style="font-size:1.1rem; margin:0;"><%= siteSettings.footerTitle %></h2>
                        </div>
                    </div>
                    <p class="footer-desc"><%= siteSettings.footerDesc %></p>
                </div>
                
                <div class="footer-links">
                    <h3>Menu</h3>
                    <ul>
                        <li><a href="/">Beranda</a></li>
                        <li><a href="/tentang">Tentang Kami</a></li>
                        <li><a href="/galeri">Galeri Kegiatan</a></li>
                    </ul>
                </div>
                
                <div class="footer-links">
                    <h3>Follow Kita!</h3>
                    <div class="social-links">
                        <% socialMediaList.forEach(soc => { %>
                            <a href="<%= soc.url %>" target="_blank" class="social-btn" title="<%= soc.name %>">
                                <% if(soc.icon) { %>
                                    <img src="<%= soc.icon %>" alt="<%= soc.name %>">
                                <% } else { %>
                                    <i data-lucide="link"></i>
                                <% } %>
                            </a>
                        <% }) %>
                    </div>
                </div>
            </div>
            
            <div class="footer-bottom">
                <span><%= siteSettings.footerCopyright %></span>
                <span><%= siteSettings.footerProgrammer %></span>
            </div>
        </div>
    </footer>

    <!-- POPUP PENGUMUMAN DIMASUKKAN DI SINI AGAR TIDAK TERTIMPA FOOTER -->
    <% if (typeof page !== 'undefined' && page === 'beranda' && typeof siteSettings !== 'undefined' && (siteSettings.announceActive === 'true' || siteSettings.announceActive === true)) { %>
    <div class="modal-overlay announce-overlay" id="announceModal" style="z-index: 9999999; padding: 20px;">
        <div class="announce-horizontal">
            
            <button class="close-modal announce-close-btn" onclick="closeAnnounce()">
                <i data-lucide="x" style="width: 18px; height: 18px;"></i>
            </button>

            <% if (siteSettings.announceImage) { %>
            <div class="announce-left">
                <img src="<%= siteSettings.announceImage %>" alt="Announcement">
            </div>
            <% } %>

            <div class="announce-right">
                <h2 class="announce-title"><%= siteSettings.announceTitle %></h2>
                <div class="announce-divider"></div>

                <div class="rich-text-content announce-text">
                    <%- siteSettings.announceContent %>
                </div>

                <button class="btn announce-btn" onclick="readAnnounce()">Saya Sudah Membaca</button>
            </div>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const titleKey = '<%= siteSettings.announceTitle.replace(/[^a-zA-Z0-9]/g, "_") %>';
            const announceKey = 'announce_read_' + titleKey;
            if (!localStorage.getItem(announceKey)) {
                setTimeout(() => { document.getElementById('announceModal').classList.add('active'); }, 600);
            }
        });

        function closeAnnounce() { 
            document.getElementById('announceModal').classList.remove('active'); 
        }

        function readAnnounce() {
            const titleKey = '<%= siteSettings.announceTitle.replace(/[^a-zA-Z0-9]/g, "_") %>';
            const announceKey = 'announce_read_' + titleKey;
            localStorage.setItem(announceKey, 'true');
            closeAnnounce();
        }
    </script>
    <% } %>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            if (typeof lucide !== 'undefined') { lucide.createIcons(); }
        });
    </script>
</body>
</html>
