</div> <!-- Menutup div.container dari header -->
    </main> <!-- Menutup tag main dari header -->
    
    <!-- Footer Utama -->
    <footer class="site-footer" style="z-index: 10; position: relative;">
        <div class="container">
            <div class="grid-3 footer-top">
                <div style="grid-column: span 1;">
                    <div class="footer-logo-area">
                        <div class="logo-box" style="width:40px; height:40px;">
                            <!-- Penambahan width dan height eksplisit untuk mencegah Layout Shift (CLS) -->
                            <img src="<%= siteSettings.footerLogo %>" alt="Logo" class="logo-img" width="40" height="40" style="width:100%; max-width:40px; object-fit:contain;" loading="lazy">
                        </div>
                        <div class="logo-text">
                            <h2 style="font-size:1.1rem; margin:0;"><%= siteSettings.footerTitle %></h2>
                        </div>
                    </div>
                    <p class="footer-desc"><%= siteSettings.footerDesc %></p>
                </div>
                
                <div class="footer-links">
                    <h3>Menu</h3>
                    <ul>
                        <li><a href="/">Beranda</a></li>
                        <li><a href="/tentang">Tentang Kami</a></li>
                        <li><a href="/galeri">Galeri Kegiatan</a></li>
                    </ul>
                </div>
                
                <div class="footer-links">
                    <h3>Follow Kita!</h3>
                    <div class="social-links">
                        <% socialMediaList.forEach(soc => { %>
                            <a href="<%= soc.url %>" target="_blank" class="social-btn" title="<%= soc.name %>" rel="noopener noreferrer">
                                <% if(soc.icon && soc.icon.length > 0) { %>
                                    <img src="<%= soc.icon %>" alt="<%= soc.name %>" width="22" height="22" loading="lazy">
                                <% } else { %>
                                    <% if (soc.name.toLowerCase().includes('instagram') || soc.name.toLowerCase().includes('ig')) { %>
                                        <i data-lucide="instagram"></i>
                                    <% } else if (soc.name.toLowerCase().includes('facebook') || soc.name.toLowerCase().includes('fb')) { %>
                                        <i data-lucide="facebook"></i>
                                    <% } else if (soc.name.toLowerCase().includes('twitter') || soc.name.toLowerCase().includes('x')) { %>
                                        <i data-lucide="twitter"></i>
                                    <% } else if (soc.name.toLowerCase().includes('youtube') || soc.name.toLowerCase().includes('yt')) { %>
                                        <i data-lucide="youtube"></i>
                                    <% } else if (soc.name.toLowerCase().includes('tiktok')) { %>
                                        <i data-lucide="tv"></i>
                                    <% } else { %>
                                        <i data-lucide="link"></i>
                                    <% } %>
                                <% } %>
                            </a>
                        <% }) %>
                    </div>
                </div>
            </div>
            
            <div class="footer-bottom">
                <span><%= siteSettings.footerCopyright %></span>
                <span><%= siteSettings.footerProgrammer %></span>
            </div>
        </div>
    </footer>

    <!-- OPTIMASI SCRIPT: Logika render Icon Lucide yang disesuaikan dengan atribut 'defer' di header -->
    <script>
        // Gunakan requestAnimationFrame atau setTimeout untuk menjamin 
        // eksekusi pembuatan icon dilakukan SETELAH semua aset utama selesai digambar oleh browser.
        document.addEventListener('DOMContentLoaded', function() {
            const initIcons = () => {
                if (typeof lucide !== 'undefined') { 
                    lucide.createIcons(); 
                } else {
                    // Jika script defer sedikit telat, coba lagi dalam 100ms
                    setTimeout(initIcons, 100);
                }
            };
            initIcons();
        });
    </script>
</body>
</html>
