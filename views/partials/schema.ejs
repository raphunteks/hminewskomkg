<%
    // ==============================================================
    // EXPERT SEO: GOOGLE SITE NAME & KNOWLEDGE PANEL FORCER
    // ==============================================================
    // Wajib menggunakan www jika canonical website Anda menggunakan www (Sesuai Gbr 1)
    const schemaBaseUrl = 'https://www.hmikomkgumi.xyz';
    const schemaSafeSettings = typeof siteSettings !== 'undefined' && siteSettings ? siteSettings : {};
    let schemaLogo = schemaSafeSettings.headerLogo || schemaBaseUrl + '/favicon.ico';
    
    // Pastikan Logo menggunakan Absolute URL
    if (schemaLogo && !schemaLogo.startsWith('http')) {
        if (!schemaLogo.startsWith('/')) schemaLogo = '/' + schemaLogo;
        schemaLogo = schemaBaseUrl + schemaLogo;
    }
%>

<!-- 1. EXPERT SEO: Organization Schema (Untuk Panel Samping Google) -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "HMI KOMKG UMI",
  "alternateName": [
    "Himpunan Mahasiswa Islam Komisariat Kedokteran Gigi UMI",
    "HMI KomKG-UMI"
  ],
  "url": "<%= schemaBaseUrl %>/",
  "logo": "<%= schemaLogo %>",
  "sameAs": [
    "https://www.instagram.com/hmi_komkgumi",
    "https://www.tiktok.com/@hmi_komkgumi"
  ],
  "contactPoint": {
    "@type": "ContactPoint",
    "contactType": "customer service",
    "url": "<%= schemaBaseUrl %>/"
  }
}
</script>

<!-- 2. EXPERT SEO: WebSite Schema (KUNCI UTAMA UNTUK MENGUBAH NAMA SITUS DI GBR 1) -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "HMI KOMKG UMI",
  "alternateName": "HMI KomKG-UMI",
  "url": "<%= schemaBaseUrl %>/",
  "potentialAction": {
    "@type": "SearchAction",
    "target": {
      "@type": "EntryPoint",
      "urlTemplate": "<%= schemaBaseUrl %>/?q={search_term_string}"
    },
    "query-input": "required name=search_term_string"
  }
}
</script>
