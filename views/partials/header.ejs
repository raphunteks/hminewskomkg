<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    
    <!-- ==============================================================
         SUPER BIG UPGRADE: 100% SEO META TAGS (TERINTEGRASI DENGAN ADMIN)
    ============================================================== -->
    <!-- Dinamis Title (Mendukung SEO per-halaman atau default Admin) -->
    <title><%= typeof pageTitle !== 'undefined' ? pageTitle + ' - ' + siteSettings.webTitle : siteSettings.webTitle %></title>
    
    <!-- Terhubung ke Setelan SEO Description di Admin Dashboard dengan Fallback Teks Custom -->
    <meta name="description" content="<%= typeof pageDescription !== 'undefined' ? pageDescription : (siteSettings.seoDescription || 'Website Resmi Himpunan Mahasiswa Islam Komisariat Kedokteran Gigi UMI') %>">
    <link rel="icon" type="image/png" href="<%= siteSettings.headerLogo %>">

    <!-- Meta Dasar & Aturan Crawling Googlebot -->
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1">
    
    <!-- Terhubung ke Setelan SEO Keywords di Admin Dashboard dengan Fallback Teks Custom -->
    <meta name="keywords" content="<%= typeof pageKeywords !== 'undefined' ? pageKeywords : (siteSettings.seoKeywords || 'hmi komkg umi, hmikomkgumi, hmi, hmi kom kg umi, hmicabmakassar, yakusa') %>">
    <meta name="author" content="<%= siteSettings.headerTitle || 'HMI KomKG UMI' %>">
    <link rel="canonical" href="<%= typeof currentUrl !== 'undefined' ? currentUrl : 'https://hmikomkgumi.xyz' %>" />
    <meta name="theme-color" content="#064e3b">

    <!-- Open Graph / Facebook / WhatsApp (SEO Social Media) -->
    <meta property="og:locale" content="id_ID">
    <meta property="og:type" content="<%= typeof pageType !== 'undefined' ? pageType : 'website' %>">
    <meta property="og:title" content="<%= typeof pageTitle !== 'undefined' ? pageTitle : siteSettings.webTitle %>">
    <meta property="og:description" content="<%= typeof pageDescription !== 'undefined' ? pageDescription : (siteSettings.seoDescription || 'Website Resmi Himpunan Mahasiswa Islam Komisariat Kedokteran Gigi UMI') %>">
    <meta property="og:url" content="<%= typeof currentUrl !== 'undefined' ? currentUrl : 'https://hmikomkgumi.xyz' %>">
    <meta property="og:site_name" content="<%= siteSettings.webTitle %>">
    
    <!-- Terhubung ke Setelan Thumbnail (OG Image) di Admin Dashboard -->
    <meta property="og:image" content="<%= typeof pageImage !== 'undefined' ? pageImage : (siteSettings.seoImage || siteSettings.headerLogo) %>">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
    <meta property="og:image:alt" content="Cover <%= siteSettings.webTitle %>">

    <!-- Twitter Cards (SEO Twitter/X) -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="<%= typeof pageTitle !== 'undefined' ? pageTitle : siteSettings.webTitle %>">
    <meta name="twitter:description" content="<%= typeof pageDescription !== 'undefined' ? pageDescription : (siteSettings.seoDescription || 'Website Resmi Himpunan Mahasiswa Islam Komisariat Kedokteran Gigi UMI') %>">
    <meta name="twitter:image" content="<%= typeof pageImage !== 'undefined' ? pageImage : (siteSettings.seoImage || siteSettings.headerLogo) %>">

    <!-- Structured Data (JSON-LD) untuk Google Rich Snippets -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "<%= siteSettings.webTitle %>",
      "url": "https://hmikomkgumi.xyz",
      "logo": "<%= siteSettings.headerLogo %>",
      "description": "<%= siteSettings.seoDescription || 'Website Resmi Himpunan Mahasiswa Islam Komisariat Kedokteran Gigi UMI' %>"
    }
    </script>
    <!-- ==============================================================
         END OF SEO UPGRADE
    ============================================================== -->

    <!-- OPTIMASI 2: PRECONNECT & DNS-PREFETCH (Super Cepat untuk Resource Luar) -->
    <link rel="dns-prefetch" href="https://fonts.googleapis.com">
    <link rel="dns-prefetch" href="https://fonts.gstatic.com">
    <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin>
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preconnect" href="https://unpkg.com" crossorigin>
    
    <!-- OPTIMASI 3: ASYNC GOOGLE FONTS (Font dimuat di latar belakang agar teks langsung muncul) -->
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700;800&display=swap">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700;800&display=swap" media="print" onload="this.media='all'">
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700;800&display=swap"></noscript>
    
    <!-- CSS UTAMA -->
    <link rel="preload" as="style" href="/css/main.css">
    <link rel="stylesheet" href="/css/main.css">

    <!-- OPTIMASI 4: DEFER LUCIDE ICONS (Berjalan tanpa memblokir perenderan HTML) -->
    <script src="https://unpkg.com/lucide@latest" defer></script>
</head>
<body>
    
    <!-- EFEK BACKGROUND ANIMASI BLOB -->
    <div class="bg-blob blob-1"></div>
    <div class="bg-blob blob-2"></div>

    <nav class="glass-header">
        <div class="container navbar">
            <button class="mobile-menu-btn" id="mobile-menu-btn" aria-label="Buka Menu Mobile">
                <i data-lucide="menu"></i>
            </button>

            <a href="/" class="logo-area" aria-label="Ke Beranda">
                <div class="logo-box" style="width:45px; height:45px;">
                    <!-- OPTIMASI 5: Prioritas Fetch Tinggi pada Logo Utama -->
                    <img src="<%= siteSettings.headerLogo %>" alt="Logo" class="logo-img" width="45" height="45" style="width:100%; max-width:45px; object-fit:contain;" fetchpriority="high">
                </div>
                <div class="logo-text">
                    <h1><%= siteSettings.headerTitle %><span class="text-primary"><%= siteSettings.headerHighlight %></span></h1>
                    <p><%= siteSettings.headerSubtitle %></p>
                </div>
            </a>
            
            <ul class="nav-links" id="nav-links">
                <li><a href="/" class="nav-item <%= typeof page !== 'undefined' && page === 'beranda' ? 'active' : '' %>"><i data-lucide="home"></i> Beranda</a></li>
                <li><a href="/tentang" class="nav-item <%= typeof page !== 'undefined' && page === 'tentang' ? 'active' : '' %>"><i data-lucide="info"></i> Tentang</a></li>
                <li><a href="/galeri" class="nav-item <%= typeof page !== 'undefined' && page === 'galeri' ? 'active' : '' %>"><i data-lucide="image"></i> Galeri</a></li>
                <li><a href="/data-anggota" class="nav-item <%= typeof page !== 'undefined' && page === 'data-anggota' ? 'active' : '' %>"><i data-lucide="users"></i> Data Anggota</a></li>
            </ul>
            
            <div class="nav-actions">
                <a href="/admin" class="btn-icon" title="Login Admin" aria-label="Login Admin">
                    <i data-lucide="lock"></i>
                </a>
            </div>
        </div>
    </nav>
    
    <main>
        <div class="container">

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const mobileMenuBtn = document.getElementById('mobile-menu-btn');
            const navLinks = document.getElementById('nav-links');
            if (mobileMenuBtn && navLinks) {
                mobileMenuBtn.addEventListener('click', function() { navLinks.classList.toggle('active'); });
            }
        });
    </script>
