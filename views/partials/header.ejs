<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= siteSettings.webTitle %></title>
    <link rel="icon" type="image/png" href="<%= siteSettings.headerLogo %>">
    
    <link rel="stylesheet" href="/css/main.css">
    <script src="https://unpkg.com/lucide@latest"></script>
    <link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
    <script src="https://cdn.quilljs.com/1.3.6/quill.min.js"></script>
</head>
<body>
    
    <div class="bg-blob blob-1"></div>
    <div class="bg-blob blob-2"></div>

    <nav class="glass-header">
        <div class="container navbar">
            <button class="mobile-menu-btn" id="mobile-menu-btn">
                <i data-lucide="menu"></i>
            </button>

            <a href="/" class="logo-area">
                <div class="logo-box">
                    <img src="<%= siteSettings.headerLogo %>" alt="Logo" class="logo-img" style="width:100%; max-width:45px; object-fit:contain;">
                </div>
                <div class="logo-text">
                    <h1><%= siteSettings.headerTitle %><span class="text-primary"><%= siteSettings.headerHighlight %></span></h1>
                    <p><%= siteSettings.headerSubtitle %></p>
                </div>
            </a>
            
            <ul class="nav-links" id="nav-links">
                <li><a href="/" class="nav-item <%= page === 'beranda' ? 'active' : '' %>"><i data-lucide="home"></i> Beranda</a></li>
                <li><a href="/tentang" class="nav-item <%= page === 'tentang' ? 'active' : '' %>"><i data-lucide="info"></i> Tentang</a></li>
                <li><a href="/galeri" class="nav-item <%= page === 'galeri' ? 'active' : '' %>"><i data-lucide="image"></i> Galeri</a></li>
                <li><a href="/data-anggota" class="nav-item <%= page === 'data-anggota' ? 'active' : '' %>"><i data-lucide="users"></i> Data Anggota</a></li>
            </ul>
            
            <div class="nav-actions">
                <a href="/admin" class="btn-icon" title="Login Admin">
                    <i data-lucide="lock"></i>
                </a>
            </div>
        </div>
    </nav>
    
    <main>
        <div class="container">

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const mobileMenuBtn = document.getElementById('mobile-menu-btn');
            const navLinks = document.getElementById('nav-links');
            if (mobileMenuBtn && navLinks) {
                mobileMenuBtn.addEventListener('click', function() { navLinks.classList.toggle('active'); });
            }
        });
    </script>
