<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= siteSettings.webTitle %></title>
    <link rel="icon" type="image/png" href="<%= siteSettings.headerLogo %>">
    
    <!-- OPTIMASI 1: PRECONNECT (Membangun koneksi awal ke server CDN untuk memangkas Latensi) -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preconnect" href="https://unpkg.com">
    
    <!-- OPTIMASI 2: FONT ASYNC (Menggunakan swap agar teks langsung muncul sebelum font selesai diload) -->
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700;800&display=swap" rel="stylesheet">
    
    <!-- Memuat CSS Utama -->
    <link rel="stylesheet" href="/css/main.css">

    <!-- OPTIMASI 3: DEFER SCRIPT (Pustaka Icon dimuat di latar belakang tanpa memblokir render HTML) -->
    <script src="https://unpkg.com/lucide@latest" defer></script>
    
    <!-- CATATAN PERFORMA: Library Quill (Editor Teks) TELAH DIHAPUS dari header publik. 
         Library tersebut sangat memberatkan PageSpeed dan kini HANYA dipanggil di dalam halaman admin-dashboard.ejs -->
</head>
<body>
    
    <div class="bg-blob blob-1"></div>
    <div class="bg-blob blob-2"></div>

    <nav class="glass-header">
        <div class="container navbar">
            <button class="mobile-menu-btn" id="mobile-menu-btn" aria-label="Buka Menu Mobile">
                <i data-lucide="menu"></i>
            </button>

            <a href="/" class="logo-area" aria-label="Ke Beranda">
                <div class="logo-box">
                    <img src="<%= siteSettings.headerLogo %>" alt="Logo" class="logo-img" width="45" height="45" style="width:100%; max-width:45px; object-fit:contain;">
                </div>
                <div class="logo-text">
                    <h1><%= siteSettings.headerTitle %><span class="text-primary"><%= siteSettings.headerHighlight %></span></h1>
                    <p><%= siteSettings.headerSubtitle %></p>
                </div>
            </a>
            
            <ul class="nav-links" id="nav-links">
                <li><a href="/" class="nav-item <%= page === 'beranda' ? 'active' : '' %>"><i data-lucide="home"></i> Beranda</a></li>
                <li><a href="/tentang" class="nav-item <%= page === 'tentang' ? 'active' : '' %>"><i data-lucide="info"></i> Tentang</a></li>
                <li><a href="/galeri" class="nav-item <%= page === 'galeri' ? 'active' : '' %>"><i data-lucide="image"></i> Galeri</a></li>
                <li><a href="/data-anggota" class="nav-item <%= page === 'data-anggota' ? 'active' : '' %>"><i data-lucide="users"></i> Data Anggota</a></li>
            </ul>
            
            <div class="nav-actions">
                <a href="/admin" class="btn-icon" title="Login Admin" aria-label="Login Admin">
                    <i data-lucide="lock"></i>
                </a>
            </div>
        </div>
    </nav>
    
    <main>
        <div class="container">

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const mobileMenuBtn = document.getElementById('mobile-menu-btn');
            const navLinks = document.getElementById('nav-links');
            if (mobileMenuBtn && navLinks) {
                mobileMenuBtn.addEventListener('click', function() { navLinks.classList.toggle('active'); });
            }
        });
    </script>
