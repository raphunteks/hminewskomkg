<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    
    <meta name="google-site-verification" content="lV4veWnfsXOsnHBVIUxj7uQUA_jdJIQ6Guk4bPGFGHc" />

    <% 
    // BASE URL: Wajib untuk memastikan OG Image terbaca oleh sistem Social Media
    const baseUrl = 'https://hmikomkgumi.xyz';
    
    // SAFE OBJECT DESTRUCTURING: Mencegah crash jika siteSettings tidak termuat
    const safeSettings = typeof siteSettings !== 'undefined' && siteSettings ? siteSettings : {};
    
    // Default SEO Fallback (Dari Setelan Admin Dashboard)
    let finalTitle = safeSettings.webTitle || 'HMI KomKG UMI';
    let finalDesc = safeSettings.seoDescription || 'Website Resmi Himpunan Mahasiswa Islam Komisariat Kedokteran Gigi UMI';
    let finalImage = safeSettings.seoImage || safeSettings.headerLogo || '';
    let finalType = 'website';
    let finalUrl = typeof currentUrl !== 'undefined' && currentUrl ? currentUrl : baseUrl;
    let finalDate = new Date().toISOString(); // Default date
    let finalCategory = 'Organisasi';

    // Pastikan URL Halaman adalah Absolute URL
    if (finalUrl.startsWith('/')) {
        finalUrl = baseUrl + finalUrl;
    }

    // AUTO-DETEKSI: Jika halaman sedang membuka DETAIL BERITA
    if (typeof berita !== 'undefined' && berita) {
        finalTitle = (berita.title || 'Berita') + ' - ' + (safeSettings.webTitle || 'HMI');
        // Membersihkan tag HTML secara aman
        if (berita.content) {
            finalDesc = berita.content.replace(/<[^>]+>/g, '').replace(/&nbsp;/g, ' ').substring(0, 160) + '...';
        }
        if (berita.image) finalImage = berita.image;
        finalType = 'article';
        finalDate = berita.date || finalDate;
        finalCategory = berita.category || 'Berita';
    } 
    // AUTO-DETEKSI: Jika halaman sedang membuka DETAIL GALERI
    else if (typeof album !== 'undefined' && album) {
        finalTitle = 'Galeri: ' + (album.title || '') + ' - ' + (safeSettings.webTitle || 'HMI');
        finalDesc = 'Dokumentasi kegiatan ' + (album.title || '') + ' HMI Komisariat Kedokteran Gigi UMI pada ' + (album.date || '') + '.';
        if (album.cover) finalImage = album.cover;
        finalType = 'article';
        finalDate = album.date || finalDate;
        finalCategory = 'Galeri Kegiatan';
    } 
    // DETEKSI VARIABEL MANUAL (Jika di-set secara spesifik dari backend)
    else if (typeof pageTitle !== 'undefined' && pageTitle) {
        finalTitle = pageTitle + ' - ' + (safeSettings.webTitle || 'HMI');
        if (typeof pageDescription !== 'undefined' && pageDescription) finalDesc = pageDescription;
        if (typeof pageImage !== 'undefined' && pageImage) finalImage = pageImage;
        if (typeof pageType !== 'undefined' && pageType) finalType = pageType;
    }

    // KONVERSI GAMBAR KE ABSOLUTE URL (VITAL UNTUK PREVIEW SOSMED BESAR)
    if (finalImage && !finalImage.startsWith('http')) {
        if (!finalImage.startsWith('/')) finalImage = '/' + finalImage;
        finalImage = baseUrl + finalImage;
    }
    
    // Logo Absolute untuk Schema Publisher
    let absoluteLogo = safeSettings.headerLogo || '';
    if (absoluteLogo && !absoluteLogo.startsWith('http')) {
        if (!absoluteLogo.startsWith('/')) absoluteLogo = '/' + absoluteLogo;
        absoluteLogo = baseUrl + absoluteLogo;
    }
    %>

    <title><%= finalTitle %></title>
    
    <meta name="description" content="<%= finalDesc %>">
    <link rel="icon" type="image/png" href="<%= safeSettings.headerLogo || '/favicon.ico' %>">

    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1">
    <meta name="googlebot" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1">
    
    <meta name="keywords" content="<%= typeof pageKeywords !== 'undefined' && pageKeywords ? pageKeywords : (safeSettings.seoKeywords || 'hmi komkg umi, hmikomkgumi, hmi, hmi kom kg umi, hmicabmakassar, yakusa') %>">
    <meta name="author" content="<%= safeSettings.headerTitle || 'HMI KomKG UMI' %>">
    <link rel="canonical" href="<%= finalUrl %>" />
    <meta name="theme-color" content="#064e3b">

    <meta property="og:locale" content="id_ID">
    <meta property="og:type" content="<%= finalType %>">
    <meta property="og:title" content="<%= finalTitle %>">
    <meta property="og:description" content="<%= finalDesc %>">
    <meta property="og:url" content="<%= finalUrl %>">
    <meta property="og:site_name" content="<%= safeSettings.webTitle || 'HMI KomKG UMI' %>">
    
    <% if (finalType === 'article') { %>
        <meta property="article:published_time" content="<%= finalDate %>">
        <meta property="article:author" content="Admin HMI KomKG UMI">
        <meta property="article:section" content="<%= finalCategory %>">
    <% } %>

    <meta property="og:image" content="<%= finalImage %>">
    <meta property="og:image:secure_url" content="<%= finalImage %>">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
    <meta property="og:image:alt" content="Cover <%= finalTitle %>">

    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:domain" content="hmikomkgumi.xyz">
    <meta name="twitter:url" content="<%= finalUrl %>">
    <meta name="twitter:title" content="<%= finalTitle %>">
    <meta name="twitter:description" content="<%= finalDesc %>">
    <meta name="twitter:image" content="<%= finalImage %>">

    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "<%= finalType === 'article' ? 'NewsArticle' : 'WebSite' %>",
      "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": "<%= finalUrl %>"
      },
      "headline": "<%= finalTitle.replace(/"/g, '\\"') %>",
      "image": [
        "<%= finalImage %>"
      ],
      <% if (finalType === 'article') { %>
      "datePublished": "<%= finalDate %>",
      "dateModified": "<%= finalDate %>",
      "author": {
        "@type": "Organization",
        "name": "HMI KomKG UMI",
        "url": "<%= baseUrl %>"
      },
      <% } %>
      "publisher": {
        "@type": "Organization",
        "name": "<%= (safeSettings.webTitle || 'HMI').replace(/"/g, '\\"') %>",
        "logo": {
          "@type": "ImageObject",
          "url": "<%= absoluteLogo %>"
        }
      },
      "description": "<%= finalDesc.replace(/"/g, '\\"') %>"
    }
    </script>

    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Beranda",
          "item": "<%= baseUrl %>"
        }
        <% if (typeof berita !== 'undefined' && berita) { %>
        ,{
          "@type": "ListItem",
          "position": 2,
          "name": "Berita",
          "item": "<%= baseUrl %>/"
        },{
          "@type": "ListItem",
          "position": 3,
          "name": "<%= (berita.title || '').replace(/"/g, '\\"') %>",
          "item": "<%= finalUrl %>"
        }
        <% } else if (typeof album !== 'undefined' && album) { %>
        ,{
          "@type": "ListItem",
          "position": 2,
          "name": "Galeri",
          "item": "<%= baseUrl %>/galeri"
        },{
          "@type": "ListItem",
          "position": 3,
          "name": "<%= (album.title || '').replace(/"/g, '\\"') %>",
          "item": "<%= finalUrl %>"
        }
        <% } else if (typeof page !== 'undefined' && page !== 'beranda') { %>
        ,{
          "@type": "ListItem",
          "position": 2,
          "name": "<%= typeof pageTitle !== 'undefined' && pageTitle ? pageTitle.replace(/"/g, '\\"') : (page.charAt(0).toUpperCase() + page.slice(1)) %>",
          "item": "<%= finalUrl %>"
        }
        <% } %>
      ]
    }
    </script>
    <link rel="dns-prefetch" href="https://fonts.googleapis.com">
    <link rel="dns-prefetch" href="https://fonts.gstatic.com">
    <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin>
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preconnect" href="https://unpkg.com" crossorigin>
    
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700;800&display=swap">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700;800&display=swap" media="print" onload="this.media='all'">
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700;800&display=swap"></noscript>
    
    <link rel="preload" as="style" href="/css/main.css">
    <link rel="stylesheet" href="/css/main.css">

    <script src="https://unpkg.com/lucide@latest" defer></script>

    <script>
        window.si = window.si || function () { (window.siq = window.siq || []).push(arguments); };
    </script>
    <script src="/_vercel/speed-insights/script.js" defer></script>
    <%- include('schema') %>
</head>
<body>
    
    <div class="bg-blob blob-1"></div>
    <div class="bg-blob blob-2"></div>

    <nav class="glass-header">
        <div class="container navbar">
            <button class="mobile-menu-btn" id="mobile-menu-btn" aria-label="Buka Menu Mobile">
                <i data-lucide="menu"></i>
            </button>

            <a href="/" class="logo-area" aria-label="Ke Beranda">
                <div class="logo-box" style="width:45px; height:45px;">
                    <img src="<%= safeSettings.headerLogo %>" alt="Logo" class="logo-img" width="45" height="45" style="width:100%; max-width:45px; object-fit:contain;" fetchpriority="high">
                </div>
                <div class="logo-text">
                    <h1><%= safeSettings.headerTitle || 'HMI' %><span class="text-primary"><%= safeSettings.headerHighlight || '' %></span></h1>
                    <p><%= safeSettings.headerSubtitle || '' %></p>
                </div>
            </a>
            
            <ul class="nav-links" id="nav-links">
                <li><a href="/" class="nav-item <%= typeof page !== 'undefined' && page === 'beranda' ? 'active' : '' %>"><i data-lucide="home"></i> Beranda</a></li>
                <li><a href="/tentang" class="nav-item <%= typeof page !== 'undefined' && page === 'tentang' ? 'active' : '' %>"><i data-lucide="info"></i> Tentang</a></li>
                <li><a href="/galeri" class="nav-item <%= typeof page !== 'undefined' && page === 'galeri' ? 'active' : '' %>"><i data-lucide="image"></i> Galeri</a></li>
                <li><a href="/data-anggota" class="nav-item <%= typeof page !== 'undefined' && page === 'data-anggota' ? 'active' : '' %>"><i data-lucide="users"></i> Data Anggota</a></li>
            </ul>
            
            <div class="nav-actions">
                <a href="/admin" class="btn-icon" title="Login Admin" aria-label="Login Admin">
                    <i data-lucide="lock"></i>
                </a>
            </div>
        </div>
    </nav>
    
    <main>
        <div class="container">

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const mobileMenuBtn = document.getElementById('mobile-menu-btn');
            const navLinks = document.getElementById('nav-links');
            if (mobileMenuBtn && navLinks) {
                mobileMenuBtn.addEventListener('click', function() { navLinks.classList.toggle('active'); });
            }
        });
    </script>
