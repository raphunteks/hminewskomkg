<%- include('partials/header') %>

<!-- POPUP PENGUMUMAN HORIZONTAL (DIEMBED LANGSUNG AGAR ANTI CRASH 500) -->
<% if (typeof siteSettings !== 'undefined' && siteSettings.announceActive === 'true') { %>
<div class="modal-overlay announce-overlay" id="announceModal" style="z-index: 9999999; padding: 20px;">
    <div class="announce-horizontal" style="display: flex; max-width: 850px; width: 100%; max-height: 80vh; background: #1b4332; border-radius: 16px; overflow: hidden; position: relative; box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.6); border: 1px solid rgba(74,222,128,0.2);">
        
        <button class="close-modal" style="position:absolute; top: 15px; right: 15px; z-index: 10; background:rgba(0,0,0,0.3); border-radius:50%; padding:8px; color:#fff; border: 1px solid rgba(255,255,255,0.1); cursor:pointer; transition:0.3s;" onmouseover="this.style.background='rgba(239,68,68,0.8)'" onmouseout="this.style.background='rgba(0,0,0,0.3)'" onclick="closeAnnounce()">
            <i data-lucide="x" style="width: 18px; height: 18px;"></i>
        </button>

        <% if (siteSettings.announceImage) { %>
        <div class="announce-left" style="flex: 0 0 45%; max-width: 45%; background: #000; position: relative; min-height: 300px;">
            <img src="<%= siteSettings.announceImage %>" alt="Announcement" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover;">
        </div>
        <% } %>

        <div class="announce-right" style="flex: 1; padding: 40px 30px; display: flex; flex-direction: column; overflow-y: auto;">
            <h2 style="color: #fff; margin-bottom: 10px; font-size: 2rem; font-weight: 800; line-height: 1.2; padding-right: 30px;"><%= siteSettings.announceTitle %></h2>
            <div style="width: 40px; height: 4px; background: #4ade80; margin-bottom: 20px; border-radius: 2px; flex-shrink: 0;"></div>

            <div class="rich-text-content announce-text" style="color: #d1d5db; margin-bottom: 30px; line-height: 1.6; font-size: 0.95rem; border-left: 3px solid rgba(74, 222, 128, 0.4); padding-left: 15px;">
                <%- siteSettings.announceContent %>
            </div>

            <button class="btn" style="align-self: flex-start; margin-top: auto; padding: 10px 24px; font-size: 0.95rem; border-radius: 8px; font-weight: bold; background: transparent; border: 1px solid #4ade80; color: #4ade80; cursor:pointer; transition: 0.3s;" onmouseover="this.style.background='#4ade80'; this.style.color='#000';" onmouseout="this.style.background='transparent'; this.style.color='#4ade80';" onclick="readAnnounce()">Tutup Pengumuman</button>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const titleKey = '<%= siteSettings.announceTitle.replace(/[^a-zA-Z0-9]/g, "_") %>';
        const announceKey = 'announce_read_' + titleKey;
        if (!localStorage.getItem(announceKey)) {
            setTimeout(() => { document.getElementById('announceModal').classList.add('active'); }, 600);
        }
    });

    function closeAnnounce() { 
        document.getElementById('announceModal').classList.remove('active'); 
    }

    function readAnnounce() {
        const titleKey = '<%= siteSettings.announceTitle.replace(/[^a-zA-Z0-9]/g, "_") %>';
        const announceKey = 'announce_read_' + titleKey;
        localStorage.setItem(announceKey, 'true');
        closeAnnounce();
    }
</script>
<% } %>

<!-- Hero / Selamat Datang -->
<div class="glass hero">
    <span class="badge">Yakusa! Yakin Usaha Sampai</span>
    <h1>Selamat datang di website resmi <br><span class="text-gradient"><%= siteSettings.heroTitle || siteSettings.webTitle %></span></h1>
    <p>Kami adalah sebuah organisasi mahasiswa yang terdiri dari para mahasiswa kedokteran gigi yang memiliki komitmen untuk meningkatkan kualitas diri dan mengembangkan potensi dalam bidang akademik, keislaman, sosial, dan kemanusiaan.</p>
    <a href="/tentang" class="btn btn-primary">Kenali Kami Lebih Dekat</a>
</div>

<!-- Section Berita -->
<div class="section-header">
    <div>
        <h2>Berita & Informasi</h2>
        <p class="text-muted">Update terbaru dari kegiatan komisariat</p>
    </div>
    <div class="filter-tags">
        <a href="/" class="filter-tag <%= currentFilter === 'Semua' ? 'active' : '' %>">Semua</a>
        <a href="/?filter=Terbaru" class="filter-tag <%= currentFilter === 'Terbaru' ? 'active' : '' %>">Terbaru</a>
        <a href="/?filter=Pin" class="filter-tag <%= currentFilter === 'Pin' ? 'active' : '' %>">Pin</a>
        <a href="/?filter=Populer" class="filter-tag <%= currentFilter === 'Populer' ? 'active' : '' %>">Populer</a>
    </div>
</div>

<div class="grid-3">
    <% if(news.length > 0) { %>
        <% news.forEach(item => { %>
        <a href="/berita/<%= item.id %>" class="glass news-card">
            <div class="card-img-wrap">
                <img src="<%= item.image %>" alt="Cover Berita">
                <div class="card-badge"><%= item.category %></div>
            </div>
            <div class="card-body">
                <div class="card-meta">
                    <i data-lucide="calendar" style="width:14px;"></i> <%= item.date %>
                    <% if(item.photos && item.photos.length > 0) { %>
                        <span style="margin-left:auto; color:#9ca3af; display:flex; align-items:center; gap:3px;">
                            <i data-lucide="image" style="width:12px;"></i> +<%= item.photos.length %>
                        </span>
                    <% } %>
                </div>
                <h3 class="card-title"><%= item.title %></h3>
                <p class="card-text"><%- item.content.replace(/<[^>]+>/g, '').substring(0, 100) %>...</p>
                <div class="read-more">Baca Selengkapnya <i data-lucide="chevron-right" style="width:16px;"></i></div>
            </div>
        </a>
        <% }) %>
    <% } else { %>
        <p class="text-muted" style="grid-column: 1 / -1; text-align: center; padding: 40px 0;">Belum ada berita dalam kategori ini.</p>
    <% } %>
</div>

<%- include('partials/footer') %>
