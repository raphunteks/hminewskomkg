<% 
    // ==============================================================
    // FIX ERROR 500 & SEO BREADCRUMB: 
    // Injeksi variabel SEO secara eksplisit untuk Halaman Beranda
    // ==============================================================
    let page = 'beranda';
    let pageTitle = 'Beranda';
%>
<%- include('partials/header', { page: page, pageTitle: pageTitle }) %>

<!-- POPUP PENGUMUMAN HORIZONTAL -->
<% if (typeof siteSettings !== 'undefined' && (siteSettings.announceActive === 'true' || siteSettings.announceActive === true)) { %>
<%- include('partials/announce') %>
<% } %>

<!-- ==============================================================
     EXPERT SEO UPGRADE: Semantic WebSite Header
============================================================== -->
<header class="glass hero" itemscope itemtype="https://schema.org/WebSite">
    <link itemprop="url" href="https://hmikomkgumi.xyz"/>
    <span class="badge">Yakusa! Yakin Usaha Sampai</span>
    <h1 itemprop="name">Selamat datang di website resmi <br><span class="text-gradient"><%= siteSettings.heroTitle || siteSettings.webTitle %></span></h1>
    <p itemprop="description">Kami adalah sebuah organisasi mahasiswa yang terdiri dari para mahasiswa kedokteran gigi yang memiliki komitmen untuk meningkatkan kualitas diri dan mengembangkan potensi dalam bidang akademik, keislaman, sosial, dan kemanusiaan.</p>
    <a href="/tentang" class="btn btn-primary" aria-label="Kenali Kami Lebih Dekat">Kenali Kami Lebih Dekat</a>
</header>

<!-- ==============================================================
     EXPERT SEO UPGRADE: Semantic Section & Navigation
============================================================== -->
<section>
    <div class="section-header" style="margin-top: 50px;">
        <div>
            <h2>Berita & Informasi</h2>
            <p class="text-muted">Update terbaru dari kegiatan komisariat</p>
        </div>
        <div class="filter-tags" role="navigation" aria-label="Filter Kategori Berita">
            <a href="/" class="filter-tag <%= currentFilter === 'Semua' ? 'active' : '' %>" aria-label="Tampilkan Semua Berita">Semua</a>
            <a href="/?filter=Terbaru" class="filter-tag <%= currentFilter === 'Terbaru' ? 'active' : '' %>" aria-label="Filter Berita Terbaru">Terbaru</a>
            <a href="/?filter=Pin" class="filter-tag <%= currentFilter === 'Pin' ? 'active' : '' %>" aria-label="Filter Berita Disematkan">Pin</a>
            <a href="/?filter=Populer" class="filter-tag <%= currentFilter === 'Populer' ? 'active' : '' %>" aria-label="Filter Berita Populer">Populer</a>
        </div>
    </div>

    <!-- ==============================================================
         EXPERT SEO UPGRADE: ItemList & NewsArticle Microdata
         (Didesain dengan display:contents agar layout Grid tidak rusak)
    ============================================================== -->
    <div class="grid-3" itemscope itemtype="https://schema.org/ItemList">
        <meta itemprop="itemListOrder" content="https://schema.org/ItemListOrderDescending" />
        
        <% if(news.length > 0) { %>
            <% news.forEach((item, index) => { %>
            
            <article itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem" style="display:contents;">
                <meta itemprop="position" content="<%= index + 1 %>" />
                
                <a href="/berita/<%= item.id %>" class="glass news-card" itemprop="item" itemscope itemtype="https://schema.org/NewsArticle">
                    <meta itemprop="url" content="https://hmikomkgumi.xyz/berita/<%= item.id %>">
                    <meta itemprop="author" content="Admin HMI KomKG UMI">
                    
                    <div class="card-img-wrap">
                        <!-- OPTIMASI 4: NATIVE LAZY LOADING & ASYNC DECODING (Dengan itemprop Image) -->
                        <img itemprop="image" src="<%= item.image %>" alt="Cover Berita: <%= item.title %>" loading="lazy" decoding="async" width="400" height="200">
                        <div class="card-badge" itemprop="articleSection"><%= item.category %></div>
                    </div>
                    <div class="card-body">
                        <div class="card-meta">
                            <i data-lucide="calendar" style="width:14px;"></i> 
                            <time itemprop="datePublished" datetime="<%= item.date %>"><%= item.date %></time>
                            <% if(item.photos && item.photos.length > 0) { %>
                                <span style="margin-left:auto; color:#9ca3af; display:flex; align-items:center; gap:3px;" aria-label="<%= item.photos.length %> Foto Tambahan">
                                    <i data-lucide="image" style="width:12px;"></i> +<%= item.photos.length %>
                                </span>
                            <% } %>
                        </div>
                        <h3 class="card-title" itemprop="headline"><%= item.title %></h3>
                        <p class="card-text" itemprop="description"><%- item.content.replace(/<[^>]+>/g, '').substring(0, 100) %>...</p>
                        <div class="read-more">Baca Selengkapnya <i data-lucide="chevron-right" style="width:16px;"></i></div>
                    </div>
                </a>
            </article>

            <% }) %>
        <% } else { %>
            <p class="text-muted" style="grid-column: 1 / -1; text-align: center; padding: 40px 0;">Belum ada berita dalam kategori ini.</p>
        <% } %>
    </div>
</section>

<%- include('partials/instagram-feed') %>

<!-- ==============================================================
     SUPER BIG UPGRADE: DASHBOARD ANALYTICS WIDGET
     Versi Anti-Error CORS & Fast Response
============================================================== -->
<section class="analytics-section" aria-label="Statistik Kunjungan Website">
    <div class="analytics-grid">
        <div class="analytic-card">
            <h4 class="analytic-title">VIEWS TODAY</h4>
            <div class="analytic-value stat-today" id="val-today">
                <i data-lucide="loader-2" class="spin-icon"></i>
            </div>
        </div>
        <div class="analytic-card">
            <h4 class="analytic-title">THIS WEEK</h4>
            <div class="analytic-value stat-week" id="val-week">
                <i data-lucide="loader-2" class="spin-icon"></i>
            </div>
        </div>
        <div class="analytic-card">
            <h4 class="analytic-title">TOTAL VIEWS</h4>
            <div class="analytic-value stat-total" id="val-total">
                <i data-lucide="loader-2" class="spin-icon"></i>
            </div>
        </div>
    </div>
</section>

<!-- SCRIPT PENGGERAK API GOOGLE APPS SCRIPT -->
<script>
document.addEventListener('DOMContentLoaded', () => {
    // --- GANTI DENGAN URL DEPLOYMENT GOOGLE SCRIPT YANG BARU ---
    const GAS_URL = "https://script.google.com/macros/s/AKfycbw8MA9YGFK3SIAXhIZAF9m1J4eOGf9LGQD-j4xXjvVSaQ826JrqeEKApPcKJWfJxw/exec";

    // Variabel state untuk mencegah update animasi berulang
    let currentStats = { today: -1, week: -1, total: -1 };

    function animateValue(obj, start, end, duration) {
        if (start === end) return; 
        let startTimestamp = null;
        const step = (timestamp) => {
            if (!startTimestamp) startTimestamp = timestamp;
            const progress = Math.min((timestamp - startTimestamp) / duration, 1);
            obj.innerHTML = Math.floor(progress * (end - start) + start).toLocaleString('id-ID'); 
            if (progress < 1) {
                window.requestAnimationFrame(step);
            }
        };
        window.requestAnimationFrame(step);
    }

    function updateUI(data, speed) {
        if(data.today !== undefined && data.today !== currentStats.today) {
            animateValue(document.getElementById('val-today'), Math.max(0, currentStats.today), data.today, speed);
            currentStats.today = data.today;
        }
        if(data.week !== undefined && data.week !== currentStats.week) {
            animateValue(document.getElementById('val-week'), Math.max(0, currentStats.week), data.week, speed);
            currentStats.week = data.week;
        }
        if(data.total !== undefined && data.total !== currentStats.total) {
            animateValue(document.getElementById('val-total'), Math.max(0, currentStats.total), data.total, speed);
            currentStats.total = data.total;
        }
    }

    // TAHAP 1: FAST FETCH (Memuat data dalam milidetik)
    async function fastFetchData() {
        try {
            // Parameter ?t= mencegah HP melakukan Cache angka lama
            const response = await fetch(GAS_URL + "?t=" + new Date().getTime());
            const textResponse = await response.text(); 
            
            try {
                const data = JSON.parse(textResponse);
                updateUI(data, 1000);
            } catch (jsonErr) {
                console.warn("GAS Redirect/CORS Error, menggunakan fallback UI.");
                setFallbackUI();
            }
        } catch (err) {
            console.warn("Koneksi ke GAS lambat/gagal.", err);
        }
    }

    // TAHAP 2: SILENT POST (Merekam IP Pengunjung di Latar Belakang)
    async function recordVisitPost() {
        try {
            const ipResponse = await fetch('https://api.ipify.org?format=json');
            const ipData = await ipResponse.json();
            const clientIP = ipData.ip || 'Unknown';

            const response = await fetch(GAS_URL, {
                method: 'POST',
                headers: { 'Content-Type': 'text/plain;charset=utf-8' },
                body: JSON.stringify({ ip: clientIP })
            });

            const textResponse = await response.text();
            
            try {
                const data = JSON.parse(textResponse);
                if(data.status === "success") {
                    updateUI(data, 500); // Update halus jika angka bertambah
                }
            } catch (jsonErr) {
                // Abaikan error HTML karena UI sudah terisi oleh GET sebelumnya
            }
        } catch (error) {
            // Berjalan secara silent
        }
    }

    function setFallbackUI() {
        if(currentStats.today === -1) {
            document.getElementById('val-today').innerHTML = "-";
            document.getElementById('val-week').innerHTML = "-";
            document.getElementById('val-total').innerHTML = "-";
        }
    }

    // EKSEKUSI TAHAP 1: Langsung muat data agar pengunjung instan melihat angka!
    fastFetchData();

    // EKSEKUSI TAHAP 2: Rekam IP pengunjung di belakang layar setelah 2 detik
    setTimeout(() => { 
        recordVisitPost(); 
    }, 2000);

});
</script>

<%- include('partials/footer') %>
