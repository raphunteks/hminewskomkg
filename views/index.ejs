<%- include('partials/header') %>

<!-- Hero / Selamat Datang -->
<div class="glass-panel rounded-3xl p-8 md:p-16 mb-12 relative overflow-hidden">
    <div class="relative z-10 max-w-3xl">
        <span class="inline-block bg-green-500/20 text-green-400 px-4 py-1.5 rounded-full text-sm font-semibold border border-green-500/30 mb-6">Yakusa! Yakin Usaha Sampai</span>
        
        <h1 class="text-4xl md:text-5xl font-bold mb-6 leading-tight">
            Selamat datang di website resmi <br>
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-green-400 to-emerald-200">Himpunan Mahasiswa Islam Komisariat Kedokteran Gigi UMI</span>
        </h1>
        
        <p class="text-lg text-gray-300 mb-8 leading-relaxed">
            Kami adalah sebuah organisasi mahasiswa yang terdiri dari para mahasiswa kedokteran gigi yang memiliki komitmen untuk meningkatkan kualitas diri dan mengembangkan potensi dalam bidang akademik, keislaman, sosial, dan kemanusiaan.
        </p>
        
        <a href="/tentang" class="inline-block bg-green-500 text-black px-8 py-3 rounded-xl font-bold hover:bg-green-400 transition-all shadow-[0_0_20px_rgba(34,197,94,0.4)]">
            Kenali Kami Lebih Dekat
        </a>
    </div>
</div>

<!-- Section Berita -->
<div class="mb-8 flex flex-col md:flex-row justify-between items-end">
    <div>
        <h2 class="text-3xl font-bold mb-2">Berita & Informasi</h2>
        <p class="text-gray-400">Update terbaru dari kegiatan komisariat</p>
    </div>
    <div class="flex space-x-2 mt-4 md:mt-0">
        <span class="px-4 py-1.5 rounded-full bg-white/10 border border-white/20 text-sm">Terbaru</span>
        <span class="px-4 py-1.5 rounded-full bg-white/5 border border-white/10 text-sm text-gray-400">Pin</span>
        <span class="px-4 py-1.5 rounded-full bg-white/5 border border-white/10 text-sm text-gray-400">Populer</span>
    </div>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    <% news.forEach(item => { %>
    <div class="glass-panel rounded-2xl overflow-hidden hover:bg-white/5 transition-all duration-300 group border border-white/10">
        <div class="relative h-48 overflow-hidden">
            <img src="<%= item.image %>" class="w-full h-full object-cover transform group-hover:scale-110 transition-transform duration-500" alt="<%= item.title %>">
            <div class="absolute top-3 left-3 bg-black/60 backdrop-blur-md px-3 py-1 rounded-lg text-xs font-semibold border border-white/10 text-white"><%= item.category %></div>
        </div>
        <div class="p-5">
            <div class="text-xs text-green-400 mb-2 flex items-center">
                <i data-lucide="calendar" class="w-3 h-3 mr-1"></i> <%= item.date %>
            </div>
            <h3 class="text-xl font-bold mb-3 line-clamp-2 group-hover:text-green-300 transition-colors"><%= item.title %></h3>
            <a href="#" class="text-green-400 text-sm font-semibold hover:text-green-300 flex items-center">Baca Selengkapnya <i data-lucide="chevron-right" class="w-4 h-4 ml-1"></i></a>
        </div>
    </div>
    <% }) %>
</div>

<%- include('partials/footer') %>