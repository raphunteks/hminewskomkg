<% 
    // ==============================================================
    // SUPER BIG UPGRADE: ERROR 500 PREVENTION (BULLETPROOF EJS)
    // Mencegah server Node.js crash jika ID Berita tidak ditemukan/dihapus
    // ==============================================================
    let safeBerita = (typeof berita !== 'undefined' && berita) ? berita : {
        id: '404',
        title: 'Berita Tidak Ditemukan',
        content: '<p>Mohon maaf, konten berita telah dihapus atau tidak tersedia.</p>',
        image: '/img/logo.png',
        category: 'Umum',
        date: new Date().toLocaleDateString('id-ID'),
        photos: []
    };

    let pageTitle = safeBerita.title;
    
    // SMART UPGRADE: Membersihkan tag HTML dari konten untuk meta description (max 150 chars)
    let rawContent = safeBerita.content || "";
    let cleanDesc = rawContent.replace(/<[^>]+>/g, '').replace(/\n/g, ' ').trim();
    let pageDescription = cleanDesc.length > 150 ? cleanDesc.substring(0, 150) + "..." : (cleanDesc || "Baca informasi terbaru dari HMI KomKG UMI.");
    
    // Standarisasi Base URL dan URL Gambar Absolute
    const seoBaseUrl = 'https://www.hmikomkgumi.xyz';
    let rawImage = safeBerita.image || '/img/logo.png';
    let absoluteImage = rawImage.startsWith('http') ? rawImage : seoBaseUrl + (rawImage.startsWith('/') ? '' : '/') + rawImage;
    let articleUrl = seoBaseUrl + "/berita/" + safeBerita.id;
%>
<%- include('partials/header', { pageTitle: pageTitle, pageDescription: pageDescription }) %>

<!-- ==============================================================
     SUPER BIG UPGRADE SEO & ANTI-ERROR PRATINJAU (PREVIEW-SAFE)
     Mengubah cara injeksi variabel EJS agar tidak bertabrakan dengan JS Parser.
     Semua data server-side (EJS) ditampung di dalam HTML DOM terlebih dahulu.
============================================================== -->
<div id="seo-server-data" 
     style="display:none;" 
     data-title="<%= pageTitle %>" 
     data-desc="<%= pageDescription %>" 
     data-url="<%= articleUrl %>" 
     data-img="<%= absoluteImage %>" 
     data-cat="<%= safeBerita.category %>" 
     data-date="<%= safeBerita.date %>"
     data-baseurl="<%= seoBaseUrl %>">
</div>

<script>
document.addEventListener('DOMContentLoaded', () => {
    // 1. MENGAMBIL DATA DARI DOM (Sangat Aman untuk fitur Pratinjau tanpa memicu SyntaxError)
    const seoDataEl = document.getElementById('seo-server-data');
    if(!seoDataEl) return;
    
    const d_title = seoDataEl.getAttribute('data-title');
    const d_desc = seoDataEl.getAttribute('data-desc');
    const d_url = seoDataEl.getAttribute('data-url');
    const d_img = seoDataEl.getAttribute('data-img');
    const d_cat = seoDataEl.getAttribute('data-cat');
    const d_date = seoDataEl.getAttribute('data-date');
    const d_baseurl = seoDataEl.getAttribute('data-baseurl');

    const metaTags = [
        { name: "description", content: d_desc },
        { name: "keywords", content: `${d_cat}, Berita HMI, Proker HMI KomKG UMI, Kedokteran Gigi UMI, Organisasi FKG UMI` },
        { name: "author", content: "Admin HMI KomKG UMI" },
        { name: "robots", content: "index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" },
        
        // Open Graph (WhatsApp, FB, IG)
        { property: "og:title", content: d_title + " | HMI KomKG UMI" },
        { property: "og:description", content: d_desc },
        { property: "og:type", content: "article" }, 
        { property: "og:url", content: d_url },
        { property: "og:image", content: d_img },
        { property: "og:site_name", content: "HMI KomKG UMI" },
        
        // Twitter Cards
        { property: "twitter:card", content: "summary_large_image" },
        { property: "twitter:title", content: d_title + " | HMI KomKG UMI" },
        { property: "twitter:description", content: d_desc },
        { property: "twitter:image", content: d_img }
    ];

    // Injeksi Link Canonical untuk Google Search Console
    let canonical = document.createElement('link');
    canonical.rel = 'canonical';
    canonical.href = d_url;
    document.head.appendChild(canonical);

    // Injeksi Meta Tags ke tag <head>
    metaTags.forEach(tag => {
        let selector = tag.name ? `meta[name="${tag.name}"]` : `meta[property="${tag.property}"]`;
        let existingTag = document.head.querySelector(selector);
        if (!existingTag) {
            let el = document.createElement('meta');
            if(tag.name) el.name = tag.name;
            if(tag.property) el.setAttribute('property', tag.property);
            el.content = tag.content;
            document.head.appendChild(el);
        } else {
            existingTag.content = tag.content;
        }
    });

    // ==============================================================
    // 2. INJEKSI JSON-LD (ARTICLE) SECARA DINAMIS (PREVIEW-SAFE)
    // Dibuat via Javascript agar struktur EJS murni tersembunyi dari parser
    // ==============================================================
    const jsonLdData = {
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "WebPage",
          "@id": `${d_url}/#webpage`,
          "url": d_url,
          "name": `${d_title} | HMI KomKG UMI`,
          "description": d_desc,
          "inLanguage": "id-ID",
          "isPartOf": { "@id": `${d_baseurl}/#website` }
        },
        {
          "@type": "BreadcrumbList",
          "@id": `${d_url}/#breadcrumb`,
          "itemListElement": [
            { "@type": "ListItem", "position": 1, "name": "Beranda", "item": `${d_baseurl}/` },
            { "@type": "ListItem", "position": 2, "name": "Berita & Informasi", "item": `${d_baseurl}/#news-list` },
            { "@type": "ListItem", "position": 3, "name": d_title, "item": d_url }
          ]
        },
        {
          "@type": "NewsArticle",
          "@id": `${d_url}/#article`,
          "headline": d_title,
          "description": d_desc,
          "image": d_img,
          "datePublished": d_date,
          "author": { "@type": "Organization", "name": "Admin HMI KomKG UMI", "url": d_baseurl },
          "publisher": { 
              "@type": "Organization", 
              "name": "HMI KomKG UMI", 
              "logo": { "@type": "ImageObject", "url": `${d_baseurl}/img/logo.png` } 
          },
          "mainEntityOfPage": { "@type": "WebPage", "@id": `${d_url}/#webpage` },
          "articleSection": d_cat
        }
      ]
    };

    // Eksekusi skrip JSON-LD ke dalam DOM
    const jsonLdScript = document.createElement('script');
    jsonLdScript.type = 'application/ld+json';
    jsonLdScript.textContent = JSON.stringify(jsonLdData);
    document.head.appendChild(jsonLdScript);
});
</script>

<div class="container" style="max-width: 800px; margin-bottom: 50px;">
    
    <!-- Tombol Kembali -->
    <a href="/" style="color:#4ade80; display:inline-flex; align-items:center; gap:5px; margin-bottom:20px; font-weight:600; transition:0.3s;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#4ade80'">
        <i data-lucide="arrow-left" style="width:16px;"></i> Kembali ke Beranda
    </a>

    <!-- ==============================================================
         SUPER BIG UPGRADE: EXPERT SEO MICRODATA (SCHEMA.ORG)
         Mengubah <div> menjadi <article> agar dikenali Google sebagai Artikel
    ============================================================== -->
    <article class="glass" itemscope itemtype="https://schema.org/NewsArticle" style="padding: 40px; border-top: 5px solid #22c55e;">
        
        <!-- Kategori -->
        <span class="badge" itemprop="articleSection" style="margin-bottom: 15px;"><%= safeBerita.category %></span>
        
        <!-- Header Artikel (Judul & Meta) -->
        <header>
            <h1 itemprop="headline" style="font-size: 2.2rem; margin-bottom: 15px; color: #fff; line-height: 1.3;"><%= safeBerita.title %></h1>
            
            <div style="display:flex; align-items:center; gap:15px; color:#9ca3af; font-size:0.9rem; margin-bottom:30px; border-bottom:1px solid rgba(255,255,255,0.1); padding-bottom:20px;">
                <span style="display:flex; align-items:center; gap:5px;">
                    <i data-lucide="calendar" style="width:16px;"></i> 
                    <time itemprop="datePublished" datetime="<%= safeBerita.date %>"><%= safeBerita.date %></time>
                </span>
                <span itemprop="author" itemscope itemtype="https://schema.org/Organization" style="display:flex; align-items:center; gap:5px;">
                    <i data-lucide="user" style="width:16px;"></i> 
                    <span itemprop="name">Admin HMI KomKGUMI</span>
                </span>
            </div>
        </header>

        <!-- Gambar Utama Artikel -->
        <div class="detail-img-wrapper">
            <img itemprop="image" src="<%= safeBerita.image %>" alt="Cover Berita: <%= safeBerita.title %>">
        </div>

        <!-- Isi/Konten Utama Artikel -->
        <div class="rich-text-content" itemprop="articleBody">
            <%- safeBerita.content %>
        </div>

        <!-- Dokumentasi Tambahan -->
        <% if(safeBerita.photos && safeBerita.photos.length > 0) { %>
            <h3 style="margin-bottom: 20px; border-top: 1px solid rgba(255,255,255,0.1); padding-top: 30px;">Dokumentasi Tambahan</h3>
            <div class="grid-2" style="gap: 15px;">
                <% safeBerita.photos.forEach(photo => { %>
                    <div style="width: 100%; height: 200px; overflow: hidden; border-radius: 10px; box-shadow: 0 5px 15px rgba(0,0,0,0.2);">
                        <!-- itemprop="image" membantu Google Images mendeteksi lebih banyak foto -->
                        <img itemprop="image" src="<%= photo.url %>" alt="Dokumentasi Tambahan: <%= safeBerita.title %>" style="width: 100%; height: 100%; object-fit: cover; transition: 0.3s;" onmouseover="this.style.transform='scale(1.05)'" onmouseout="this.style.transform='scale(1)'">
                    </div>
                <% }) %>
            </div>
        <% } %>

    </article>
</div>

<%- include('partials/footer') %>
