<%- include('partials/header') %>

<style>
    /* CSS KHUSUS UNTUK FITUR LIGHTBOX GALERI (FULLSCREEN POP-UP) */
    .lightbox-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.95);
        z-index: 999999999;
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        visibility: hidden;
        transition: opacity 0.3s ease, visibility 0.3s ease;
    }
    
    .lightbox-overlay.active {
        opacity: 1;
        visibility: visible;
    }

    .lightbox-header {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        padding: 20px 30px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        z-index: 10;
        background: linear-gradient(to bottom, rgba(0,0,0,0.8) 0%, transparent 100%);
    }

    .lightbox-counter {
        color: #fff;
        font-size: 1.1rem;
        font-weight: 600;
        font-family: 'Plus Jakarta Sans', sans-serif;
    }

    .lightbox-actions {
        display: flex;
        gap: 20px;
        align-items: center;
    }

    .lightbox-actions a, .lightbox-actions button {
        color: #fff;
        background: none;
        border: none;
        cursor: pointer;
        transition: 0.3s;
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0.7;
    }

    .lightbox-actions a:hover, .lightbox-actions button:hover {
        color: #4ade80;
        opacity: 1;
        transform: scale(1.1);
    }

    .lightbox-nav {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        background: rgba(255, 255, 255, 0.1);
        border: 1px solid rgba(255, 255, 255, 0.2);
        color: white;
        width: 50px;
        height: 50px;
        border-radius: 50%;
        cursor: pointer;
        transition: 0.3s;
        z-index: 10;
        display: flex;
        align-items: center;
        justify-content: center;
        backdrop-filter: blur(5px);
    }

    .lightbox-nav:hover {
        background: rgba(74, 222, 128, 0.8);
        color: #000;
        border-color: #4ade80;
    }

    .lightbox-nav.prev { left: 20px; }
    .lightbox-nav.next { right: 20px; }

    .lightbox-img-wrapper {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 60px; /* Ruang aman agar tidak menabrak nav/header */
    }

    .lightbox-img-wrapper img {
        max-width: 100%;
        max-height: 90vh; /* Memastikan foto HD tampil utuh */
        object-fit: contain;
        box-shadow: 0 10px 40px rgba(0,0,0,0.5);
        user-select: none;
    }

    /* Efek Hover Pada Card Galeri */
    .gallery-clickable {
        cursor: pointer;
        transition: 0.3s;
    }
    .gallery-clickable:hover {
        transform: translateY(-5px);
        box-shadow: 0 15px 30px rgba(34, 197, 94, 0.2);
        border-color: rgba(34, 197, 94, 0.4);
    }
    .gallery-clickable:hover img {
        transform: scale(1.05);
    }

    @media (max-width: 768px) {
        .lightbox-nav { width: 40px; height: 40px; }
        .lightbox-nav.prev { left: 10px; }
        .lightbox-nav.next { right: 10px; }
        .lightbox-img-wrapper { padding: 40px 10px; }
    }
</style>

<!-- Halaman Detail Ini Akan Muncul Ketika Anda Meng-Klik Salah Satu Kegiatan Galeri -->
<div class="container" style="text-align:center; margin-bottom:40px; border-bottom:1px solid rgba(255,255,255,0.1); padding-bottom:30px;">
    <a href="/galeri" style="color:#4ade80; display:inline-flex; align-items:center; gap:5px; margin-bottom:20px; font-weight:600; transition:0.3s;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#4ade80'">
        <i data-lucide="arrow-left" style="width:16px;"></i> Kembali ke Galeri
    </a>
    
    <h2 style="font-size: 2.5rem; margin-bottom: 10px;"><%= album.title %></h2>
    <p class="text-muted" style="display:inline-flex; align-items:center; gap:5px; font-size: 1rem;">
        <i data-lucide="calendar" style="width:16px;"></i> <%= album.date %>
    </p>
</div>

<!-- UPGRADE: Menerapkan kelas gallery-detail-grid dan gallery-detail-item dari main.css -->
<div class="gallery-detail-grid">
    <!-- Foto Cover Utama -->
    <div class="gallery-detail-item gallery-clickable" onclick="openLightbox(0)">
        <img src="<%= album.cover %>" alt="Cover: <%= album.title %>">
    </div>
    
    <!-- Render Foto-Foto Tambahan dari Kegiatan Tersebut -->
    <% if(album.photos && album.photos.length > 0) { %>
        <% album.photos.forEach((photo, index) => { %>
            <div class="gallery-detail-item gallery-clickable" onclick="openLightbox(<%= index + 1 %>)">
                <img src="<%= photo.url %>" alt="Photo <%= index + 1 %>">
            </div>
        <% }) %>
    <% } %>
</div>

<!-- =======================================================
     LIGHTBOX FULLSCREEN OVERLAY
======================================================== -->
<div id="lightboxOverlay" class="lightbox-overlay">
    <div class="lightbox-header">
        <div class="lightbox-counter" id="lightboxCounter">1 / 1</div>
        <div class="lightbox-actions">
            <!-- Tombol Download -->
            <a id="lightboxDownload" href="#" download="HMI_KomKGUMI_Galeri" title="Download Gambar">
                <i data-lucide="download" style="width:24px; height:24px;"></i>
            </a>
            <!-- Tombol Tutup -->
            <button onclick="closeLightbox()" title="Tutup">
                <i data-lucide="x" style="width:28px; height:28px;"></i>
            </button>
        </div>
    </div>
    
    <!-- Tombol Prev -->
    <button class="lightbox-nav prev" onclick="changeLightboxImage(-1)">
        <i data-lucide="chevron-left" style="width:24px; height:24px;"></i>
    </button>
    
    <!-- Gambar Fullscreen (HD) -->
    <div class="lightbox-img-wrapper" id="lightboxImgWrapper">
        <img id="lightboxImg" src="" alt="Fullscreen Galeri">
    </div>

    <!-- Tombol Next -->
    <button class="lightbox-nav next" onclick="changeLightboxImage(1)">
        <i data-lucide="chevron-right" style="width:24px; height:24px;"></i>
    </button>
</div>

<!-- JAVASCRIPT UNTUK LOGIKA LIGHTBOX -->
<script>
    // Kumpulkan seluruh URL gambar (Cover + Photos) dari database EJS
    const lightboxImages = [
        "<%= album.cover %>",
        <% if(album.photos && album.photos.length > 0) { %>
            <% album.photos.forEach(photo => { %>
                "<%= photo.url %>",
            <% }) %>
        <% } %>
    ];

    let currentLightboxIndex = 0;
    const overlay = document.getElementById('lightboxOverlay');
    const imgEl = document.getElementById('lightboxImg');
    const counterEl = document.getElementById('lightboxCounter');
    const downloadEl = document.getElementById('lightboxDownload');

    // Fungsi Buka Lightbox
    function openLightbox(index) {
        currentLightboxIndex = index;
        updateLightbox();
        overlay.classList.add('active');
        document.body.style.overflow = 'hidden'; // Matikan scroll di background
    }

    // Fungsi Tutup Lightbox
    function closeLightbox() {
        overlay.classList.remove('active');
        document.body.style.overflow = 'auto'; // Nyalakan scroll kembali
    }

    // Fungsi Ganti Gambar Kiri/Kanan
    function changeLightboxImage(direction) {
        currentLightboxIndex += direction;
        
        // Looping tak terbatas (jika sudah di ujung, kembali ke awal)
        if (currentLightboxIndex < 0) {
            currentLightboxIndex = lightboxImages.length - 1;
        } else if (currentLightboxIndex >= lightboxImages.length) {
            currentLightboxIndex = 0;
        }
        
        updateLightbox();
    }

    // Fungsi Update Konten UI
    function updateLightbox() {
        const imageUrl = lightboxImages[currentLightboxIndex];
        
        // Animasi transisi halus saat ganti gambar
        imgEl.style.opacity = 0;
        setTimeout(() => {
            imgEl.src = imageUrl;
            imgEl.style.opacity = 1;
        }, 150);

        counterEl.innerText = (currentLightboxIndex + 1) + " / " + lightboxImages.length;
        
        // Atur link download (Menggunakan nama file dinamis)
        downloadEl.href = imageUrl;
        downloadEl.download = "Galeri_HMI_" + "<%= album.title.replace(/[^a-zA-Z0-9]/g, '_') %>" + "_" + (currentLightboxIndex + 1);
    }

    // Tutup saat area hitam di-klik (di luar gambar)
    document.getElementById('lightboxImgWrapper').addEventListener('click', function(e) {
        if (e.target === this) {
            closeLightbox();
        }
    });

    // Navigasi Menggunakan Keyboard (Panah Kiri, Kanan, Escape)
    document.addEventListener('keydown', function(e) {
        if (!overlay.classList.contains('active')) return;
        
        if (e.key === "ArrowLeft") {
            changeLightboxImage(-1);
        } else if (e.key === "ArrowRight") {
            changeLightboxImage(1);
        } else if (e.key === "Escape") {
            closeLightbox();
        }
    });
</script>

<%- include('partials/footer') %>
