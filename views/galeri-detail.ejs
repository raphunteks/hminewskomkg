<%- include('partials/header') %>

<!-- ==============================================================
     SMART GUARD: Mencegah Error 500 jika Album tidak ditemukan
============================================================== -->
<% if (typeof album !== 'undefined' && album) { %>

<div class="container" style="text-align:center; margin-bottom:40px; border-bottom:1px solid rgba(255,255,255,0.1); padding-bottom:30px;">
    <a href="/galeri" style="color:#4ade80; display:inline-flex; align-items:center; gap:5px; margin-bottom:20px; font-weight:600; transition:0.3s;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#4ade80'">
        <i data-lucide="arrow-left" style="width:16px;"></i> Kembali ke Galeri
    </a>
    
    <h2 style="font-size: 2.5rem; margin-bottom: 10px;"><%= album.title || 'Detail Galeri' %></h2>
    <p class="text-muted" style="display:inline-flex; align-items:center; gap:5px; font-size: 1rem;">
        <i data-lucide="calendar" style="width:16px;"></i> <%= album.date || '-' %>
    </p>
</div>

<!-- ==============================================================
     UPGRADE UI: Menggunakan Grid Presisi dari main.css
============================================================== -->
<div class="gallery-detail-grid container">
    <!-- Foto Cover Utama -->
    <% if (album.cover) { %>
    <div class="gallery-detail-item gallery-clickable" onclick="openLightbox(0)">
        <img src="<%= album.cover %>" alt="Cover: <%= album.title %>">
    </div>
    <% } %>
    
    <!-- Render Foto-Foto Tambahan -->
    <% if(album.photos && album.photos.length > 0) { %>
        <% album.photos.forEach((photo, index) => { %>
            <div class="gallery-detail-item gallery-clickable" onclick="openLightbox(<%= album.cover ? index + 1 : index %>)">
                <img src="<%= photo.url %>" alt="Photo <%= index + 1 %>">
            </div>
        <% }) %>
    <% } %>
</div>

<!-- =======================================================
     LIGHTBOX FULLSCREEN OVERLAY (UI di main.css)
======================================================== -->
<div id="lightboxOverlay" class="lightbox-overlay">
    <div class="lightbox-header">
        <div class="lightbox-counter" id="lightboxCounter">1 / 1</div>
        <div class="lightbox-actions">
            <!-- Tombol Download -->
            <a id="lightboxDownload" href="#" download="HMI_KomKGUMI_Galeri" title="Download Gambar">
                <i data-lucide="download" style="width:24px; height:24px;"></i>
            </a>
            <!-- Tombol Tutup -->
            <button onclick="closeLightbox()" title="Tutup">
                <i data-lucide="x" style="width:28px; height:28px;"></i>
            </button>
        </div>
    </div>
    
    <!-- Tombol Prev -->
    <button class="lightbox-nav prev" onclick="changeLightboxImage(-1)">
        <i data-lucide="chevron-left" style="width:24px; height:24px;"></i>
    </button>
    
    <!-- Gambar Fullscreen (HD) -->
    <div class="lightbox-img-wrapper" id="lightboxImgWrapper">
        <img id="lightboxImg" src="" alt="Fullscreen Galeri">
    </div>

    <!-- Tombol Next -->
    <button class="lightbox-nav next" onclick="changeLightboxImage(1)">
        <i data-lucide="chevron-right" style="width:24px; height:24px;"></i>
    </button>
</div>

<!-- ==============================================================
     LOGIKA LIGHTBOX ANTI-CRASH (Bebas Error 500 & Syntax Error)
============================================================== -->
<!-- INJEKSI DATA AMAN: Memisahkan EJS dari Javascript Parser -->
<script id="albumDataJson" type="application/json"><%- typeof album !== 'undefined' && album ? JSON.stringify(album).replace(/</g, '\\u003c') : '{}' %></script>

<script>
    // Memindahkan parsing data ke Client-Side secara aman
    let albumData = {};
    try {
        const rawAlbum = document.getElementById('albumDataJson').textContent;
        // Pengecekan Aman: Pastikan string tidak kosong dan bukan tag EJS mentah
        if (rawAlbum && rawAlbum.trim() !== '' && !rawAlbum.includes('<' + '%')) {
            albumData = JSON.parse(rawAlbum);
        }
    } catch(e) {
        console.warn('Parsing EJS data failed:', e);
    }

    const lightboxImages = [];

    // Filter array gambar secara aman
    if (albumData.cover) {
        lightboxImages.push(albumData.cover);
    }
    if (albumData.photos && albumData.photos.length > 0) {
        albumData.photos.forEach(photo => {
            if (photo && photo.url) lightboxImages.push(photo.url);
        });
    }

    let currentLightboxIndex = 0;
    const overlay = document.getElementById('lightboxOverlay');
    const imgEl = document.getElementById('lightboxImg');
    const counterEl = document.getElementById('lightboxCounter');
    const downloadEl = document.getElementById('lightboxDownload');

    function openLightbox(index) {
        if (lightboxImages.length === 0) return;
        currentLightboxIndex = index;
        updateLightbox();
        overlay.classList.add('active');
        document.body.style.overflow = 'hidden'; 
    }

    function closeLightbox() {
        overlay.classList.remove('active');
        document.body.style.overflow = 'auto'; 
    }

    function changeLightboxImage(direction) {
        if (lightboxImages.length === 0) return;
        currentLightboxIndex += direction;
        
        if (currentLightboxIndex < 0) {
            currentLightboxIndex = lightboxImages.length - 1;
        } else if (currentLightboxIndex >= lightboxImages.length) {
            currentLightboxIndex = 0;
        }
        
        updateLightbox();
    }

    function updateLightbox() {
        if (lightboxImages.length === 0) return;
        const imageUrl = lightboxImages[currentLightboxIndex];
        
        imgEl.style.opacity = 0;
        setTimeout(() => {
            imgEl.src = imageUrl;
            imgEl.style.opacity = 1;
        }, 150);

        counterEl.innerText = (currentLightboxIndex + 1) + " / " + lightboxImages.length;
        
        // Manipulasi nama download dilakukan di frontend
        const safeTitle = (albumData.title || "Galeri").toString().replace(/[^a-zA-Z0-9]/g, '_');
        downloadEl.href = imageUrl;
        downloadEl.download = "Galeri_HMI_" + safeTitle + "_" + (currentLightboxIndex + 1);
    }

    document.getElementById('lightboxImgWrapper').addEventListener('click', function(e) {
        if (e.target === this) {
            closeLightbox();
        }
    });

    document.addEventListener('keydown', function(e) {
        if (!overlay || !overlay.classList.contains('active')) return;
        if (e.key === "ArrowLeft") changeLightboxImage(-1);
        else if (e.key === "ArrowRight") changeLightboxImage(1);
        else if (e.key === "Escape") closeLightbox();
    });
</script>

<!-- ==============================================================
     FALLBACK UI: Jika URL Galeri Salah / Dihapus
============================================================== -->
<% } else { %>
<div class="container" style="text-align:center; padding: 100px 20px;">
    <div style="background: rgba(255,255,255,0.05); padding: 50px; border-radius: 20px; border: 1px solid rgba(255,255,255,0.1); max-width: 600px; margin: 0 auto;">
        <i data-lucide="alert-circle" style="width:64px; height:64px; color:#ef4444; margin-bottom:20px;"></i>
        <h2 style="margin-bottom: 10px;">Galeri Tidak Ditemukan</h2>
        <p class="text-muted" style="margin-bottom:30px;">Album galeri yang Anda cari mungkin telah dihapus, rusak, atau tidak tersedia.</p>
        <a href="/galeri" class="btn btn-primary">Kembali ke Daftar Galeri</a>
    </div>
</div>
<% } %>

<%- include('partials/footer') %>
