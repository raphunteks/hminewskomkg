<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Link - <%= bioPage.bio %></title>
    <link rel="icon" type="image/png" href="<%= bioPage.profileImage %>">
    <script src="https://unpkg.com/lucide@latest"></script>
    <link rel="stylesheet" href="/css/bio.css">
</head>
<!-- LOGIKA BACKGROUND: Membedakan tipe Image atau Gradient secara otomatis -->
<body style="<% if(bioPage.bgType === 'image') { %> background-image: url('<%= bioPage.bgValue %>'); <% } else { %> background: <%= bioPage.bgValue %>; <% } %>">

    <div class="bio-container">
        <!-- PROFIL -->
        <img src="<%= bioPage.profileImage %>" alt="Profile" class="profile-img">
        
        <!-- TITLE MENGGUNAKAN RICH TEXT (DARI QUILL) -->
        <div class="bio-title"><%- bioPage.title %></div>
        
        <p class="bio-desc"><%= bioPage.bio %></p>

        <!-- TOMBOL LINK BERDASARKAN ID HALAMAN INI -->
        <div class="link-list">
            <% bioLinks.forEach(link => { %>
                <a href="<%= link.url %>" class="link-btn" target="_blank" rel="noopener noreferrer">
                    <div class="link-icon">
                        <% if(link.icon) { %>
                            <img src="<%= link.icon %>" alt="Icon">
                        <% } else { %>
                            <i data-lucide="link" style="width: 20px; color: #fff;"></i>
                        <% } %>
                    </div>
                    <!-- TEXT MENGGUNAKAN RICH TEXT (DARI QUILL) -->
                    <span class="link-text"><%- link.title %></span>
                </a>
            <% }) %>
        </div>

        <!-- WATERMARK MENUJU BERANDA -->
        <a href="/" class="watermark">
            <i data-lucide="home" style="width:16px;"></i> 
            Powered by HMI KomKG-UMI
        </a>
    </div>

    <script>
        lucide.createIcons();
    </script>
</body>
</html>
