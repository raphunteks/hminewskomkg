                        <% if(person.ig || person.fb || person.twitter || person.linkedin || person.tiktok) { %>
                        <div class="team-socials">
                            <% if(person.ig) { %><a href="<%= person.ig %>" target="_blank" class="team-social-btn kohati-social-btn" aria-label="Instagram"><svg viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg></a><% } %>
                            <% if(person.fb) { %><a href="<%= person.fb %>" target="_blank" class="team-social-btn kohati-social-btn" aria-label="Facebook"><svg viewBox="0 0 24 24"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg></a><% } %>
                            <% if(person.tiktok) { %><a href="<%= person.tiktok %>" target="_blank" class="team-social-btn kohati-social-btn" aria-label="TikTok"><svg viewBox="0 0 24 24"><path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"></path></svg></a><% } %>
                            <% if(person.twitter) { %><a href="<%= person.twitter %>" target="_blank" class="team-social-btn kohati-social-btn" aria-label="Twitter/X"><svg viewBox="0 0 24 24"><path d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"></path></svg></a><% } %>
                            <% if(person.linkedin) { %><a href="<%= person.linkedin %>" target="_blank" class="team-social-btn kohati-social-btn" aria-label="LinkedIn"><svg viewBox="0 0 24 24"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg></a><% } %>
                        </div>
                        <% } %>
                    </div>
                    <% }) %>
                </div>
                
                <div style="margin-top: 50px; padding-top: 40px; border-top: 1px solid rgba(244,114,182,0.2);">
                    <h3 style="margin-bottom:30px; text-align:center; color:#f472b6;">Bidang-Bidang Kohati</h3>
                    <div style="display:flex; flex-direction:column; gap:40px;">
                        <% kohatiBidang.forEach(b => { %>
                            <div>
                                <h4 style="color:#f472b6; border-bottom:1px dashed rgba(244,114,182,0.3); padding-bottom:10px; margin-bottom:20px; text-align:center;"><%= b.name %></h4>
                                <% if(b.members && b.members.length > 0) { %>
                                    <div class="team-scroll-wrapper">
                                        <% b.members.forEach(m => { %>
                                            <div class="glass team-card" style="padding:15px; border-color: rgba(244,114,182,0.2);" itemprop="member" itemscope itemtype="https://schema.org/Person">
                                                <div class="team-img" style="width:80px; height:80px; border-color: rgba(244,114,182,0.5);">
                                                    <img itemprop="image" src="<%= m.image %>" alt="<%= m.name %>">
                                                </div>
                                                <h4 class="team-name" itemprop="name" style="font-size:0.95rem;"><%= m.name %></h4>
                                                <% if(m.role) { %>
                                                    <p itemprop="jobTitle" style="color:#f472b6; font-size:0.8rem; font-weight:bold; margin-top:2px;"><%= m.role %></p>
                                                <% } %>
                                                
                                                <!-- ANGGOTA BIDANG KOHATI SOCIAL MEDIA -->
                                                <% if(m.ig || m.fb || m.twitter || m.linkedin || m.tiktok) { %>
                                                <div class="team-socials" style="margin-top:10px;">
                                                    <% if(m.ig) { %><a href="<%= m.ig %>" target="_blank" class="team-social-btn kohati-social-btn" style="width:28px; height:28px;"><svg viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg></a><% } %>
                                                    <% if(m.fb) { %><a href="<%= m.fb %>" target="_blank" class="team-social-btn kohati-social-btn" style="width:28px; height:28px;"><svg viewBox="0 0 24 24"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg></a><% } %>
                                                    <% if(m.tiktok) { %><a href="<%= m.tiktok %>" target="_blank" class="team-social-btn kohati-social-btn" style="width:28px; height:28px;"><svg viewBox="0 0 24 24"><path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"></path></svg></a><% } %>
                                                    <% if(m.twitter) { %><a href="<%= m.twitter %>" target="_blank" class="team-social-btn kohati-social-btn" style="width:28px; height:28px;"><svg viewBox="0 0 24 24"><path d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"></path></svg></a><% } %>
                                                    <% if(m.linkedin) { %><a href="<%= m.linkedin %>" target="_blank" class="team-social-btn kohati-social-btn" style="width:28px; height:28px;"><svg viewBox="0 0 24 24"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg></a><% } %>
                                                </div>
                                                <% } %>
                                            </div>
                                        <% }) %>
                                    </div>
                                <% } else { %>
                                    <p style="text-align:center; color:#9ca3af; font-size:0.9rem;">Belum ada anggota.</p>
                                <% } %>
                            </div>
                        <% }) %>
                    </div>
                </div>
            </div>
        </div>
    </section>
    <% } %>

</article>

<script>
    function openTab(tabId) {
        document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));
        document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
        document.getElementById(tabId).classList.add('active');
        event.currentTarget.classList.add('active');
    }
    
    // Lucide hanya bertugas memuat ikon lain (selain sosmed profil yang sudah dijamin oleh inline SVG)
    document.addEventListener('DOMContentLoaded', () => {
        if(typeof lucide !== 'undefined') lucide.createIcons();
    });
</script>

<%- include('partials/footer') %>
