<% 
    // ==============================================================
    // FIX ERROR 500 & SEO BREADCRUMB: 
    // Injeksi variabel SEO secara eksplisit sebelum memanggil header
    // ==============================================================
    let pageTitle = "Tentang Kami";
    
    // BILINGUAL SEO UPGRADE: Menggabungkan ID & EN untuk menjaring lebih banyak kata kunci
    let pageDescription = "Profil, Visi Misi, dan Struktur Kepengurusan HMI Komisariat Kedokteran Gigi UMI. About us, vision, mission, and organizational structure of HMI Dentistry UMI.";
    let orgName = typeof siteSettings !== 'undefined' ? (siteSettings.headerTitle + ' ' + (siteSettings.headerHighlight || '')) : 'HMI KomKG UMI';
    
    // ==============================================================
    // SUPER BIG UPGRADE: DYNAMIC SEO SCHEMA GENERATOR (ENTERPRISE LEVEL)
    // Men-generate Schema SEO "Person" secara otomatis setiap ada data pengurus baru
    // ==============================================================
    let personsSchema = [];
    let baseUrl = "https://hmikomkgumi.com"; // Bisa disesuaikan dengan domain asli Anda
    
    // Fungsi Auto-Builder Schema
    function addMemberToSchema(member, department) {
        if(!member) return;
        let igLink = member.ig || baseUrl + "/tentang";
        let imgUrl = member.image ? (member.image.startsWith('http') ? member.image : baseUrl + member.image) : baseUrl + "/img/default.png";
        
        personsSchema.push({
            "@type": "Person",
            "name": member.name,
            "jobTitle": member.role || department,
            "worksFor": { "@id": baseUrl + "/#organization" },
            "image": imgUrl,
            "sameAs": [igLink]
        });
    }

    // 1. Auto-Generate SEO untuk Pengurus Harian
    if(typeof pengurus !== 'undefined' && pengurus.length > 0) {
        pengurus.forEach(p => addMemberToSchema(p, "Pengurus Harian (Executive Board)"));
    }
    
    // 2. Auto-Generate SEO untuk Anggota Bidang
    if(typeof bidang !== 'undefined' && bidang.length > 0) {
        bidang.forEach(b => {
            if(b.members) b.members.forEach(m => addMemberToSchema(m, "Bidang " + b.name));
        });
    }
    
    // 3. Auto-Generate SEO untuk KOHATI
    if (typeof siteSettings !== 'undefined' && String(siteSettings.kohatiActive) === 'true') {
        if(typeof kohatiPengurus !== 'undefined') {
            kohatiPengurus.forEach(p => addMemberToSchema(p, "Pengurus Harian KOHATI (Women's Division Board)"));
        }
        if(typeof kohatiBidang !== 'undefined') {
            kohatiBidang.forEach(b => {
                if(b.members) b.members.forEach(m => addMemberToSchema(m, "KOHATI - " + b.name));
            });
        }
    }
%>
<%- include('partials/header', { pageTitle: pageTitle, pageDescription: pageDescription }) %>

<!-- ==============================================================
     ADVANCED JSON-LD SCHEMA.ORG (@graph) - SERVER SIDE RENDERED
     Google akan memanen ribuan meta data ini dalam hitungan milidetik.
============================================================== -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "AboutPage",
      "@id": "<%= baseUrl %>/tentang/#webpage",
      "url": "<%= baseUrl %>/tentang",
      "name": "<%= pageTitle %> | <%= orgName %>",
      "description": "<%= pageDescription %>",
      "inLanguage": ["id-ID", "en-US"],
      "publisher": { "@id": "<%= baseUrl %>/#organization" }
    },
    {
      "@type": "Organization",
      "@id": "<%= baseUrl %>/#organization",
      "name": "<%= orgName %>",
      "alternateName": "Islamic Association of University Students - Dentistry Commissariat UMI",
      "url": "<%= baseUrl %>/",
      "description": "Organisasi mahasiswa Islam tingkat fakultas kedokteran gigi. Islamic student organization at the faculty of dentistry level.",
      "logo": {
        "@type": "ImageObject",
        "url": "<%= baseUrl %>/img/bemfkgumi.png"
      }
    },
    {
      "@type": "BreadcrumbList",
      "@id": "<%= baseUrl %>/tentang/#breadcrumb",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Beranda (Home)",
          "item": "<%= baseUrl %>/"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "Tentang Kami (About Us)",
          "item": "<%= baseUrl %>/tentang"
        }
      ]
    }
    <% if (personsSchema.length > 0) { %>,
    <%- JSON.stringify(personsSchema).slice(1, -1) %>
    <% } %>
  ]
}
</script>

<!-- ==============================================================
     EXPERT SEO MICRODATA (SCHEMA.ORG) & BILINGUAL FALLBACK
============================================================== -->
<article itemscope itemtype="https://schema.org/Organization">
    
    <!-- Meta tersembunyi bilingual untuk bot SEO (Invisible to Users) -->
    <div style="display: none;" aria-hidden="true">
        <h2>About Us - <%= orgName %></h2>
        <p>Welcome to the official profile of HMI (Himpunan Mahasiswa Islam) Dentistry Commissariat UMI. Discover our vision, mission, organizational structure, and executive board members.</p>
    </div>

    <!-- Meta tersembunyi agar Google langsung mengenali nama organisasi -->
    <meta itemprop="name" content="<%= orgName %>">

    <nav class="tab-nav" aria-label="Navigasi Profil Organisasi">
        <button class="tab-btn active" onclick="openTab('tab-profil')"><i data-lucide="user"></i> Profil</button>
        <button class="tab-btn" onclick="openTab('tab-visimisi')"><i data-lucide="target"></i> Visi & Misi</button>
        <button class="tab-btn" onclick="openTab('tab-struktur')"><i data-lucide="users"></i> Kepengurusan</button>
        <% if (String(siteSettings.kohatiActive) === 'true') { %>
            <button class="tab-btn" onclick="openTab('tab-kohati')" style="color: #f472b6;"><i data-lucide="heart"></i> Kohati</button>
        <% } %>
    </nav>

    <!-- Mengubah div menjadi <section> Semantic -->
    <section id="tab-profil" class="tab-content active">
        <div class="vm-card" style="max-width: 900px; margin: 0 auto 40px; border-left: none; padding: 40px;">
            <h2 style="color:#4ade80; margin-bottom:15px; font-weight:bold; font-size:1.8rem;">Profil</h2>
            
            <!-- itemprop="description" mendikte Google bahwa ini adalah profil resmi -->
            <div class="rich-text-content" itemprop="description" style="margin-bottom: 40px; font-size:1.05rem; line-height:1.7; white-space: pre-line; color: #e5e7eb;">
                <%- siteSettings.profilText || '' %>
            </div>

            <h2 style="color:#4ade80; margin-bottom:15px; font-weight:bold; font-size:1.8rem;">Welcome</h2>
            <div class="rich-text-content" style="font-size:1.05rem; line-height:1.7; white-space: pre-line; color: #e5e7eb;">
                <%- siteSettings.welcomeText || '' %>
            </div>
        </div>
        
        <% if (siteSettings.bookletPdf || siteSettings.mapsEmbed) { %>
            <div class="glass" style="padding: 40px; max-width: 900px; margin: 0 auto 40px;">
                <div style="display:flex; flex-direction:column; gap: 40px;">
                    
                    <% if (siteSettings.bookletPdf && siteSettings.bookletPdf.length > 5) { %>
                    <div style="width: 100%;">
                        <h3 style="margin-bottom: 20px; font-size:1.5rem; text-align:center; color:#4ade80;">Buku Pedoman / Profil</h3>
                        
                        <!-- UPGRADE 3: PURE CSS 3D PDF VIEWER -->
                        <div class="css3d-pdf-wrapper">
                            <div class="css3d-pdf-frame">
                                <!-- UPGRADE PDF: Menambahkan parameter view=FitH untuk memaksa tampilan vertikal -->
                                <iframe 
                                    src="<%= siteSettings.bookletPdf %>#toolbar=0&navpanes=0&view=FitH" 
                                    type="application/pdf" 
                                    title="Buku Pedoman / Profil Komisariat"
                                    class="native-pdf-viewer"
                                    scrolling="yes"
                                    style="width: 100%; height: 100%; border: none;">
                                </iframe>
                            </div>
                        </div>
                        
                        <p class="text-muted" style="text-align:center; margin-top:15px; font-size:0.9rem;">
                            <i data-lucide="mouse-pointer-click" style="width:16px; display:inline; margin-bottom:-2px;"></i> Scroll ke bawah untuk membaca atau buka dalam mode layar penuh (tergantung browser).
                        </p>
                    </div>
                    <% } %>
                    
                    <% if (siteSettings.mapsEmbed) { %>
                    <!-- itemprop="location" mendikte Google bahwa ini adalah lokasi fisik sekretariat -->
                    <div style="width: 100%;" itemprop="location" itemscope itemtype="https://schema.org/Place">
                        <h3 style="margin-bottom: 15px; font-size:1.5rem; text-align:center; color:#4ade80;">Lokasi Sekretariat</h3>
                        <div class="ratio ratio-16x9 glass" style="border-radius: 12px; border: 1px solid rgba(255,255,255,0.1); box-shadow: 0 10px 30px rgba(0,0,0,0.2); padding: 5px;">
                            
                            <!-- UPGRADE SOLUSI MAPS: Penambahan class "map-responsive-container" -->
                            <div class="map-responsive-container" style="border-radius: 8px; overflow: hidden; width: 100%; height: 100%; position: relative;">
                                <%- siteSettings.mapsEmbed %>
                            </div>
                            
                            <!-- Inline CSS Eksklusif untuk memaksa Google Maps iframe menjadi 100% presisi -->
                            <style>
                                .map-responsive-container iframe {
                                    position: absolute !important;
                                    top: 0 !important;
                                    left: 0 !important;
                                    width: 100% !important;
                                    height: 100% !important;
                                    border: 0 !important;
                                }
                            </style>

                        </div>
                    </div>
                    <% } %>
                    
                </div>
            </div>
        <% } %>
        
        <%- include('partials/instagram-feed') %>

    </section>

    <section id="tab-visimisi" class="tab-content">
        <div style="text-align: center; margin-bottom: 30px;">
            <h2 style="font-size:2rem; margin-bottom:10px;">Visi dan Misi</h2>
            <p class="text-muted" style="font-size:1.05rem;">Panduan bagi HMI Komisariat Kedokteran Gigi UMI untuk merencanakan kegiatan organisasi.</p>
        </div>
        
        <div style="max-width: 900px; margin: 0 auto; margin-bottom: 50px;">
            <div class="vm-card">
                <div class="vm-icon">🚀</div>
                <h3 class="vm-title">Visi</h3>
                <div class="rich-text-content" style="white-space: pre-line; color: #e5e7eb;"><%- siteSettings.visiText || '' %></div>
            </div>

            <div class="vm-card">
                <div class="vm-icon">📈</div>
                <h3 class="vm-title">Misi</h3>
                <div class="rich-text-content" style="white-space: pre-line; color: #e5e7eb;"><%- siteSettings.misiText || '' %></div>
            </div>
        </div>
    </section>

    <section id="tab-struktur" class="tab-content">
        <div class="glass" style="padding: 40px; text-align: center;">
            <h2>Struktur Kepengurusan</h2>
            <p class="text-muted" style="margin-bottom: 40px;">Pengurus Harian</p>
            
            <div class="team-scroll-wrapper">
                <% pengurus.forEach(person => { %>
                <!-- EXPERT SEO: Mendeklarasikan Anggota Pengurus (Person Schema) -->
                <div class="glass team-card" itemprop="member" itemscope itemtype="https://schema.org/Person">
                    <div class="team-img">
                        <img itemprop="image" src="<%= person.image %>" alt="<%= person.name %>">
                    </div>
                    <h4 class="team-name" itemprop="name"><%= person.name %></h4>
                    <p class="team-role" itemprop="jobTitle"><%= person.role %></p>
                    
                    <!-- ==============================================================
                         SUPER BIG UPGRADE: PURE INLINE SVG SOCIAL MEDIA (HMI UMUM)
                         Anti-Error/Bundaran Putih. Langsung muncul secara instan!
                    ============================================================== -->
                    <% if(person.ig || person.fb || person.twitter || person.linkedin || person.tiktok) { %>
                    <div class="team-socials">
                        <% if(person.ig) { %><a href="<%= person.ig %>" target="_blank" class="team-social-btn" aria-label="Instagram"><svg viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg></a><% } %>
                        <% if(person.fb) { %><a href="<%= person.fb %>" target="_blank" class="team-social-btn" aria-label="Facebook"><svg viewBox="0 0 24 24"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg></a><% } %>
                        <% if(person.tiktok) { %><a href="<%= person.tiktok %>" target="_blank" class="team-social-btn" aria-label="TikTok"><svg viewBox="0 0 24 24"><path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"></path></svg></a><% } %>
                        <% if(person.twitter) { %><a href="<%= person.twitter %>" target="_blank" class="team-social-btn" aria-label="Twitter/X"><svg viewBox="0 0 24 24"><path d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"></path></svg></a><% } %>
                        <% if(person.linkedin) { %><a href="<%= person.linkedin %>" target="_blank" class="team-social-btn" aria-label="LinkedIn"><svg viewBox="0 0 24 24"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg></a><% } %>
                    </div>
                    <% } %>
                </div>
                <% }) %>
            </div>
            
            <div style="margin-top: 50px; padding-top: 40px; border-top: 1px solid rgba(255,255,255,0.1);">
                <h3 style="margin-bottom:30px; text-align:center;">Bidang-Bidang</h3>
                <div style="display:flex; flex-direction:column; gap:40px;">
                    <% bidang.forEach(b => { %>
                        <div>
                            <h4 style="color:#4ade80; border-bottom:1px dashed rgba(255,255,255,0.2); padding-bottom:10px; margin-bottom:20px; text-align:center;"><%= b.name %></h4>
                            <% if(b.members && b.members.length > 0) { %>
                                <div class="team-scroll-wrapper">
                                    <% b.members.forEach(m => { %>
                                        <div class="glass team-card" style="padding:15px;" itemprop="member" itemscope itemtype="https://schema.org/Person">
                                            <div class="team-img" style="width:80px; height:80px;">
                                                <img itemprop="image" src="<%= m.image %>" alt="<%= m.name %>">
                                            </div>
                                            <h4 class="team-name" itemprop="name" style="font-size:0.95rem;"><%= m.name %></h4>
                                            <% if(m.role) { %>
                                                <p itemprop="jobTitle" style="color:#4ade80; font-size:0.8rem; font-weight:bold; margin-top:2px;"><%= m.role %></p>
                                            <% } %>
                                            
                                            <!-- ANGGOTA BIDANG SOSIAL MEDIA INLINE SVG -->
                                            <% if(m.ig || m.fb || m.twitter || m.linkedin || m.tiktok) { %>
                                            <div class="team-socials" style="margin-top:10px;">
                                                <% if(m.ig) { %><a href="<%= m.ig %>" target="_blank" class="team-social-btn" style="width:28px; height:28px;"><svg viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg></a><% } %>
                                                <% if(m.fb) { %><a href="<%= m.fb %>" target="_blank" class="team-social-btn" style="width:28px; height:28px;"><svg viewBox="0 0 24 24"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg></a><% } %>
                                                <% if(m.tiktok) { %><a href="<%= m.tiktok %>" target="_blank" class="team-social-btn" style="width:28px; height:28px;"><svg viewBox="0 0 24 24"><path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"></path></svg></a><% } %>
                                                <% if(m.twitter) { %><a href="<%= m.twitter %>" target="_blank" class="team-social-btn" style="width:28px; height:28px;"><svg viewBox="0 0 24 24"><path d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"></path></svg></a><% } %>
                                                <% if(m.linkedin) { %><a href="<%= m.linkedin %>" target="_blank" class="team-social-btn" style="width:28px; height:28px;"><svg viewBox="0 0 24 24"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg></a><% } %>
                                            </div>
                                            <% } %>
                                        </div>
                                    <% }) %>
                                </div>
                            <% } else { %>
                                <p style="text-align:center; color:#9ca3af; font-size:0.9rem;">Belum ada anggota.</p>
                            <% } %>
                        </div>
                    <% }) %>
                </div>
            </div>
        </div>
    </section>

    <% if (String(siteSettings.kohatiActive) === 'true') { %>
    <section id="tab-kohati" class="tab-content">
        <div style="margin-bottom: 40px;">
            <div class="vm-card" style="max-width: 900px; margin: 0 auto 50px; border-left: none; background: rgba(244,114,182,0.05); border: 1px solid rgba(244,114,182,0.2); padding: 40px;">
