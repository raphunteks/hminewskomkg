<%- include('partials/header') %>

<!-- Navigasi Tabs -->
<div class="tab-nav">
    <button class="tab-btn active" onclick="openTab('tab-profil')"><i data-lucide="user" style="width:16px; display:inline; margin-right:5px;"></i> Profil</button>
    <button class="tab-btn" onclick="openTab('tab-visimisi')"><i data-lucide="target" style="width:16px; display:inline; margin-right:5px;"></i> Visi & Misi</button>
    <button class="tab-btn" onclick="openTab('tab-struktur')"><i data-lucide="users" style="width:16px; display:inline; margin-right:5px;"></i> Struktur Kepengurusan</button>
    <button class="tab-btn" onclick="openTab('tab-kohati')" style="color: #f472b6;"><i data-lucide="heart" style="width:16px; display:inline; margin-right:5px;"></i> Kohati</button>
</div>

<!-- KONTEN TABS -->

<!-- 1. TAB PROFIL -->
<div id="tab-profil" class="tab-content active">
    <div class="glass" style="padding: 40px; margin-bottom: 40px;">
        <h2 style="border-bottom: 1px solid rgba(34,197,94,0.3); padding-bottom:10px; margin-bottom:20px; display:inline-block;" class="text-gradient">Profil</h2>
        <p style="color:#d1d5db; line-height:1.7; margin-bottom:30px; font-size:1.1rem;">
            Halaman profil ini berisi deskripsi singkat mengenai sejarah, visi, dan misi Himpunan Mahasiswa Islam Komisariat Kedokteran Gigi Universitas Muslim Indonesia, serta program kerja dan kegiatan yang telah dan akan dilaksanakan oleh organisasi tersebut.
        </p>
        
        <h3 style="margin-bottom:15px; font-size:1.5rem;">Welcome</h3>
        <p style="color:#d1d5db; line-height:1.7;">
            Selamat datang di website resmi Himpunan Mahasiswa Islam Komisariat Kedokteran Gigi Universitas Muslim Indonesia. Kami adalah sebuah organisasi mahasiswa yang terdiri dari para mahasiswa kedokteran gigi yang memiliki komitmen untuk meningkatkan kualitas diri dan mengembangkan potensi dalam bidang akademik, keislaman, sosial, dan kemanusiaan. Di sini, Anda dapat menemukan informasi terbaru tentang kegiatan kami, program kerja, dan berbagai kegiatan yang telah kami lakukan. Selamat menjelajahi situs web kami!
        </p>
    </div>
</div>

<!-- 2. TAB VISI & MISI -->
<div id="tab-visimisi" class="tab-content">
    <div style="text-align: center; margin-bottom: 30px;">
        <h2>Visi dan Misi</h2>
        <p class="text-muted">Panduan bagi HMI Komisariat Kedokteran Gigi UMI untuk merencanakan kegiatan organisasi.</p>
    </div>
    <div class="grid-2" style="margin-bottom: 50px;">
        <div class="glass vision-mission-card v-left">
            <div class="icon-box">🚀</div>
            <h3 class="text-primary">Visi</h3>
            <p style="color:#d1d5db; line-height:1.6;">Terbinanya insan akademis, pencipta, pengabdi yang bernafaskan Islam dan bertanggung jawab atas terwujudnya masyarakat adil makmur yang diridhoi Allah SWT, khususnya dalam mewujudkan dokter gigi muslim yang profesional.</p>
        </div>
        <div class="glass vision-mission-card m-left">
            <div class="icon-box">📈</div>
            <h3 style="color:#34d399;">Misi</h3>
            <ul class="list-custom">
                <li><span class="list-num">1.</span> Reaktualisasi nilai-nilai ke-Islaman dalam pengembangan kapasitas diri kader.</li>
                <li><span class="list-num">2.</span> Optimalisasi kesadaran kader terkait isu kesehatan gigi dan masyarakat.</li>
                <li><span class="list-num">3.</span> Memelihara dan mengedepankan nilai-nilai kekeluargaan dalam aktivitas organisasi.</li>
            </ul>
        </div>
    </div>
</div>

<!-- 3. TAB STRUKTUR KEPENGURUSAN -->
<div id="tab-struktur" class="tab-content">
    <div class="glass" style="padding: 40px; text-align: center;">
        <h2>Struktur Kepengurusan</h2>
        <p class="text-muted" style="margin-bottom: 40px;">Periode 2025-2026</p>
        
        <div class="grid-4">
            <% pengurus.forEach(person => { %>
            <div class="glass team-card">
                <div class="team-img"><img src="<%= person.image %>" alt="<%= person.name %>"></div>
                <h4 class="team-name"><%= person.name %></h4>
                <p class="team-role"><%= person.role %></p>
            </div>
            <% }) %>
        </div>
        
        <div style="margin-top: 40px; padding-top: 30px; border-top: 1px solid rgba(255,255,255,0.1);">
            <h3 style="margin-bottom:20px;">Bidang-Bidang</h3>
            <div style="display:flex; justify-content:center; flex-wrap:wrap; gap:15px;">
                <% bidang.forEach(b => { %>
                    <span style="padding:10px 20px; background:rgba(0,0,0,0.3); border:1px solid rgba(255,255,255,0.1); border-radius:10px; <%= b.toLowerCase().includes('kohati') ? 'color:#f472b6; border-color:rgba(244,114,182,0.3);' : '' %>"><%= b %></span>
                <% }) %>
            </div>
        </div>
    </div>
</div>

<!-- 4. TAB KOHATI -->
<div id="tab-kohati" class="tab-content">
    <div class="glass" style="padding: 40px; border-left: 5px solid #f472b6;">
        <!-- Profil Kohati -->
        <h2 style="color: #f472b6; margin-bottom:15px;"><i data-lucide="heart" style="display:inline; margin-right:5px;"></i> Profil KOHATI</h2>
        <p style="color:#d1d5db; line-height:1.7; margin-bottom:30px;">
            Korps HMI-Wati (KOHATI) adalah badan khusus HMI yang bertugas membina, mengembangkan, dan meningkatkan potensi HMI-Wati dalam wacana dan dinamika gerakan perempuan. KOHATI Komisariat Kedokteran Gigi UMI mewadahi mahasiswi muslimah untuk mencetak generasi insan cita.
        </p>

        <!-- Visi Misi Kohati -->
        <h3 style="margin-bottom:15px; font-size:1.3rem;">Visi & Misi Kohati</h3>
        <div style="background:rgba(0,0,0,0.2); padding:20px; border-radius:15px; border:1px solid rgba(244,114,182,0.2); margin-bottom:30px;">
            <strong style="color:#f472b6; display:block; margin-bottom:5px;">Visi:</strong>
            <p style="color:#d1d5db; margin-bottom:15px;">Terbinanya muslimah berkualitas insan cita.</p>
            <strong style="color:#f472b6; display:block; margin-bottom:5px;">Misi:</strong>
            <ul style="color:#d1d5db; padding-left:20px;">
                <li style="margin-bottom:5px;">1. Membina HMI-Wati untuk menjadi insan akademis yang profesional.</li>
                <li style="margin-bottom:5px;">2. Meningkatkan peran serta HMI-Wati dalam memajukan perempuan di bidang kesehatan.</li>
            </ul>
        </div>

        <!-- Struktur Kohati -->
        <h3 style="margin-bottom:20px; font-size:1.3rem;">Struktur Kepengurusan KOHATI</h3>
        <div class="grid-3">
            <div class="glass team-card" style="border-color: rgba(244,114,182,0.2);">
                <div class="team-img" style="border-color: rgba(244,114,182,0.5);"><img src="[https://images.unsplash.com/photo-1438761681033-6461ffad8d80?w=200&q=80](https://images.unsplash.com/photo-1438761681033-6461ffad8d80?w=200&q=80)" alt="Ketua Kohati"></div>
                <h4 class="team-name">Andi Nurul Hidayah</h4>
                <p style="color:#f472b6; font-size: 0.85rem; font-weight: bold;">Ketua Umum KOHATI</p>
            </div>
             <div class="glass team-card" style="border-color: rgba(244,114,182,0.2);">
                <div class="team-img" style="border-color: rgba(244,114,182,0.5);"><img src="[https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=200&q=80](https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=200&q=80)" alt="Sekretaris Kohati"></div>
                <h4 class="team-name">Siti Fatimah</h4>
                <p style="color:#f472b6; font-size: 0.85rem; font-weight: bold;">Sekretaris KOHATI</p>
            </div>
        </div>
    </div>
</div>

<script>
    function openTab(tabId) {
        document.querySelectorAll('.tab-content').forEach(tab => tab.classList.remove('active'));
        document.querySelectorAll('.tab-btn').forEach(btn => btn.classList.remove('active'));
        
        document.getElementById(tabId).classList.add('active');
        event.currentTarget.classList.add('active');
    }
</script>

<%- include('partials/footer') %>
