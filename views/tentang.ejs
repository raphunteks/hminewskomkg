<%- include('partials/header') %>

<div class="tab-nav">
    <button class="tab-btn active" onclick="openTab('tab-profil')"><i data-lucide="user"></i> Profil</button>
    <button class="tab-btn" onclick="openTab('tab-visimisi')"><i data-lucide="target"></i> Visi & Misi</button>
    <button class="tab-btn" onclick="openTab('tab-struktur')"><i data-lucide="users"></i> Kepengurusan</button>
    <!-- Toggle KOHATI Fixed dengan Pengecekan Aman (Strict String) -->
    <% if (String(siteSettings.kohatiActive) === 'true') { %>
        <button class="tab-btn" onclick="openTab('tab-kohati')" style="color: #f472b6;"><i data-lucide="heart"></i> Kohati</button>
    <% } %>
</div>

<div id="tab-profil" class="tab-content active">
    <div class="glass" style="padding: 40px; margin-bottom: 40px;">
        <h2 style="color:#4ade80; margin-bottom:15px; font-weight:bold; font-size:1.8rem;">Profil</h2>
        <div class="rich-text-content" style="margin-bottom: 40px; font-size:1.05rem; line-height:1.7;">
            <%- siteSettings.profilText || '' %>
        </div>

        <h2 style="color:#4ade80; margin-bottom:15px; font-weight:bold; font-size:1.8rem;">Welcome</h2>
        <div class="rich-text-content" style="font-size:1.05rem; line-height:1.7;">
            <%- siteSettings.welcomeText || '' %>
        </div>
        
        <!-- MODULE BOOKLET PDF & MAPS -->
        <% if (siteSettings.bookletPdf || siteSettings.mapsEmbed) { %>
            <div class="grid-2" style="margin-top: 50px; gap: 30px;">
                
                <!-- UPGRADE: DEARFLIP 3D FLIPBOOK UNTUK BUKU PEDOMAN (SUPER FIXED) -->
                <% if (siteSettings.bookletPdf) { %>
                <div style="grid-column: 1 / -1; margin-bottom: 20px;">
                    <h3 style="margin-bottom: 20px; font-size:1.5rem; text-align:center; color:#4ade80;">Buku Pedoman / Profil</h3>
                    
                    <!-- Kebutuhan Library DearFlip (CDN JSDelivr Lebih Stabil) -->
                    <link href="https://cdn.jsdelivr.net/npm/dflip@2.2.23/css/dflip.min.css" rel="stylesheet">
                    <link href="https://cdn.jsdelivr.net/npm/dflip@2.2.23/css/themify-icons.min.css" rel="stylesheet">
                    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
                    
                    <!-- KUNCI FIX 1: Menentukan lokasi library dFlip -->
                    <script>
                        var dFlipLocation = "https://cdn.jsdelivr.net/npm/dflip@2.2.23/";
                    </script>
                    <script src="https://cdn.jsdelivr.net/npm/dflip@2.2.23/js/dflip.min.js"></script>
                    
                    <!-- Kontainer Flipbook -->
                    <div class="flipbook-container" style="width: 100%; height: 80vh; min-height: 500px; border-radius: 12px; overflow: hidden; border: 1px solid rgba(74,222,128,0.3); box-shadow: 0 10px 30px rgba(0,0,0,0.5);">
                        <!-- Elemen kosong untuk diinisialisasi manual via Javascript -->
                        <div id="df_manual_book" style="height: 100%; width: 100%;"></div>
                    </div>
                    
                    <p class="text-muted" style="text-align:center; margin-top:15px; font-size:0.9rem;">
                        <i data-lucide="mouse-pointer-click" style="width:16px; display:inline; margin-bottom:-2px;"></i> Geser halaman dari sudut, atau gunakan tombol navigasi di atas untuk membaca isi buku pedoman.
                    </p>

                    <!-- KUNCI FIX 2: Data Base64 disembunyikan di elemen HTML agar tidak merusak Script (Anti Syntax Error) -->
                    <input type="hidden" id="bookletPdfData" value="<%= siteSettings.bookletPdf %>">

                    <!-- KUNCI FIX 3: Konversi Menggunakan Native Fetch API (Anti Nge-freeze/Crash) -->
                    <script>
                        $(document).ready(function () {
                            var pdfBase64 = document.getElementById('bookletPdfData').value;

                            if (pdfBase64) {
                                var options = {
                                    webgl: true,
                                    backgroundColor: "#333333", /* Dark grey background persis seperti GBR 2 */
                                    height: "100%",
                                    width: "100%",
                                    duration: 800
                                };

                                if (pdfBase64.includes('base64,')) {
                                    // Gunakan Fetch API untuk konversi (Sangat Cepat & Tidak Membekukan Browser)
                                    fetch(pdfBase64)
                                        .then(res => res.blob())
                                        .then(blob => {
                                            var pdfUrl = URL.createObjectURL(blob);
                                            // Inisialisasi Flipbook setelah Blob URL berhasil dibuat
                                            $("#df_manual_book").FlipBook(pdfUrl, options);
                                        })
                                        .catch(err => console.error("Error memproses PDF:", err));
                                } else {
                                    // Jika yang tersimpan adalah Link URL PDF biasa
                                    $("#df_manual_book").FlipBook(pdfBase64, options);
                                }
                            }
                        });
                    </script>
                </div>
                <% } %>
                
                <!-- MAPS SEKRETARIAT -->
                <% if (siteSettings.mapsEmbed) { %>
                <div style="grid-column: 1 / -1; margin-top: 20px;">
                    <h3 style="margin-bottom: 15px; font-size:1.5rem; text-align:center; color:#4ade80;">Lokasi Sekretariat</h3>
                    <div style="width: 100%; height: 400px; border-radius: 12px; overflow: hidden; border: 1px solid rgba(255,255,255,0.1); box-shadow: 0 10px 30px rgba(0,0,0,0.2);"><%- siteSettings.mapsEmbed %></div>
                </div>
                <% } %>
                
            </div>
        <% } %>
    </div>
</div>

<div id="tab-visimisi" class="tab-content">
    <div style="text-align: center; margin-bottom: 30px;">
        <h2 style="font-size:2rem; margin-bottom:10px;">Visi dan Misi</h2>
        <p class="text-muted" style="font-size:1.05rem;">Panduan bagi HMI Komisariat Kedokteran Gigi UMI untuk merencanakan kegiatan organisasi.</p>
    </div>
    
    <div style="max-width: 900px; margin: 0 auto; margin-bottom: 50px;">
        <div class="vm-card">
            <div class="vm-icon">🚀</div>
            <h3 class="vm-title">Visi</h3>
            <div class="rich-text-content"><%- siteSettings.visiText || '' %></div>
        </div>

        <div class="vm-card">
            <div class="vm-icon">📈</div>
            <h3 class="vm-title">Misi</h3>
            <div class="rich-text-content"><%- siteSettings.misiText || '' %></div>
        </div>
    </div>
</div>

<!-- STRUKTUR UMUM -->
<div id="tab-struktur" class="tab-content">
    <div class="glass" style="padding: 40px; text-align: center;">
        <h2>Struktur Kepengurusan</h2>
        <p class="text-muted" style="margin-bottom: 40px;">Pengurus Harian</p>
        <div class="grid-4">
            <% pengurus.forEach(person => { %>
            <div class="glass team-card">
                <div class="team-img"><img src="<%= person.image %>" alt="<%= person.name %>"></div>
                <h4 class="team-name"><%= person.name %></h4>
                <p class="team-role"><%= person.role %></p>
            </div>
            <% }) %>
        </div>
        
        <div style="margin-top: 50px; padding-top: 40px; border-top: 1px solid rgba(255,255,255,0.1);">
            <h3 style="margin-bottom:30px; text-align:center;">Bidang-Bidang</h3>
            <div style="display:flex; flex-direction:column; gap:40px;">
                <% bidang.forEach(b => { %>
                    <div>
                        <h4 style="color:#4ade80; border-bottom:1px dashed rgba(255,255,255,0.2); padding-bottom:10px; margin-bottom:20px; text-align:center;"><%= b.name %></h4>
                        <% if(b.members && b.members.length > 0) { %>
                            <div class="grid-4" style="justify-content:center;">
                                <% b.members.forEach(m => { %>
                                    <div class="glass team-card" style="padding:15px;">
                                        <div class="team-img" style="width:80px; height:80px;"><img src="<%= m.image %>" alt="<%= m.name %>"></div>
                                        <h4 class="team-name" style="font-size:0.95rem;"><%= m.name %></h4>
                                        <!-- JABATAN ANGGOTA BIDANG (UMUM) -->
                                        <% if(m.role) { %>
                                            <p style="color:#4ade80; font-size:0.8rem; font-weight:bold; margin-top:2px;"><%= m.role %></p>
                                        <% } %>
                                    </div>
                                <% }) %>
                            </div>
                        <% } else { %>
                            <p style="text-align:center; color:#9ca3af; font-size:0.9rem;">Belum ada anggota.</p>
                        <% } %>
                    </div>
                <% }) %>
            </div>
        </div>
    </div>
</div>

<!-- STRUKTUR LENGKAP KOHATI -->
<% if (String(siteSettings.kohatiActive) === 'true') { %>
<div id="tab-kohati" class="tab-content">
    <div class="glass" style="padding: 40px; border-top: 5px solid #f472b6;">
        
        <!-- PROFIL KOHATI -->
        <div style="margin-bottom: 50px;">
            <h2 style="color: #f472b6; margin-bottom: 20px; border-bottom: 1px solid rgba(244,114,182,0.3); padding-bottom: 10px; display: inline-block;"><i data-lucide="heart"></i> Profil KOHATI</h2>
            <div class="rich-text-content" style="font-size:1.05rem; line-height:1.7;">
                <%- siteSettings.kohatiProfilText || '' %>
            </div>
        </div>

        <!-- VISI & MISI KOHATI -->
        <div style="margin-bottom: 50px;">
            <h2 style="color: #f472b6; margin-bottom: 20px; border-bottom: 1px solid rgba(244,114,182,0.3); padding-bottom: 10px; display: inline-block; width:100%;"><i data-lucide="target"></i> Visi & Misi KOHATI</h2>
            
            <div class="vm-card" style="border-left-color: #f472b6; background: rgba(244,114,182,0.1);">
                <div class="vm-icon" style="color: #f472b6;">🚀</div>
                <h3 class="vm-title" style="color: #f472b6;">Visi KOHATI</h3>
                <div class="rich-text-content"><%- siteSettings.kohatiVisiText || '' %></div>
            </div>

            <div class="vm-card" style="border-left-color: #f472b6; background: rgba(244,114,182,0.1);">
                <div class="vm-icon" style="color: #f472b6;">📈</div>
                <h3 class="vm-title" style="color: #f472b6;">Misi KOHATI</h3>
                <div class="rich-text-content"><%- siteSettings.kohatiMisiText || '' %></div>
            </div>
        </div>

        <div style="text-align: center;">
            <h2 style="color: #f472b6; margin-bottom: 10px;"><i data-lucide="users"></i> Struktur Kepengurusan KOHATI</h2>
            <p class="text-muted" style="margin-bottom: 40px;">Pengurus Harian</p>
            
            <div class="grid-4">
                <% kohatiPengurus.forEach(person => { %>
                <div class="glass team-card" style="border-color: rgba(244,114,182,0.2);">
                    <div class="team-img" style="border-color: rgba(244,114,182,0.5);"><img src="<%= person.image %>"></div>
                    <h4 class="team-name"><%= person.name %></h4>
                    <p style="color:#f472b6; font-size:0.85rem; font-weight:bold;"><%= person.role %></p>
                </div>
                <% }) %>
            </div>
            
            <div style="margin-top: 50px; padding-top: 40px; border-top: 1px solid rgba(244,114,182,0.2);">
                <h3 style="margin-bottom:30px; text-align:center; color:#f472b6;">Bidang-Bidang Kohati</h3>
                <div style="display:flex; flex-direction:column; gap:40px;">
                    <% kohatiBidang.forEach(b => { %>
                        <div>
                            <h4 style="color:#f472b6; border-bottom:1px dashed rgba(244,114,182,0.3); padding-bottom:10px; margin-bottom:20px; text-align:center;"><%= b.name %></h4>
                            <% if(b.members && b.members.length > 0) { %>
                                <div class="grid-4" style="justify-content:center;">
                                    <% b.members.forEach(m => { %>
                                        <div class="glass team-card" style="padding:15px; border-color: rgba(244,114,182,0.2);">
                                            <div class="team-img" style="width:80px; height:80px; border-color: rgba(244,114,182,0.5);"><img src="<%= m.image %>"></div>
                                            <h4 class="team-name" style="font-size:0.95rem;"><%= m.name %></h4>
                                            <!-- JABATAN ANGGOTA BIDANG (KOHATI) -->
                                            <% if(m.role) { %>
                                                <p style="color:#f472b6; font-size:0.8rem; font-weight:bold; margin-top:2px;"><%= m.role %></p>
                                            <% } %>
                                        </div>
                                    <% }) %>
                                </div>
                            <% } else { %>
                                <p style="text-align:center; color:#9ca3af; font-size:0.9rem;">Belum ada anggota.</p>
                            <% } %>
                        </div>
                    <% }) %>
                </div>
            </div>
        </div>
    </div>
</div>
<% } %>

<script>
    function openTab(tabId) {
        document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));
        document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
        document.getElementById(tabId).classList.add('active');
        event.currentTarget.classList.add('active');
    }
    
    // Inisialisasi Ulang Lucide Icon setelah pergantian tab atau DOM render
    document.addEventListener('DOMContentLoaded', () => {
        if(typeof lucide !== 'undefined') lucide.createIcons();
    });
</script>

<%- include('partials/footer') %>
