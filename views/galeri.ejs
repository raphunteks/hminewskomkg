<%- include('partials/header') %>

<div class="text-center mb-10">
    <h2 class="text-3xl font-bold mb-4">Galeri Kegiatan</h2>
    <p class="text-gray-400">Dokumentasi kegiatan dan momen inspiratif kader HMI KomKG-UMI</p>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
    <% albums.forEach(album => { %>
    <div class="glass-panel p-4 rounded-2xl cursor-pointer hover:bg-white/10 transition-all duration-300 group">
        <div class="relative h-48 rounded-xl overflow-hidden mb-4">
            <img src="<%= album.cover %>" class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-500" alt="<%= album.title %>">
            <div class="absolute bottom-2 right-2 bg-black/70 backdrop-blur px-2 py-1 rounded text-xs flex items-center text-white border border-white/10">
                <i data-lucide="image" class="w-3 h-3 mr-1"></i> Album
            </div>
        </div>
        <h3 class="text-xl font-bold mb-1 group-hover:text-green-400 transition-colors"><%= album.title %></h3>
        <p class="text-sm text-gray-400 flex items-center"><i data-lucide="calendar" class="w-4 h-4 mr-2"></i> <%= album.date %></p>
    </div>
    <% }) %>
</div>

<%- include('partials/footer') %>