<%- include('partials/header') %>

<div style="text-align: center; margin-bottom: 40px;">
    <h2>Galeri Kegiatan</h2>
    <p class="text-muted">Dokumentasi kegiatan dan momen inspiratif kader HMI KomKG-UMI</p>
</div>

<div class="grid-3">
    <% albums.forEach(album => { %>
    <!-- SEKARANG BISA DI-KLIK UNTUK MENUJU HALAMAN DETAIL -->
    <a href="/galeri/<%= album.id %>" class="glass gallery-card" style="display:block; cursor:pointer;">
        <div class="gallery-img-box">
            <img src="<%= album.cover %>" alt="<%= album.title %>">
            <div class="photo-count"><i data-lucide="image" style="width:14px;"></i> <% if(album.photos && album.photos.length > 0){ %><%= album.photos.length + 1 %><% } else { %>1<% } %> Foto</div>
        </div>
        <h3 style="font-size:1.2rem; transition:0.3s;"><%= album.title %></h3>
        <p class="text-muted" style="font-size:0.85rem; display:flex; align-items:center; gap:5px; margin-top:5px;"><i data-lucide="calendar" style="width:14px;"></i> <%= album.date %></p>
    </a>
    <% }) %>
</div>

<%- include('partials/footer') %>
