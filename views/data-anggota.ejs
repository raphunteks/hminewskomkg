<%- include('partials/header') %>

<div style="max-width: 900px; margin: 0 auto; text-align: center; margin-bottom: 50px;">
    <h2>Data Anggota HMI KomKG-UMI</h2>
    <p class="text-muted" style="margin-bottom: 30px;">Database keanggotaan terupdate. Pilih dan preview file PDF dibawah ini yang telah di-upload oleh admin.</p>
    
    <% if(dataAnggota && dataAnggota.length > 0) { %>
        <!-- Tab navigation for multiple PDFs -->
        <div style="display:flex; flex-wrap:wrap; gap:10px; justify-content:center; margin-bottom: 20px;">
            <% dataAnggota.forEach((item, index) => { %>
                <button class="btn <%= index === 0 ? 'btn-primary' : 'btn-secondary' %>" onclick="changePdf('<%= item.file %>', this)" style="padding: 8px 16px; font-size: 0.85rem;">
                    <i data-lucide="file-text" style="width:16px;"></i> <%= item.title %>
                </button>
            <% }) %>
        </div>

        <div class="glass" style="padding: 15px; height: 75vh;">
            <iframe id="pdf-viewer" src="<%= dataAnggota[0].file %>" style="width:100%; height:100%; border-radius:10px; background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.1);" frameborder="0">
                Browser Anda tidak mendukung iframe PDF. Silakan download PDF ini.
            </iframe>
        </div>
    <% } else { %>
        <div class="glass" style="padding: 50px; text-align:center;">
            <i data-lucide="file-x" style="width:60px; height:60px; color:#9ca3af; margin:bottom:15px; display:inline-block;"></i>
            <h3 style="color:#fff;">Belum ada Data Anggota</h3>
            <p class="text-muted">Admin belum mengunggah file data anggota.</p>
        </div>
    <% } %>
</div>

<script>
    function changePdf(src, btn) {
        document.getElementById('pdf-viewer').src = src;
        
        // Update active button styling
        document.querySelectorAll('button[onclick^="changePdf"]').forEach(b => {
            b.classList.remove('btn-primary');
            b.classList.add('btn-secondary');
        });
        btn.classList.remove('btn-secondary');
        btn.classList.add('btn-primary');
    }
</script>

<%- include('partials/footer') %>
