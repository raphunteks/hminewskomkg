<% 
    // ==============================================================
    // FIX ERROR 500 (SERVER CRASH): 
    // Injeksi variabel SEO secara eksplisit sebelum memanggil header
    // Mencegah ReferenceError pada fitur Expert SEO (Breadcrumbs)
    // ==============================================================
    let pageTitle = "Data Anggota";
    let pageDescription = "Database keanggotaan terupdate HMI Komisariat Kedokteran Gigi UMI. Akses arsip data kader dan pengurus komisariat.";
    
    // Konstanta Base URL untuk Expert SEO PDF Indexing
    const seoBaseUrl = 'https://www.hmikomkgumi.xyz';
%>
<%- include('partials/header', { pageTitle: pageTitle, pageDescription: pageDescription }) %>

<!-- ==============================================================
     SUPER BIG UPGRADE SEO: DYNAMIC META TAGS INJECTION
     Memastikan Judul, Deskripsi, Gambar & Canonical Terindeks Sempurna
============================================================== -->
<script>
document.addEventListener('DOMContentLoaded', () => {
    const metaTags = [
        { name: "description", content: "<%= pageDescription %>" },
        { name: "keywords", content: "Data Anggota HMI, Database Kader HMI, HMI KomKG UMI, Kedokteran Gigi UMI, Mahasiswa FKG UMI, Pengurus HMI Makassar, Yakusa" },
        { name: "author", content: "Admin HMI KomKG UMI" },
        { name: "robots", content: "index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" },
        
        // Open Graph (WhatsApp, FB, IG)
        { property: "og:title", content: "<%= pageTitle %> | HMI KomKG UMI" },
        { property: "og:description", content: "<%= pageDescription %>" },
        { property: "og:type", content: "website" },
        { property: "og:url", content: "<%= seoBaseUrl %>/data-anggota" },
        { property: "og:image", content: "<%= seoBaseUrl %>/img/logo.png" }, // Pastikan logo.png ada di folder public/img
        { property: "og:site_name", content: "HMI KomKG UMI" },
        
        // Twitter Cards
        { property: "twitter:card", content: "summary_large_image" },
        { property: "twitter:title", content: "<%= pageTitle %> | HMI KomKG UMI" },
        { property: "twitter:description", content: "<%= pageDescription %>" },
        { property: "twitter:image", content: "<%= seoBaseUrl %>/img/logo.png" }
    ];

    // Injeksi Link Canonical ke Google Search Console
    let canonical = document.createElement('link');
    canonical.rel = 'canonical';
    canonical.href = "<%= seoBaseUrl %>/data-anggota";
    document.head.appendChild(canonical);

    // Injeksi Meta Tags ke dalam Head
    metaTags.forEach(tag => {
        let selector = tag.name ? `meta[name="${tag.name}"]` : `meta[property="${tag.property}"]`;
        if (!document.head.querySelector(selector)) {
            let el = document.createElement('meta');
            if(tag.name) el.name = tag.name;
            if(tag.property) el.setAttribute('property', tag.property);
            el.content = tag.content;
            document.head.appendChild(el);
        }
    });
});
</script>

<div style="max-width: 900px; margin: 0 auto; text-align: center; margin-bottom: 50px;">
    <h2 style="color:#4ade80; margin-bottom:15px; font-weight:bold; font-size:2rem;">Data Anggota HMI KomKG-UMI</h2>
    <p class="text-muted" style="margin-bottom: 40px;">Database keanggotaan terupdate. Pilih dan preview file PDF dibawah ini.</p>
    
    <% 
    // ==============================================================
    // UPGRADE LOGIC (SMART FALLBACK & CRUD INTEGRATION): 
    // ==============================================================
    // Jika data dari Admin/Database kosong, otomatis pakai file default
    let pdfList = (typeof dataAnggota !== 'undefined' && dataAnggota && dataAnggota.length > 0) 
                  ? dataAnggota 
                  : [{ title: "Data Anggota Komisariat (Default)", file: "/data-anggota.pdf", date: "Default" }];
    %>

    <!-- ==============================================================
         SUPER BIG UPGRADE SEO: ADVANCED @GRAPH JSON-LD
         Mendikte Google tentang Halaman Web, Breadcrumb, dan Dataset PDF
    ============================================================== -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "WebPage",
          "@id": "<%= seoBaseUrl %>/data-anggota/#webpage",
          "url": "<%= seoBaseUrl %>/data-anggota",
          "name": "<%= pageTitle %> | HMI KomKG UMI",
          "description": "<%= pageDescription %>",
          "inLanguage": "id-ID",
          "isPartOf": { "@id": "<%= seoBaseUrl %>/#website" }
        },
        {
          "@type": "BreadcrumbList",
          "@id": "<%= seoBaseUrl %>/data-anggota/#breadcrumb",
          "itemListElement": [
            {
              "@type": "ListItem",
              "position": 1,
              "name": "Beranda",
              "item": "<%= seoBaseUrl %>/"
            },
            {
              "@type": "ListItem",
              "position": 2,
              "name": "Data Anggota",
              "item": "<%= seoBaseUrl %>/data-anggota"
            }
          ]
        },
        {
          "@type": "Dataset",
          "@id": "<%= seoBaseUrl %>/data-anggota/#dataset",
          "name": "Database Anggota HMI KomKG UMI",
          "description": "Kumpulan data anggota, kader, dan pengurus Himpunan Mahasiswa Islam Komisariat Kedokteran Gigi UMI.",
          "creator": {
            "@type": "Organization",
            "name": "HMI KomKG UMI",
            "url": "<%= seoBaseUrl %>"
          },
          "distribution": [
            <% pdfList.forEach((item, index) => { 
                let absolutePdfUrl = item.file.startsWith('http') ? item.file : seoBaseUrl + (item.file.startsWith('/') ? '' : '/') + item.file;
            %>
            {
              "@type": "DataDownload",
              "name": "<%- JSON.stringify(item.title).slice(1, -1) %>",
              "encodingFormat": "application/pdf",
              "contentUrl": "<%= absolutePdfUrl %>"
            }<%= index < pdfList.length - 1 ? ',' : '' %>
            <% }) %>
          ]
        }
      ]
    }
    </script>

    <!-- Tab navigation for multiple PDFs -->
    <!-- UPGRADE SEO: Mengubah <button> menjadi <a> tag dengan href valid agar Googlebot bisa merayapi PDF-nya -->
    <div style="display:flex; flex-wrap:wrap; gap:10px; justify-content:center; margin-bottom: 30px;" itemscope itemtype="https://schema.org/ItemList">
        <meta itemprop="name" content="Daftar Dokumen PDF Data Anggota" />
        
        <% pdfList.forEach((item, index) => { 
            let absolutePdfUrl = item.file.startsWith('http') ? item.file : seoBaseUrl + (item.file.startsWith('/') ? '' : '/') + item.file;
        %>
            <article itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem" style="display: contents;">
                <meta itemprop="position" content="<%= index + 1 %>" />
                <a href="<%= absolutePdfUrl %>" 
                   onclick="event.preventDefault(); changePdf('<%= item.file %>', this)" 
                   class="btn <%= index === 0 ? 'btn-primary' : 'btn-secondary' %> tab-pdf-btn" 
                   style="padding: 10px 20px; font-size: 0.9rem; border-radius: 12px; transition: all 0.3s ease; box-shadow: 0 4px 10px rgba(0,0,0,0.15);"
                   itemprop="item">
                    <i data-lucide="external-link" style="width:18px;"></i> 
                    <span itemprop="name"><%= item.title %></span>
                </a>
            </article>
        <% }) %>
    </div>

    <!-- PURE CSS 3D PDF VIEWER -->
    <!-- Menggunakan parameter view=FitH agar otomatis presisi & bisa di-scroll vertikal -->
    <div class="css3d-pdf-wrapper" style="margin-top: 0;">
        <div class="css3d-pdf-frame">
            <iframe 
                id="pdf-viewer" 
                src="<%= pdfList[0].file %>#toolbar=0&navpanes=0&view=FitH" 
                class="native-pdf-viewer" 
                title="Data Anggota Viewer"
                scrolling="yes"
                style="width: 100%; height: 100%; border: none;">
                Browser Anda tidak mendukung iframe PDF. Silakan <a href="<%= pdfList[0].file.startsWith('http') ? pdfList[0].file : seoBaseUrl + (pdfList[0].file.startsWith('/') ? '' : '/') + pdfList[0].file %>" target="_blank" style="color:#4ade80; text-decoration:underline;">download PDF ini</a>.
            </iframe>
        </div>
    </div>
    
    <p class="text-muted" style="text-align:center; margin-top:20px; font-size:0.9rem;">
        <i data-lucide="mouse-pointer-click" style="width:16px; display:inline; margin-bottom:-2px;"></i> Klik tombol di atas untuk membuka PDF di tab baru, atau scroll pada area dokumen untuk membaca.
    </p>
</div>

<script>
    function changePdf(src, btn) {
        // Update iframe src (Mempertahankan parameter view=FitH agar tampilan tetap presisi vertikal)
        document.getElementById('pdf-viewer').src = src + '#toolbar=0&navpanes=0&view=FitH';
        
        // Animasi perpindahan warna tombol Tab
        document.querySelectorAll('.tab-pdf-btn').forEach(b => {
            b.classList.remove('btn-primary');
            b.classList.add('btn-secondary');
        });
        btn.classList.remove('btn-secondary');
        btn.classList.add('btn-primary');

        // Buka file PDF langsung di tab baru secara otomatis saat di-klik
        // Menggunakan Absolute URL agar path-nya tidak rusak di tab baru
        let absoluteSrc = src;
        if (!src.startsWith('http')) {
            absoluteSrc = 'https://www.hmikomkgumi.xyz' + (src.startsWith('/') ? '' : '/') + src;
        }
        window.open(absoluteSrc, '_blank');
    }
</script>

<%- include('partials/footer') %>
