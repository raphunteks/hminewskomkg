<%- include('partials/header') %>

<div class="auth-wrapper">
    <div class="glass auth-card">
        <div class="auth-top-line"></div>
        
        <div class="auth-header">
            <div class="auth-icon"><i data-lucide="lock" style="width:30px; height:30px;"></i></div>
            <h2>Admin Login</h2>
            <p class="text-muted">Dashboard Pengelola Website</p>
        </div>
        
        <% if (error) { %>
            <div class="alert-error"><%= error %></div>
        <% } %>

        <form action="/admin/login" method="POST">
            <div class="form-group">
                <label>Username</label>
                <input type="text" name="username" class="input-control" required placeholder="Masukkan username">
            </div>
            <div class="form-group">
                <label>Password</label>
                <input type="password" name="password" class="input-control" required placeholder="••••••••">
            </div>
            <button type="submit" class="btn btn-primary" style="width:100%; margin-top:10px;">Masuk Ke Dashboard</button>
        </form>
    </div>
</div>

<%- include('partials/footer') %>
