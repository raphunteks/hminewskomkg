<%- include('partials/header') %>

<div class="flex items-center justify-center min-h-[50vh]">
    <div class="w-full max-w-md p-8 rounded-3xl glass-panel border border-white/10 bg-black/30 backdrop-blur-xl shadow-2xl relative overflow-hidden">
        <div class="absolute top-0 left-0 w-full h-1.5 bg-gradient-to-r from-green-400 to-emerald-600"></div>
        
        <div class="text-center mb-8">
            <div class="inline-flex p-3 rounded-2xl bg-green-500/20 text-green-400 mb-4">
                <i data-lucide="lock" class="w-8 h-8"></i>
            </div>
            <h2 class="text-2xl font-bold">Admin Login</h2>
            <p class="text-gray-400 text-sm mt-1">Dashboard Pengelola Website</p>
        </div>
        
        <% if (error) { %>
            <div class="bg-red-500/20 text-red-300 p-3 rounded-xl text-center mb-6 border border-red-500/30 text-sm"><%= error %></div>
        <% } %>

        <form action="/admin/login" method="POST" class="space-y-5">
            <div>
                <label class="block text-sm font-medium text-gray-300 mb-1">Username</label>
                <input type="text" name="username" class="w-full px-4 py-3 rounded-xl bg-black/50 border border-white/10 focus:border-green-500 focus:outline-none focus:ring-1 focus:ring-green-500 text-white transition-all" required placeholder="Masukkan username">
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-300 mb-1">Password</label>
                <input type="password" name="password" class="w-full px-4 py-3 rounded-xl bg-black/50 border border-white/10 focus:border-green-500 focus:outline-none focus:ring-1 focus:ring-green-500 text-white transition-all" required placeholder="••••••••">
            </div>
            <button type="submit" class="w-full py-3 rounded-xl bg-green-500 hover:bg-green-400 text-black font-bold transition-all shadow-lg hover:shadow-green-500/40 mt-2">Masuk</button>
        </form>
    </div>
</div>

<%- include('partials/footer') %>